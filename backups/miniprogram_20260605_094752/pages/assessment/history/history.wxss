/* 成长记录页面样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 顶部操作栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
}

.header-info {
  display: flex;
  align-items: center;
}

.record-count {
  font-size: 28rpx;
  color: #666;
}

.header-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 记录列表 */
.record-list {
  padding: 24rpx 32rpx;
}

.record-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.record-item:active {
  transform: scale(0.98);
}

.record-left {
  margin-right: 20rpx;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  background: #FFF3ED;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
}

.record-level {
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.record-info {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.record-child {
  font-size: 24rpx;
  color: #666;
}

.record-divider {
  font-size: 24rpx;
  color: #CCC;
  margin: 0 12rpx;
}

.record-score {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 500;
}

.record-time {
  font-size: 22rpx;
  color: #999;
}

.record-right {
  margin-left: 12rpx;
}

.record-arrow {
  font-size: 36rpx;
  color: #CCC;
}

.delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.record-item:active .delete-btn {
  opacity: 1;
}

.delete-icon {
  font-size: 32rpx;
  color: #CCC;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #FF6B35, #FF7E4B);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
}

/* 骨架屏样式 */
.skeleton-container {
  padding: 24rpx 32rpx;
}

.skeleton-record {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.skeleton-record-content {
  flex: 1;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

/* 筛选弹窗 */
.filter-modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
}

.filter-section {
  padding: 24rpx 32rpx;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 16rpx 28rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.filter-option.active {
  background: #FFF3ED;
  color: #FF6B35;
  border-color: #FF6B35;
}

.filter-footer {
  display: flex;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  gap: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.reset-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666;
  background: #F5F5F5;
  border-radius: 44rpx;
}

.confirm-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #FF6B35, #FF7E4B);
  border-radius: 44rpx;
}

/* 趋势弹窗 */
.trend-modal {
  width: 90%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.trend-chart {
  padding: 32rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
  padding: 20rpx 0;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  width: 60rpx;
  height: 200rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.bar {
  width: 40rpx;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 20rpx;
  transition: height 0.5s ease;
}

.bar-label {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  margin-top: 8rpx;
}

.bar-date {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.trend-legend {
  padding: 0 32rpx 32rpx;
  text-align: center;
}

.legend-text {
  font-size: 24rpx;
  color: #888;
}
