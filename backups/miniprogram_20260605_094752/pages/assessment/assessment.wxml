<!-- 成长观察 -->
<view class="page">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">成长观察</text>
    <text class="page-subtitle">用结构化问题了解孩子近期表现</text>
  </view>

  <!-- 当前孩子信息 -->
  <view class="child-info" wx:if="{{currentChild}}">
    <view class="child-avatar">{{currentChild.name[0] || '宝'}}</view>
    <view class="child-detail">
      <text class="child-name">{{currentChild.name}}</text>
      <text class="child-age">{{currentChild.ageText || currentChild.age + '岁'}}</text>
    </view>
    <view class="history-entry" bindtap="goToHistory">
      <text class="history-icon">📋</text>
      <text class="history-text">历史记录</text>
      <view class="history-badge" wx:if="{{historyCount > 0}}">{{historyCount}}</view>
    </view>
  </view>

  <view class="age-filter">
    <view class="age-filter-header">
      <text class="age-filter-title">选择年龄段</text>
      <text class="age-filter-subtitle">当前显示适合 {{selectedAgeGroup}} 的观察工具</text>
    </view>
    <scroll-view class="age-scroll" scroll-x enable-flex>
      <view class="age-option {{selectedAgeGroup === item.value ? 'active' : ''}}" wx:for="{{ageOptions}}" wx:key="value" data-age="{{item.value}}" bindtap="onAgeFilterTap">
        {{item.label}}
      </view>
    </scroll-view>
  </view>

  <!-- 观察工具列表 -->
  <view class="assessment-list">
    <view class="empty-assessment" wx:if="{{loadError}}">
      <text class="empty-title">加载失败</text>
      <text class="empty-desc">{{loadError}}</text>
      <button class="empty-action" size="mini" bindtap="retryLoadAssessmentList">重试</button>
    </view>
    <block wx:if="{{!loadError && filteredAssessmentList.length > 0}}">
      <view class="assessment-card" wx:for="{{filteredAssessmentList}}" wx:key="code" bindtap="onAssessmentTap" data-code="{{item.code}}">
        <view class="card-icon-wrap">
          <text class="card-icon">{{item.icon}}</text>
        </view>
        <view class="card-content">
          <text class="card-name">{{item.name}}</text>
          <text class="card-desc">{{item.desc}}</text>
          <view class="card-meta">
            <view class="meta-tags">
              <text class="meta-tag count-tag">共{{item.count}}题</text>
              <text class="meta-tag time-tag">约{{item.duration}}分钟</text>
              <text class="meta-tag age-tag">{{selectedAgeGroup}}</text>
            </view>
            <text class="card-arrow">→</text>
          </view>
        </view>
      </view>
    </block>
    <view class="empty-assessment" wx:if="{{!loadError && filteredAssessmentList.length === 0}}">
      <text class="empty-title">该年龄段暂无可用观察工具</text>
      <text class="empty-desc">可切换其他年龄段，或先完善孩子档案后再查看。</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="footer-text">结构化观察工具，帮助您更了解孩子</text>
    <text class="footer-subtext">结果仅供家庭教育参考，如有明显担忧请咨询专业人士</text>
  </view>
</view>

<!-- 说明弹窗 -->
<view class="modal-mask" wx:if="{{showIntroModal}}" bindtap="closeModal">
  <view class="modal-container" catchtap="preventBubble">
    <view class="modal-header">
      <text class="modal-icon">{{currentAssessment.icon}}</text>
      <text class="modal-title">{{currentAssessment.name}}</text>
      <view class="modal-close" bindtap="closeModal">×</view>
    </view>
    
    <view class="modal-body">
      <view class="intro-section">
        <text class="intro-label">使用说明</text>
        <text class="intro-text">{{currentAssessment.desc}}</text>
      </view>
      
      <view class="intro-info">
        <view class="info-item">
          <text class="info-icon">📝</text>
          <text class="info-label">题目数量</text>
          <text class="info-value">{{currentAssessment.count}}题</text>
        </view>
        <view class="info-item">
          <text class="info-icon">⏱️</text>
          <text class="info-label">预计时间</text>
          <text class="info-value">约{{currentAssessment.duration}}分钟</text>
        </view>
        <view class="info-item">
          <text class="info-icon">👶</text>
          <text class="info-label">年龄段</text>
          <text class="info-value">{{selectedAgeGroup}}</text>
        </view>
      </view>
      
      <view class="intro-tips">
        <text class="tips-title">温馨提示</text>
        <view class="tips-list">
          <text class="tips-item">• 请在安静环境下完成作答</text>
          <text class="tips-item">• 根据孩子最近一个月的表现作答</text>
          <text class="tips-item">• 答题过程中可随时退出保存进度</text>
          <text class="tips-item">• 结果仅供参考，不作为医学或心理诊断依据</text>
        </view>
      </view>
    </view>
    
    <view class="modal-footer">
      <view class="btn-cancel" bindtap="closeModal">取消</view>
      <view class="btn-confirm" bindtap="startAssessment">开始作答</view>
    </view>
  </view>
</view>
