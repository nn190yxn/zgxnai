/* AI聊天页面样式 */

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--bg);
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 210rpx;
  overflow-y: auto;
}

.service-banner {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FFF7ED;
  border: 1rpx solid #FDBA74;
}

.service-banner-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #9A3412;
  margin-bottom: 8rpx;
}

.service-banner-desc {
  display: block;
  font-size: 24rpx;
  color: #B45309;
  line-height: 1.6;
}

.service-banner.info {
  background: #F0F9FF;
  border-color: #BAE6FD;
}

.service-banner.info .service-banner-title {
  color: #075985;
}

.service-banner.info .service-banner-desc {
  color: #0C4A6E;
}

.service-closed {
  margin: 120rpx 16rpx 24rpx;
  padding: 44rpx 32rpx;
  border-radius: 8rpx;
  background: #fff;
  border: 1rpx solid var(--border);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
  text-align: center;
}

.service-closed-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
}

.service-closed-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

.service-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
  gap: 18rpx;
}

.service-action {
  min-width: 150rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 8rpx;
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  padding: 0 22rpx;
}

.service-action.secondary {
  background: #f1f5f9;
  color: var(--text);
}

.operation-section,
.sample-section {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.operation-title,
.sample-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 18rpx;
}

.operation-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.operation-card:last-child {
  border-bottom: none;
}

.operation-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #FFF7ED;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.operation-body {
  flex: 1;
}

.operation-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 6rpx;
}

.operation-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.operation-arrow {
  color: var(--text-muted);
  font-size: 30rpx;
  margin-left: 12rpx;
}

.sample-question {
  margin-top: 14rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: #F8FAFC;
  color: #0F172A;
  font-size: 26rpx;
  line-height: 1.5;
}

.ai-label {
  display: inline-block !important;
  width: fit-content;
  margin-bottom: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #FEF3C7;
  color: #92400E;
  font-size: 22rpx;
  font-weight: 600;
}

.ai-input-notice {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding: 12rpx 24rpx;
  background: #FFFBEB;
  border-top: 1rpx solid #FDE68A;
  color: #92400E;
  font-size: 22rpx;
  text-align: center;
  z-index: 9;
}

/* 消息 */
.message {
  display: flex;
  margin-bottom: 32rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.message.bot .avatar {
  background: var(--primary-bg);
  margin-right: 20rpx;
}

.message.user .avatar {
  background: #E3F2FD;
  margin-left: 20rpx;
}

.bubble {
  max-width: 70%;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-wrap: break-word;
}

.message.bot .bubble {
  background: var(--white);
  border: 1rpx solid var(--border);
  border-top-left-radius: 8rpx;
  color: var(--text);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.message.bot.error .bubble {
  background: #FFF7ED;
  border-color: #FDBA74;
  color: #9A3412;
}

.message.user .bubble {
  background: var(--primary);
  color: #fff;
  border-top-right-radius: 8rpx;
}

.bubble text {
  display: block;
}

.mt20 {
  margin-top: 20rpx;
}

/* 来源标签 */
.sources {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.sources-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.sources text {
  font-size: 22rpx;
  color: var(--primary);
  display: inline;
  margin-right: 12rpx;
}

/* 加载动画 */
.loading-bubble {
  padding: 32rpx 48rpx;
}

.typing {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-light);
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
  30% { transform: translateY(-16rpx); opacity: 1; }
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--white);
  border-top: 1rpx solid var(--border);
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.input-wrapper {
  flex: 1;
  background: var(--bg);
  border-radius: 40rpx;
  padding: 0 32rpx;
}

.input {
  height: 80rpx;
  font-size: 28rpx;
  color: var(--text);
}

.send-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.send-btn[disabled] {
  background: var(--border);
  color: var(--text-muted);
}
