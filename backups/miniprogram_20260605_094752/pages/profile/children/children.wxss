/* 孩子档案列表样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 160rpx;
}

/* 顶部提示 */
.header-tip {
  background: #FFF9E6;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #FFE58F;
}

.tip-text {
  font-size: 24rpx;
  color: #D48806;
}

/* 孩子列表 */
.children-list {
  padding: 24rpx 32rpx;
}

.child-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.child-card:active {
  background: #FAFAFA;
}

/* 星标按钮 */
.star-btn {
  position: absolute;
  top: 16rpx;
  right: 60rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star-icon {
  font-size: 40rpx;
  color: #CCCCCC;
}

.star-btn.active .star-icon {
  color: #FFB800;
}

/* 头像 */
.child-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF3ED, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 50rpx;
}

/* 孩子信息 */
.child-info {
  flex: 1;
  min-width: 0;
}

.child-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.child-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 8rpx;
}

.child-nickname {
  font-size: 26rpx;
  color: #999999;
  margin-right: 12rpx;
}

.default-badge {
  font-size: 20rpx;
  color: #FFFFFF;
  background: #FF6B35;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.child-detail {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.detail-item {
  font-size: 26rpx;
  color: #666666;
}

.detail-divider {
  font-size: 26rpx;
  color: #CCCCCC;
  margin: 0 16rpx;
}

/* 标签 */
.child-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: #FF6B35;
  background: #FFF3ED;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 箭头 */
.arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 36rpx;
  color: #CCCCCC;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 48rpx;
  text-align: center;
}

.add-btn-primary {
  background: linear-gradient(135deg, #FF6B35, #E85A29);
  color: #FFFFFF;
  font-size: 30rpx;
  padding: 24rpx 80rpx;
  border-radius: 40rpx;
  border: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.add-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6B35, #E85A29);
  color: #FFFFFF;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 40rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.add-text {
  font-size: 30rpx;
}

.count-tip {
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 上限提示 */
.max-tip {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFF9E6;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  text-align: center;
}

.max-tip-text {
  font-size: 26rpx;
  color: #D48806;
}
