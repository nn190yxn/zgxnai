/* 能力成长样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(145deg, #E85A29, #FF6B35 40%, #FF7E4B);
  padding: 48rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  position: relative;
  z-index: 1;
}

/* 阅读力提升任务 */
.reading-task-section {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.reading-task-list {
  padding: 0 24rpx;
}

.reading-task-card {
  border: 1rpx solid #F2F2F2;
  border-radius: 16rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  background: #FFFDFC;
}

.reading-task-card:last-child {
  margin-bottom: 0;
}

.reading-task-main {
  flex: 1;
  min-width: 0;
}

.reading-task-visual {
  width: 108rpx;
  min-width: 108rpx;
  height: 132rpx;
  margin-right: 18rpx;
  border-radius: 16rpx;
  background: linear-gradient(160deg, #FFF2EC, #FFE0D1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 107, 53, 0.16);
}

.reading-task-visual-icon {
  font-size: 42rpx;
  line-height: 1;
  margin-bottom: 12rpx;
}

.reading-task-visual-label {
  font-size: 20rpx;
  color: #A9512E;
  text-align: center;
  line-height: 1.2;
}

.reading-task-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.reading-task-level {
  font-size: 20rpx;
  color: #2F80ED;
  background: rgba(47, 128, 237, 0.12);
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}

.reading-task-status {
  font-size: 22rpx;
  color: #999;
  margin-left: auto;
}

.reading-task-status.completed {
  color: #43A047;
}

.reading-task-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.reading-task-age {
  font-size: 20rpx;
  color: #A08C86;
  background: #FAF6F3;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}

.reading-task-material {
  display: block;
  font-size: 23rpx;
  color: #5F514C;
  line-height: 1.55;
  margin-bottom: 6rpx;
}

.reading-task-objective,
.reading-task-duration {
  display: block;
  font-size: 22rpx;
  color: #777;
  line-height: 1.6;
}

.reading-task-steps {
  margin: 10rpx 0;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: #FAF6F3;
}

.reading-task-step {
  display: block;
  font-size: 21rpx;
  color: #6B5B55;
  line-height: 1.55;
}

/* 任务封面图 */
.reading-task-cover {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  object-fit: cover;
}

/* 示例回答 */
.reading-task-example {
  margin: 12rpx 0;
  padding: 16rpx;
  border-radius: 12rpx;
  background: linear-gradient(145deg, #E8F5E9, #C8E6C9);
}

.example-title {
  display: block;
  font-size: 20rpx;
  color: #2E7D32;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.example-bubble {
  background: #fff;
  border-radius: 8rpx;
  padding: 12rpx;
  font-size: 22rpx;
  color: #4E342E;
  line-height: 1.55;
  border-left: 4rpx solid #4CAF50;
}

/* 家长提示 */
.reading-task-tips {
  margin: 12rpx 0;
  padding: 16rpx;
  border-radius: 12rpx;
  background: linear-gradient(145deg, #FFF8E1, #FFECB3);
}

.tips-title {
  display: block;
  font-size: 20rpx;
  color: #FF8F00;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tips-content {
  display: block;
  font-size: 22rpx;
  color: #5D4037;
  line-height: 1.55;
}

.reading-task-prompt {
  display: block;
  font-size: 22rpx;
  color: #E65100;
  line-height: 1.55;
  margin-bottom: 4rpx;
}

.reading-task-actions {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.task-action-btn {
  font-size: 22rpx;
  color: #FF6B35;
}

.task-share-btn {
  font-size: 22rpx;
  color: #2F80ED;
}

.task-voice-btn {
  font-size: 22rpx;
  color: #6A1B9A;
}

.recording-section {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.recording-card {
  padding: 0 24rpx;
}

.recording-tip {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.7;
}

.recording-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
}

.recording-btn {
  font-size: 22rpx;
  color: #2F80ED;
  background: rgba(47, 128, 237, 0.1);
  border-radius: 12rpx;
  padding: 10rpx 14rpx;
}

.recording-btn-stop {
  color: #C62828;
  background: rgba(198, 40, 40, 0.1);
}

.recording-path {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #43A047;
}

.reading-report-section,
.reading-script-section {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.reading-report-card,
.reading-script-card {
  padding: 0 24rpx;
}

.reading-report-line {
  display: block;
  font-size: 24rpx;
  color: #333;
  line-height: 1.8;
}

.reading-report-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #777;
  line-height: 1.7;
}

.reading-script-item {
  display: block;
  font-size: 24rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.reading-script-item:last-child {
  margin-bottom: 0;
}

/* 年级选择 */
.grade-selector {
  margin: -20rpx 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.grade-info {
  display: flex;
  align-items: center;
}

.grade-label {
  font-size: 26rpx;
  color: #888;
  margin-right: 16rpx;
}

.grade-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B35;
}

.grade-arrow {
  font-size: 24rpx;
  color: #aaa;
}

/* 区块头部 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #FF6B35;
}

/* 成长进度概览 */
.progress-section {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.progress-cards {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.progress-card {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  margin: 0 8rpx;
}

.progress-card:first-child {
  margin-left: 0;
}

.progress-card:last-child {
  margin-right: 0;
}

.progress-card.mastered {
  background: linear-gradient(135deg, #FFF3ED, #C8E6C9);
}

.progress-card.learning {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
}

.progress-card.total {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
}

.progress-num {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #333;
  line-height: 1.2;
}

.progress-card.mastered .progress-num {
  color: #FF6B35;
}

.progress-card.learning .progress-num {
  color: #E65100;
}

.progress-card.total .progress-num {
  color: #2F80ED;
}

.progress-label {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #E8E8E8;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF7E4B, #FF6B35);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-rate {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 600;
  white-space: nowrap;
}

/* 今日成长任务 */
.task-section {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.task-count {
  font-size: 24rpx;
  color: #E65100;
  font-weight: 500;
}

.task-list {
  padding: 0 24rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.task-item:last-child {
  border-bottom: none;
}

.task-item.completed {
  opacity: 0.7;
}

.task-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-icon {
  font-size: 40rpx;
}

.task-content {
  flex: 1;
  min-width: 0;
}

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.task-subject {
  font-size: 24rpx;
  color: #888;
  margin-right: 12rpx;
}

.task-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.task-status.pending {
  background: #FFF3E0;
  color: #E65100;
}

.task-status.in_progress {
  background: #E3F2FD;
  color: #2F80ED;
}

.task-status.completed {
  background: #FFF3ED;
  color: #FF6B35;
}

.task-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-progress {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.task-progress-bar {
  flex: 1;
  height: 8rpx;
  background: #E8E8E8;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 12rpx;
}

.task-progress-fill {
  height: 100%;
  background: #2F80ED;
  border-radius: 4rpx;
}

.task-progress-text {
  font-size: 22rpx;
  color: #2F80ED;
  font-weight: 500;
}

.task-arrow {
  font-size: 28rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 学科列表 */
.subject-section {
  margin: 0 32rpx;
}

.subject-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.subject-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.subject-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.card-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #FFF3ED;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-icon {
  font-size: 48rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
}

.card-arrow {
  font-size: 30rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 底部提示 */
.footer-tip {
  padding: 40rpx 32rpx 20rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #aaa;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

/* 年级选择弹窗 */
.grade-picker-modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: relative;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
  color: #aaa;
  line-height: 1;
}

.grade-options {
  padding: 16rpx 32rpx 32rpx;
}

.grade-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: #F8F8F8;
  transition: all 0.2s;
}

.grade-option.active {
  background: #FFF3ED;
}

.grade-option:active {
  background: #F0F0F0;
}

.grade-option.active:active {
  background: #C8E6C9;
}

.grade-option-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.grade-option.active .grade-option-text {
  color: #FF6B35;
  font-weight: 700;
}

.grade-option-check {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: 700;
}

