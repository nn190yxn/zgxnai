# 后端环境变量配置示例
# 复制为 .env 后使用

# === 基础配置 ===
NODE_ENV=production
PORT=8010

# === 数据库配置 ===
DB_PATH=./data/app.db

# === JWT配置 ===
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# === 微信支付配置 ===
WX_APPID=wx_your_appid_here
WX_MCHID=your_merchant_id
WX_API_KEY=your_32_bytes_api_key
WX_NOTIFY_URL=https://api.supercalf.com/api/v1/payment/notify
WX_CERT_PATH=/path/to/apiclient_cert.pem
WX_KEY_PATH=/path/to/apiclient_key.pem

# === 微信小程序虚拟支付配置 ===
WECHAT_VIRTUAL_PAY_OFFER_ID=
WECHAT_VIRTUAL_PAY_ENV=1
WECHAT_VIRTUAL_PAY_SANDBOX_APP_KEY=
WECHAT_VIRTUAL_PAY_APP_KEY=
WECHAT_VIRTUAL_PAY_PRODUCT_MONTH=1001
WECHAT_VIRTUAL_PAY_PRODUCT_QUARTER=1002
WECHAT_VIRTUAL_PAY_PRODUCT_YEAR=1003
WECHAT_MESSAGE_PUSH_TOKEN=

# === 会员配置 ===
ENABLE_PAYMENT=false
TRIAL_DAYS=15
REFERRAL_MAX_DAYS=60
REFERRAL_REWARD_DAYS=7

# === AI问答配置 ===
# 支持 openai / deepseek / kimi / moonshot / qwen / dashscope / openrouter / siliconflow / compatible
AI_PROVIDER=deepseek
AI_API_KEY=your_ai_api_key
AI_MODEL=deepseek-chat
# 可选：未填写时按 provider 使用默认 OpenAI 兼容地址
AI_BASE_URL=
AI_TIMEOUT_MS=12000

# === 后台管理配置 ===
ADMIN_API_PREFIX=/admin-api/v1
ADMIN_JWT_SECRET=change_me_for_admin
ADMIN_JWT_EXPIRES_IN=12h
# 首次初始化后台账号时填写，初始化后可移除
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
