/* 小牛育儿AI助理 v4.0 - 全局样式 */

/* 主题变量 */
page {
  --primary: #FF6B35;
  --primary-light: #FF8F5A;
  --primary-bg: #FFF3ED;
  --accent: #FF8F00;
  --text: #1B2A1B;
  --text-secondary: #7A6660;
  --text-muted: #A08C86;
  --bg: #FAF6F3;
  --white: #FFF;
  --border: #E9D7CF;
  
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background: var(--bg);
  min-height: 100vh;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 卡片 */
.card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* 按钮 */
.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: var(--white);
}

.btn-secondary {
  background: var(--white);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

/* 标题 */
.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 模块图标 */
.module-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

/* 网格布局 */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--primary-bg);
  color: var(--primary);
}

.tag-accent {
  background: #FFF8E1;
  color: var(--accent);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-muted);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* ========== 性能优化通用样式 ========== */

/* 骨架屏动画 */
@keyframes skeleton-loading {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

.skeleton-text {
  height: 28rpx;
  margin-bottom: 16rpx;
}

.skeleton-title {
  height: 40rpx;
  width: 60%;
  margin-bottom: 20rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.skeleton-image {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
}

.skeleton-card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

/* 统一加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 页面过渡动画 */
.page-transition {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 列表项进入动画 */
.list-item-enter {
  animation: slideInUp 0.3s ease-out;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 图片占位符 */
.image-placeholder {
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 48rpx;
}

/* 图片淡入效果 */
.image-fade-in {
  opacity: 0;
  transition: opacity 0.3s ease;
}

.image-fade-in.loaded {
  opacity: 1;
}

/* 优化滚动性能 */
.scroll-view-optimized {
  will-change: transform;
  -webkit-overflow-scrolling: touch;
}

/* 防止重绘优化 */
.gpu-accelerated {
  transform: translateZ(0);
  backface-visibility: hidden;
}
