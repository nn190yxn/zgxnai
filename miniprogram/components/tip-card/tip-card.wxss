/* tip-card 组件样式 - 遵循移动端排版规范 */
.tip-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: var(--white);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tip-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tip-card-text {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-secondary);
  line-height: 1.7;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.tip-card-why {
  margin-top: 16rpx;
}

.tip-card-why-label {
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--primary);
}

.tip-card-rationale {
  margin-top: 12rpx;
  padding: 16rpx 16rpx 16rpx 20rpx;
  background: var(--primary-bg);
  border-left: 4rpx solid var(--primary);
  border-radius: 0 8rpx 8rpx 0;
}

.tip-card-rationale text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.tip-card-source {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
}

.tip-card-source text {
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--primary);
}
