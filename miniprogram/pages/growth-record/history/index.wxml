<view class="page">
  <view class="history-card" wx:for="{{list}}" wx:key="id">
    <view class="history-head">
      <text class="history-date">{{item.recordDate}}</text>
    </view>
    <text class="history-line">情绪：{{item.moodStatus}}  进食：{{item.appetiteStatus}}</text>
    <text class="history-line">睡眠：{{item.sleepStatus}}  活动：{{item.exerciseStatus}}  社交：{{item.socialStatus}}</text>
    <text class="history-note" wx:if="{{item.noteText}}">{{item.noteText}}</text>
  </view>
  <view class="empty-card" wx:if="{{!loading && !list.length}}">还没有记录，今晚先记一次就好</view>
</view>
