<view class="page">
  <view wx:if="{{!currentChild}}" class="empty-card">
    <text class="empty-title">先完善孩子档案，再开始成长记录</text>
    <view class="primary-btn" bindtap="goToChildSetup">去完善档案</view>
  </view>

  <block wx:else>
    <view class="hero-card">
      <text class="hero-title">{{currentChild.name}} 的成长记录</text>
      <picker mode="date" value="{{recordDate}}" bindchange="onDateChange">
        <view class="date-chip">{{recordDate}}</view>
      </picker>
    </view>

    <view class="section-card" wx:for="{{sections}}" wx:key="field">
      <text class="section-title">{{item.title}}</text>
      <view class="option-list">
        <view
          class="option-chip {{form[item.field] === option.value ? 'option-chip-active' : ''}}"
          wx:for="{{item.options}}"
          wx:for-item="option"
          wx:key="value"
          data-field="{{item.field}}"
          data-value="{{option.value}}"
          bindtap="onPickStatus"
        >
          {{option.label}}
        </view>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">今天的补充记录</text>
      <textarea class="note-box" maxlength="500" placeholder="例如：午睡偏短，晚饭时情绪有点急，散步后稳定很多。" value="{{form.noteText}}" bindinput="onNoteInput"></textarea>
    </view>

    <view class="action-row">
      <view class="secondary-btn" bindtap="goToHistory">查看历史记录</view>
      <view class="secondary-btn" bindtap="goToWeeklySummary">查看成长总结</view>
    </view>

    <view class="section-card">
      <text class="section-title">记录建议</text>
      <text class="helper-copy">每天睡前花30秒记一下，坚持一周，你就会看到孩子的变化趋势了。</text>
    </view>

    <view class="primary-btn {{saving ? 'primary-btn-disabled' : ''}}" bindtap="submitRecord">{{saving ? '保存中...' : '保存成长记录'}}</view>
  </block>
</view>
