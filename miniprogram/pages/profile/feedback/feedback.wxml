<!-- 意见反馈 -->
<view class="page">
  <view class="form-card">
    <view class="form-title">告诉我们你的问题或建议</view>
    <view class="form-desc">你的反馈将帮助我们持续改进</view>

    <view class="field">
      <view class="field-label">反馈类型</view>
      <picker mode="selector" range="{{types}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-value">{{types[typeIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">详细描述</view>
      <textarea
        class="content-input"
        value="{{content}}"
        placeholder="请描述你遇到的问题或建议，包括操作步骤、页面位置等，越详细我们越能快速定位…"
        maxlength="1000"
        bindinput="onContentInput"
        auto-height
      />
      <view class="char-count">{{content.length}}/1000</view>
    </view>

    <view class="field">
      <view class="field-label">联系方式（选填）</view>
      <input class="contact-input" value="{{contact}}" placeholder="手机号或微信号，方便我们联系你" bindinput="onContactInput" />
    </view>

    <button class="submit-btn" bindtap="submitFeedback" loading="{{submitting}}" disabled="{{!canSubmit}}">提交反馈</button>
  </view>

  <view class="history-section" wx:if="{{history.length > 0}}">
    <view class="history-title">我的反馈记录</view>
    <view class="history-item" wx:for="{{history}}" wx:key="id">
      <view class="history-type">{{item.type_text || '问题反馈'}}</view>
      <view class="history-content">{{item.content}}</view>
      <view class="history-time">{{item.created_at || ''}}</view>
    </view>
  </view>
</view>
