.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

.header {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.date {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.content {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-top: 30rpx;
  margin-bottom: 20rpx;
}

.section-title:first-child {
  margin-top: 0;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.list-item {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  margin-left: 20rpx;
  margin-bottom: 10rpx;
}
