/* 孩子档案编辑页面样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* 表单容器 */
.form-container {
  padding: 24rpx 32rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF3ED, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 80rpx;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.avatar-edit-icon text {
  font-size: 24rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 表单区块 */
.form-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.section-tip {
  font-size: 24rpx;
  font-weight: normal;
  color: #999999;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.error {
  background: #FFF5F5;
  margin: 0 -24rpx;
  padding: 24rpx;
}

.form-item-textarea {
  flex-direction: column;
  align-items: flex-start;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  width: 160rpx;
  flex-shrink: 0;
}

.form-label.required::before {
  content: '*';
  color: #E53935;
  margin-right: 4rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.form-input::placeholder {
  color: #CCCCCC;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #333333;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
}

/* 单选框 */
.radio-group {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.radio-item {
  display: flex;
  align-items: center;
  margin-left: 40rpx;
}

.radio-label {
  font-size: 28rpx;
  color: #333333;
  margin-left: 8rpx;
}

/* 选择器 */
.form-picker {
  flex: 1;
  text-align: right;
}

.picker-value {
  font-size: 28rpx;
  color: #333333;
}

.picker-value.placeholder {
  color: #CCCCCC;
}

/* 带单位的输入框 */
.input-with-unit {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.input-with-unit .form-input {
  width: 160rpx;
  text-align: right;
}

.unit {
  font-size: 26rpx;
  color: #999999;
  margin-left: 8rpx;
  line-height: 1.45;
}

/* 错误提示 */
.error-tip {
  font-size: 24rpx;
  color: #E53935;
  padding: 8rpx 0 16rpx;
  line-height: 1.6;
}

/* 标签选择 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  background: #F5F5F5;
  border: 2rpx solid transparent;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  margin: 0;
  line-height: 1.45;
  font-size: 26rpx;
  color: #666666;
  box-sizing: border-box;
}

.tag-text {
  font-size: 26rpx;
  line-height: 1.45;
}

.tag-item.selected {
  background: #FFF3ED;
  border-color: #FF6B35;
  color: #FF6B35;
}

.tag-item::after {
  border: none;
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.btn {
  flex: 1;
  min-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  line-height: 1.45;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 20rpx 16rpx;
  box-sizing: border-box;
}

.btn-cancel {
  background: #FFFFFF;
  color: #666666;
  border: 2rpx solid #E0E0E0;
}

.btn-save {
  background: linear-gradient(135deg, #FF6B35, #E85A29);
  color: #FFFFFF;
}

.btn-delete {
  width: 100%;
  min-height: 88rpx;
  background: #FFFFFF;
  color: #E53935;
  border: 2rpx solid #E53935;
  border-radius: 44rpx;
  font-size: 30rpx;
  line-height: 1.45;
  padding: 20rpx 16rpx;
  box-sizing: border-box;
}

/* 删除区域 */
.delete-section {
  margin-top: 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
}
