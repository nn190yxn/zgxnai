<!-- 孩子档案列表 -->
<view class="page">
  <!-- 顶部提示 -->
  <view class="header-tip" wx:if="{{children.length > 0}}">
    <text class="tip-text">点星星设为默认孩子，点卡片可以修改信息</text>
  </view>

  <!-- 孩子列表 -->
  <view class="children-list">
    <block wx:for="{{children}}" wx:key="id">
      <view class="child-card" bindtap="editChild" data-id="{{item.id}}">
        <!-- 星标按钮 -->
        <view class="star-btn {{item.isDefault ? 'active' : ''}}" catchtap="setDefault" data-id="{{item.id}}">
          <text class="star-icon">{{item.isDefault ? '★' : '☆'}}</text>
        </view>

        <!-- 头像 -->
        <view class="child-avatar">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill" class="avatar-img" binderror="onAvatarError" data-id="{{item.id}}"></image>
          <text wx:else class="avatar-text">{{item.gender === 'male' ? '👦' : item.gender === 'female' ? '👧' : '👶'}}</text>
        </view>

        <!-- 信息 -->
        <view class="child-info">
          <view class="child-name-row">
            <text class="child-name">{{item.name}}</text>
            <text class="child-nickname" wx:if="{{item.nickname}}">({{item.nickname}})</text>
            <text class="default-badge" wx:if="{{item.isDefault}}">默认</text>
          </view>
          <view class="child-detail">
            <text class="detail-item">{{item.gender === 'male' ? '男' : item.gender === 'female' ? '女' : '未知'}}</text>
            <text class="detail-divider">|</text>
            <text class="detail-item">{{item.birthday ? item.ageText : '年龄未知'}}</text>
          </view>
          <!-- 标签 -->
          <view class="child-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
        </view>

        <!-- 箭头 -->
        <view class="arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && children.length === 0}}">
    <text class="empty-icon">👶</text>
    <text class="empty-title">还没有添加孩子档案</text>
    <text class="empty-desc">填好年龄和基本情况，建议会更贴合你家孩子</text>
    <button class="add-btn-primary" bindtap="addChild">添加孩子</button>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading && children.length === 0}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 底部添加按钮 -->
  <view class="bottom-bar" wx:if="{{children.length > 0 && children.length < maxChildren}}">
    <button class="add-btn" bindtap="addChild">
      <text class="add-icon">+</text>
      <text class="add-text">添加孩子</text>
    </button>
    <text class="count-tip">已添加 {{children.length}}/{{maxChildren}} 个孩子</text>
  </view>

  <!-- 已达上限提示 -->
  <view class="max-tip" wx:if="{{children.length >= maxChildren}}">
    <text class="max-tip-text">已达到最大数量限制（{{maxChildren}}个）</text>
  </view>
</view>
