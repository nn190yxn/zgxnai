/* 个人中心样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 用户区域 */
.user-section {
  background: linear-gradient(145deg, #E85A29, #FF6B35);
  padding: 60rpx 32rpx;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 28rpx;
  overflow: hidden;
}

.user-avatar-img {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.user-phone {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.88);
}

/* 区块 */
.section {
  padding: 32rpx;
}

.auth-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
}

.auth-copy {
  margin-bottom: 24rpx;
}

.auth-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2F2F2F;
  line-height: 1.5;
}

.auth-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
}

.auth-primary-btn,
.auth-secondary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.auth-primary-btn {
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF6B35, #E85A29);
}

.auth-secondary-btn {
  color: #E85A29;
  background: #FFF3ED;
}

.auth-success {
  background: #FFF7F2;
  border-radius: 20rpx;
  padding: 24rpx;
}

.auth-success-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #E85A29;
}

.auth-success-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

/* 孩子档案入口 */
.child-entry {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.child-entry:active {
  background: #FAFAFA;
}

.child-entry-left {
  display: flex;
  align-items: center;
}

.child-entry-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFF3ED, #C8E6C9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.child-entry-info {
  display: flex;
  flex-direction: column;
}

.child-entry-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.child-entry-desc {
  font-size: 24rpx;
  color: #999999;
}

.child-entry-right {
  display: flex;
  align-items: center;
}

.child-count {
  font-size: 26rpx;
  color: #FF6B35;
  margin-right: 8rpx;
}

.arrow-icon {
  font-size: 36rpx;
  color: #CCCCCC;
}

/* 当前孩子卡片 */
.current-child-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.child-avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF3ED, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img-small {
  width: 100%;
  height: 100%;
}

.avatar-text-small {
  font-size: 40rpx;
}

.child-info-small {
  flex: 1;
  min-width: 0;
}

.child-name-row-small {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.child-name-small {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 12rpx;
}

.default-badge-small {
  font-size: 20rpx;
  color: #FFFFFF;
  background: #FF6B35;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.child-detail-small {
  display: flex;
  align-items: center;
}

.detail-text-small {
  font-size: 24rpx;
  color: #666666;
}

.detail-divider-small {
  font-size: 24rpx;
  color: #CCCCCC;
  margin: 0 12rpx;
}

.switch-btn {
  padding: 12rpx 24rpx;
  background: #FFF3ED;
  border-radius: 20rpx;
}

.switch-btn:active {
  background: #C8E6C9;
}

.switch-text {
  font-size: 26rpx;
  color: #FF6B35;
}

/* 菜单列表 */
.menu-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #FAFAFA;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* 危险操作菜单项 */
.menu-item.danger .menu-text {
  color: #FF3B30;
}

/* 会员入口 */
.membership-entry {
  background: linear-gradient(135deg, #FF6B35, #FF8F35);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.2);
}

.membership-entry:active {
  opacity: 0.9;
}

.membership-entry-left {
  display: flex;
  align-items: center;
}

.membership-entry-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-right: 24rpx;
}

.membership-entry-info {
  display: flex;
  flex-direction: column;
}

.membership-entry-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.membership-entry-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.membership-entry-right {
  display: flex;
  align-items: center;
}

.membership-status {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-right: 8rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
}

.membership-status.active {
  background: rgba(255, 255, 255, 0.3);
  font-weight: 600;
}

/* 版本信息 */
.version {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 24rpx;
}

.version text {
  display: block;
  margin-bottom: 8rpx;
}
