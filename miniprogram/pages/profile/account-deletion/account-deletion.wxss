.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

.warning-card {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.warning-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.warning-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #E65100;
  margin-bottom: 16rpx;
  line-height: 1.45;
}

.warning-text {
  display: block;
  font-size: 28rpx;
  color: #BF360C;
  line-height: 1.65;
}

.info-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.notice-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.notice-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  line-height: 1.45;
}

.notice-text {
  display: block;
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.checkbox-area {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.checkbox-label {
  display: flex;
  align-items: flex-start;
}

checkbox {
  margin-top: 6rpx;
  margin-right: 16rpx;
}

.checkbox-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
}

.delete-btn {
  width: 100%;
  min-height: 96rpx;
  background-color: #FF3B30;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  line-height: 1.45;
  padding: 24rpx 20rpx;
  box-sizing: border-box;
}

.delete-btn.disabled {
  background-color: #CCCCCC;
}

.contact-area {
  text-align: center;
  padding: 30rpx;
}

.contact-text {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 10rpx;
  line-height: 1.6;
}

.contact-email {
  display: block;
  font-size: 26rpx;
  color: #07C160;
  line-height: 1.6;
}
