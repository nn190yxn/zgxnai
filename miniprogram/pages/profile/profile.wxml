<!-- 个人中心 -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-avatar">
      <image wx:if="{{userInfo && userInfo.avatar_url}}" src="{{userInfo.avatar_url}}" mode="aspectFill" class="user-avatar-img"></image>
      <text wx:else>😊</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{isLoggedIn ? (userInfo.nickname || '微信用户') : '未登录'}}</text>
      <text class="user-id">{{isLoggedIn ? ('ID: ' + userInfo.id) : '先完成微信登录，再补充手机号'}}</text>
      <text class="user-phone" wx:if="{{isLoggedIn && phoneNumberMasked}}">已绑定手机号 {{phoneNumberMasked}}</text>
      <text class="user-phone" wx:elif="{{isLoggedIn}}">还没有绑定手机号</text>
    </view>
  </view>

  <view class="section">
    <view class="auth-card">
      <view class="auth-copy">
        <text class="auth-title">先完成微信登录，再继续孩子档案和成长记录</text>
        <text class="auth-desc">登录后你的孩子档案和成长记录就能一直保存着，补充手机号后服务通知也方便。</text>
      </view>
      <button class="auth-primary-btn" wx:if="{{!isLoggedIn}}" bindtap="login">微信一键登录</button>
      <button class="auth-secondary-btn" wx:elif="{{!phoneNumber}}" open-type="getPhoneNumber" bindgetphonenumber="bindPhoneNumber">获取手机号</button>
      <view class="auth-success" wx:else>
        <text class="auth-success-title">登录和手机号绑定都已完成</text>
        <text class="auth-success-desc">添加孩子档案后即可查看成长记录和成长服务。</text>
      </view>
    </view>
  </view>

  <!-- 成长服务状态卡片 -->
  <view class="section" wx:if="{{isLoggedIn}}">
    <view class="membership-entry" bindtap="goToMembership">
      <view class="membership-entry-left">
        <view class="membership-entry-icon">VIP</view>
        <view class="membership-entry-info">
          <text class="membership-entry-title">宝贝成长服务</text>
          <text class="membership-entry-desc" wx:if="{{membershipInfo.is_active}}">{{membershipInfo.membership_type === 'trial' ? '成长服务试用中' : '成长服务已开通'}} 剩余 {{membershipInfo.days_left}} 天</text>
          <text class="membership-entry-desc" wx:else>查看更完整的成长总结和陪伴建议</text>
        </view>
      </view>
      <view class="membership-entry-right">
        <text class="membership-status {{membershipInfo.is_active ? 'active' : ''}}">{{membershipInfo.is_active ? '可查看' : '去查看'}}</text>
        <text class="arrow-icon">›</text>
      </view>
    </view>
  </view>
  <view class="section">
    <view class="child-entry" bindtap="goToChildren">
      <view class="child-entry-left">
        <view class="child-entry-icon">👶</view>
        <view class="child-entry-info">
          <text class="child-entry-title">孩子档案</text>
          <text class="child-entry-desc" wx:if="{{currentChild}}">当前：{{currentChild.name}} {{currentChild.gender === 'male' ? '👦' : currentChild.gender === 'female' ? '👧' : ''}}</text>
          <text class="child-entry-desc" wx:else>填一下孩子的基本信息，建议会更贴合实际情况</text>
        </view>
      </view>
      <view class="child-entry-right">
        <text class="child-count" wx:if="{{childrenCount > 0}}">{{childrenCount}}个孩子</text>
        <text class="arrow-icon">›</text>
      </view>
    </view>

    <!-- 当前孩子信息卡片 -->
    <view class="current-child-card" wx:if="{{currentChild}}">
      <view class="child-avatar-small">
        <image wx:if="{{currentChild.avatar}}" src="{{currentChild.avatar}}" mode="aspectFill" class="avatar-img-small" binderror="onCurrentChildAvatarError"></image>
        <text wx:else class="avatar-text-small">{{currentChild.gender === 'male' ? '👦' : currentChild.gender === 'female' ? '👧' : '👶'}}</text>
      </view>
      <view class="child-info-small">
        <view class="child-name-row-small">
          <text class="child-name-small">{{currentChild.name}}</text>
          <text class="default-badge-small">默认</text>
        </view>
        <view class="child-detail-small">
          <text class="detail-text-small">{{currentChild.gender === 'male' ? '男' : currentChild.gender === 'female' ? '女' : '未知'}}</text>
          <text class="detail-divider-small" wx:if="{{currentChild.birthday}}">|</text>
          <text class="detail-text-small" wx:if="{{currentChild.birthday}}">{{currentChild.ageText || ''}}</text>
        </view>
      </view>
      <view class="switch-btn" bindtap="goToChildren">
        <text class="switch-text">切换</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="viewHistory">
        <text class="menu-icon">📋</text>
        <text class="menu-text">小牛问答记录</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="viewAssessments">
        <text class="menu-icon">📊</text>
        <text class="menu-text">成长记录</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="viewWeeklySummary">
        <text class="menu-icon">📝</text>
        <text class="menu-text">每周成长总结</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="feedback">
        <text class="menu-icon">💬</text>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="aboutUs">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 协议与合规 -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="viewPrivacy">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">隐私保护指引</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="viewAgreement">
        <text class="menu-icon">📜</text>
        <text class="menu-text">用户协议</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item danger" bindtap="viewAccountDeletion">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">账号注销</text>
        <text class="menu-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version">
    <text>小牛育儿 v4.0</text>
    <text>成长观察、每日练习、育儿锦囊、营养建议</text>
  </view>
</view>
