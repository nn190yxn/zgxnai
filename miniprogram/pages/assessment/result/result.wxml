<!-- 成长观察结果页 -->
<view class="page page-transition">
  <!-- 骨架屏加载状态 -->
  <view class="skeleton-detail-container" wx:if="{{loading}}">
    <view style="padding: 60rpx 32rpx;">
      <view class="skeleton" style="width: 200rpx; height: 200rpx; border-radius: 50%; margin: 0 auto 40rpx;"></view>
      <view class="skeleton skeleton-title" style="width: 40%; margin: 0 auto 60rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 100%; margin-bottom: 20rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 90%; margin-bottom: 20rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 95%; margin-bottom: 20rpx;"></view>
    </view>
  </view>

  <block wx:else>
    <!-- 报告头部 -->
    <view class="report-header">
      <view class="header-bg"></view>
      <view class="header-content">
        <text class="assessment-title">{{assessmentName}}</text>
        <text class="child-name">{{childName}}</text>
        <text class="completed-time">{{completedAt}}</text>
      </view>
    </view>

    <!-- 综合评分 -->
    <view class="score-section">
      <view class="score-card">
        <view class="score-circle">
          <view class="circle-bg">
            <view class="circle-progress" style="background: conic-gradient({{levelColor}} {{percentage * 3.6}}deg, #E8E8E8 {{percentage * 3.6}}deg);"></view>
            <view class="circle-inner">
              <text class="score-number">{{percentage}}</text>
              <text class="score-unit">分</text>
            </view>
          </view>
        </view>
        <view class="level-badge" style="background: {{levelColor}};">{{level}}</view>
        <view class="time-info">
          <text class="time-label">用时</text>
          <text class="time-value">{{timeText}}</text>
        </view>
      </view>
    </view>

    <view class="section disclaimer-section">
      <view class="section-header">
        <text class="section-title">免责声明</text>
      </view>
      <view class="disclaimer-card">
        <text class="disclaimer-text">{{disclaimerText}}</text>
      </view>
    </view>

    <!-- 维度得分 -->
    <view class="section" wx:if="{{dimensions.length > 0}}">
      <view class="section-header">
        <text class="section-title">各维度得分</text>
      </view>
      <view class="dimensions-list">
        <view class="dimension-item" wx:for="{{dimensions}}" wx:key="name">
          <view class="dimension-info">
            <text class="dimension-name">{{item.name}}</text>
              <text class="dimension-score">{{item.displayScore || item.score + '分'}}</text>
          </view>
          <view class="dimension-bar">
            <view class="bar-fill" style="width: {{item.score}}%; background: {{item.score >= 70 ? '#FF6B35' : item.score >= 50 ? '#FFA000' : '#FF5722'}};"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 详细解读 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">详细解读</text>
      </view>
      <view class="interpretation-card">
        <text class="interpretation-text">{{interpretation}}</text>
      </view>
    </view>

    <!-- 年龄段专属解读 -->
    <view class="section" wx:if="{{ageNote}}">
      <view class="section-header">
        <text class="section-title">本年龄段说明</text>
      </view>
      <view class="age-context-card">
        <view class="age-context-row">
          <text class="age-context-label">发展阶段</text>
          <text class="age-context-text">{{ageNote}}</text>
        </view>
        <view class="age-context-row" wx:if="{{expectedByAge}}">
          <text class="age-context-label">年龄预期</text>
          <text class="age-context-text">{{expectedByAge}}</text>
        </view>
        <view class="age-context-row" wx:if="{{priorityFocus}}">
          <text class="age-context-label">优先方向</text>
          <text class="age-context-text">{{priorityFocus}}</text>
        </view>
      </view>
    </view>

    <!-- 个性化建议 -->
    <view class="section" wx:if="{{suggestions.length > 0}}">
      <view class="section-header">
        <text class="section-title">个性化建议</text>
      </view>
      <view class="suggestions-list">
        <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="title">
          <view class="suggestion-icon">{{index + 1}}</view>
          <view class="suggestion-content">
            <text class="suggestion-title">{{item.title}}</text>
            <text class="suggestion-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 家庭支持建议 -->
    <view class="section" wx:if="{{trainingPlans.length > 0}}">
      <view class="section-header">
        <text class="section-title">家庭支持建议</text>
      </view>
      <view class="plans-list">
        <view class="plan-item" wx:for="{{trainingPlans}}" wx:key="name">
          <view class="plan-header">
            <text class="plan-name">{{item.name}}</text>
            <text class="plan-duration">{{item.duration}}</text>
          </view>
          <text class="plan-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="bottom-actions">
      <view class="action-btn share-btn" bindtap="shareReport">
        <text class="btn-icon">📤</text>
        <text class="btn-text">分享报告</text>
      </view>
      <view class="action-btn save-btn" bindtap="saveToAlbum">
        <text class="btn-icon">📷</text>
        <text class="btn-text">保存图片</text>
      </view>
      <view class="action-btn history-btn" bindtap="goToHistory">
        <text class="btn-icon">📋</text>
        <text class="btn-text">历史记录</text>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-buttons">
      <view class="btn-secondary" bindtap="goBack">返回</view>
      <view class="btn-primary" bindtap="redoAssessment">重新作答</view>
    </view>

    <!-- 底部提示 -->
    <view class="footer-tip">
      <text class="tip-text">结果仅供参考，不能替代专业评估或诊断</text>
      <text class="tip-text">如有疑问请咨询专业人士</text>
    </view>
  </block>
</view>
