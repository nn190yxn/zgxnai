/* 成长观察结果页样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #888;
}

/* 报告头部 */
.report-header {
  position: relative;
  padding: 48rpx 32rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(145deg, #E85A29, #FF6B35 40%, #FF7E4B);
}

.header-content {
  position: relative;
  z-index: 1;
  padding-top: 20rpx;
}

.assessment-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  line-height: 1.45;
}

.child-name {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
  line-height: 1.45;
}

.completed-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 综合评分 */
.score-section {
  padding: 0 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.score-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.circle-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
}

.circle-progress {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
}

.circle-inner {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
}

.score-unit {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.level-badge {
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.time-label {
  font-size: 24rpx;
  color: #888;
}

.time-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 通用section */
.section {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

/* 维度得分 */
.dimensions-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dimension-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dimension-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dimension-name {
  font-size: 28rpx;
  color: #333;
}

.dimension-score {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.dimension-bar {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 详细解读 */
.interpretation-card {
  background: #F8F9F8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.disclaimer-section {
  border-left: 6rpx solid #FFB74D;
}

.disclaimer-card {
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 24rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: #8A5A00;
  line-height: 1.7;
}

.interpretation-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 个性化建议 */
.suggestions-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.suggestion-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF6B35, #FF7E4B);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.suggestion-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.suggestion-meta {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.suggestion-meta-tag {
  font-size: 20rpx;
  color: #d65a1f;
  background: #fff1ea;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

/* 训练方案 */
.plans-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plan-item {
  background: #F8F9F8;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #E8E8E8;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.plan-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.plan-duration {
  font-size: 22rpx;
  color: #FF6B35;
  background: #FFF3ED;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.plan-desc {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.plan-action {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 500;
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-btn .btn-icon {
  font-size: 40rpx;
}

.action-btn .btn-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.45;
}

/* 底部按钮 */
.bottom-buttons {
  display: flex;
  padding: 0 32rpx;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.btn-secondary {
  flex: 1;
  min-height: 88rpx;
  line-height: 1.45;
  text-align: center;
  font-size: 30rpx;
  color: #FF6B35;
  background: #fff;
  border: 2rpx solid #FF6B35;
  border-radius: 44rpx;
  padding: 20rpx 16rpx;
  box-sizing: border-box;
}

.btn-primary {
  flex: 1;
  min-height: 88rpx;
  line-height: 1.45;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #FF6B35, #FF7E4B);
  border-radius: 44rpx;
  padding: 20rpx 16rpx;
  box-sizing: border-box;
}

/* 年龄段专属解读 */
.age-context-card {
  background: #f8f5ef;
  border-radius: 16rpx;
  padding: 24rpx;
}

.age-context-row {
  margin-bottom: 20rpx;
}

.age-context-row:last-child {
  margin-bottom: 0;
}

.age-context-label {
  display: block;
  font-size: 24rpx;
  color: #d65a1f;
  font-weight: 600;
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.age-context-text {
  display: block;
  font-size: 26rpx;
  color: #4f453f;
  line-height: 1.7;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 20rpx 32rpx;
}

.tip-text {
  display: block;
  font-size: 22rpx;
  color: #aaa;
  line-height: 1.6;
}

.membership-cta-section {
  margin: 0 32rpx 40rpx;
}

.membership-cta-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
}

.cta-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.cta-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.cta-btn {
  display: inline-block;
  background: #fff;
  color: #667eea;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 40rpx;
  border-radius: 40rpx;
}
