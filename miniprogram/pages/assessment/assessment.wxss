/* 成长观察样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(145deg, #E85A29, #FF6B35 40%, #FF7E4B);
  padding: 48rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  position: relative;
  z-index: 1;
}

/* 当前孩子信息 */
.child-info {
  display: flex;
  align-items: center;
  background: #fff;
  margin: -20rpx 32rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 2;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FF8F5A, #FF7E4B);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 20rpx;
}

.child-detail {
  flex: 1;
}

.child-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.child-age {
  font-size: 24rpx;
  color: #888;
}

.history-entry {
  display: flex;
  align-items: center;
  background: #FFF3ED;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  position: relative;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.history-text {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 500;
}

.history-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #FF5722;
  border-radius: 18rpx;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.age-filter {
  background: #fff;
  margin: 0 32rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.age-filter-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.age-filter-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  flex-shrink: 0;
}

.age-filter-subtitle {
  font-size: 22rpx;
  color: #888;
  text-align: right;
  line-height: 1.35;
}

.age-scroll {
  width: 100%;
  white-space: nowrap;
}

.age-option {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 116rpx;
  height: 56rpx;
  margin-right: 14rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: #F5F5F5;
  color: #666;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.age-option.active {
  background: #FF6B35;
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 53, 0.28);
}

/* 观察工具列表 */
.assessment-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.assessment-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.assessment-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.card-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: #FFF3ED;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-icon {
  font-size: 48rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meta-tags {
  display: flex;
  gap: 12rpx;
}

.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.count-tag {
  background: #FFF3ED;
  color: #FF6B35;
}

.time-tag {
  background: #FFF8E1;
  color: #FF8F00;
}

.age-tag {
  background: #E8F5E9;
  color: #2E7D32;
}

.card-arrow {
  font-size: 30rpx;
  color: #bbb;
}

.empty-assessment {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #444;
  margin-bottom: 10rpx;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.empty-action {
  margin-top: 22rpx;
  min-width: 144rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 8rpx;
  background: #2f7cf6;
  color: #fff;
  font-size: 24rpx;
}

/* 底部提示 */
.footer-tip {
  padding: 40rpx 32rpx 20rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: #aaa;
  margin-bottom: 8rpx;
}

.footer-subtext {
  font-size: 22rpx;
  color: #bbb;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-container {
  width: 90%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #FFF3ED, #C8E6C9);
  position: relative;
}

.modal-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.modal-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #E85A29;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
}

.modal-body {
  padding: 32rpx;
}

.intro-section {
  margin-bottom: 24rpx;
}

.intro-label {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.intro-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.intro-info {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.info-item {
  flex: 1 1 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #F5F5F5;
  padding: 20rpx;
  border-radius: 16rpx;
}

.info-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.intro-tips {
  background: #FFF8E1;
  padding: 24rpx;
  border-radius: 16rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #FF8F00;
  margin-bottom: 12rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  padding: 0 32rpx 32rpx;
  gap: 24rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666;
  background: #F5F5F5;
  border-radius: 44rpx;
}

.btn-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #FF6B35, #FF7E4B);
  border-radius: 44rpx;
}
