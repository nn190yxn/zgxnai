.page {
  min-height: 100vh;
  background: #F6F7F4;
  padding: 28rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #24312A;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6B746D;
}

.card {
  min-height: 760rpx;
  border-radius: 12rpx;
  padding: 42rpx 38rpx;
  box-sizing: border-box;
  color: #fff;
  background: linear-gradient(155deg, #24312A 0%, #31523A 46%, #E86B3D 100%);
  box-shadow: 0 20rpx 46rpx rgba(36, 49, 42, 0.18);
  display: flex;
  flex-direction: column;
}

.card-head {
  min-height: 220rpx;
}

.badge {
  display: inline-block;
  font-size: 22rpx;
  line-height: 1;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.94);
}

.name {
  display: block;
  margin-top: 28rpx;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.16;
  color: #fff;
}

.subline {
  display: block;
  margin-top: 20rpx;
  max-width: 560rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.88);
}

.hero-metric {
  margin: 62rpx 0 42rpx;
  padding: 34rpx 30rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.hero-num {
  display: block;
  font-size: 96rpx;
  font-weight: 900;
  line-height: 1;
  color: #FFF8E7;
}

.hero-label {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.9);
}

.chips {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.chip {
  min-height: 110rpx;
  padding: 18rpx 10rpx;
  border-radius: 10rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.14);
}

.chip-value {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
  color: #fff;
}

.chip-label {
  display: block;
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.78);
}

.card-footer {
  margin-top: auto;
  padding-top: 44rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.brand {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.76);
  line-height: 1.5;
}

.cta {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFF8E7;
  text-align: right;
  line-height: 1.45;
}

.copy-card {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 10rpx;
  box-shadow: 0 6rpx 18rpx rgba(31, 45, 37, 0.06);
}

.copy-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #24312A;
  margin-bottom: 12rpx;
  line-height: 1.45;
}

.copy-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.68;
  color: #3F4A43;
}

.actions {
  margin-top: 24rpx;
  display: flex;
  gap: 14rpx;
}

.btn {
  flex: 1;
  text-align: center;
  border-radius: 10rpx;
  padding: 22rpx 16rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.45;
}

.btn-primary {
  background: #E86B3D;
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #31523A;
  border: 1rpx solid #DCE4D7;
}

.tip {
  margin-top: 18rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6B746D;
}

.stats-panel {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 10rpx;
  padding: 16rpx;
}

.stats-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #24312A;
  margin-bottom: 10rpx;
  line-height: 1.45;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
}

.stats-item {
  text-align: center;
  background: #F6F7F4;
  border-radius: 8rpx;
  padding: 8rpx 4rpx;
}

.stats-num {
  display: block;
  font-size: 22rpx;
  color: #E86B3D;
  font-weight: 700;
  line-height: 1.45;
}

.stats-label {
  display: block;
  font-size: 18rpx;
  color: #667168;
  line-height: 1.45;
}

.stats-extra {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #667168;
  line-height: 1.55;
}

.source-top {
  margin-top: 8rpx;
}

.source-title,
.source-item {
  display: block;
  font-size: 20rpx;
  color: #667168;
  line-height: 1.6;
}

.debug-toggle {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #2F80ED;
}

.debug-logs {
  margin-top: 8rpx;
  background: #fff;
  border-radius: 10rpx;
  padding: 12rpx;
}

.debug-item {
  padding: 6rpx 0;
  border-bottom: 1rpx solid #EEF1EC;
}

.debug-item:last-child {
  border-bottom: none;
}

.debug-line {
  font-size: 20rpx;
  color: #667168;
}
