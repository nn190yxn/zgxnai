.page {
  min-height: 100vh;
  background: #f7f3ec;
  padding: 24rpx;
  box-sizing: border-box;
}

.summary-card,
.content-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.summary-title,
.section-title,
.content-title {
  font-size: 32rpx;
  line-height: 1.45;
  color: #2c2623;
  font-weight: 700;
  word-break: break-word;
}

.summary-range {
  display: block;
  margin-top: 14rpx;
  color: #9a8f87;
  font-size: 24rpx;
  line-height: 1.5;
}

.summary-badge {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1ea;
  color: #d65a1f;
  font-size: 22rpx;
  line-height: 1.45;
}

.summary-badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.summary-badge-row .summary-badge {
  margin-top: 0;
}

.summary-badge-active {
  background: #eef8ee;
  color: #2f8f46;
}

.summary-badge-soft {
  background: #f4efe6;
  color: #7c6858;
}

.summary-copy,
.content-summary {
  display: block;
  margin-top: 16rpx;
  color: #6c625b;
  font-size: 26rpx;
  line-height: 1.7;
  word-break: break-word;
}

.primary-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #ff7a45;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.45;
  box-sizing: border-box;
  word-break: break-word;
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1 1 240rpx;
  min-width: 0;
  margin-top: 0;
}

.secondary-btn {
  text-align: center;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f4efe6;
  color: #6c625b;
  font-size: 28rpx;
  line-height: 1.45;
  box-sizing: border-box;
  word-break: break-word;
}

.dimension-item {
  margin-top: 20rpx;
}

.dimension-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.dimension-label,
.dimension-score {
  font-size: 24rpx;
  line-height: 1.45;
  color: #4f453f;
  word-break: break-word;
}

.dimension-label {
  min-width: 0;
  flex: 1;
}

.dimension-score {
  flex-shrink: 0;
}

.dimension-score {
  color: #8e7665;
}

.dimension-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #efe7da;
}

.dimension-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff9c5f 0%, #ff7a45 100%);
}

.trend-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 16rpx;
}

.trend-copy {
  flex: 1;
  min-width: 0;
  margin-top: 0;
}

.trend-dir {
  font-size: 32rpx;
  line-height: 1.6;
  min-width: 36rpx;
  text-align: center;
}

.trend-up {
  color: #2f8f46;
}

.trend-down {
  color: #d65a1f;
}

.trend-stable {
  color: #7c6858;
}

.zone-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.zone-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1ea;
  color: #d65a1f;
  font-size: 22rpx;
  line-height: 1.45;
}

.practice-list {
  margin-top: 12rpx;
}

.practice-item {
  display: block;
  margin-top: 12rpx;
  color: #7c6858;
  font-size: 24rpx;
  line-height: 1.65;
  word-break: break-word;
}

.overview-begin {
  border-left: 8rpx solid #ffb64d;
  padding-left: 16rpx;
}

.overview-building {
  border-left: 8rpx solid #ffb64d;
  padding-left: 16rpx;
}

.overview-steady {
  border-left: 8rpx solid #2f8f46;
  padding-left: 16rpx;
}
