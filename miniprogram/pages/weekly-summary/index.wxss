.page {
  min-height: 100vh;
  background: #f7f3ec;
  padding: 24rpx;
}

.summary-card,
.content-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.summary-title,
.section-title,
.content-title {
  font-size: 32rpx;
  color: #2c2623;
  font-weight: 700;
}

.summary-range {
  display: block;
  margin-top: 12rpx;
  color: #9a8f87;
  font-size: 24rpx;
}

.summary-badge {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1ea;
  color: #d65a1f;
  font-size: 22rpx;
}

.summary-badge-active {
  background: #eef8ee;
  color: #2f8f46;
}

.summary-copy,
.content-summary {
  display: block;
  margin-top: 16rpx;
  color: #6c625b;
  font-size: 26rpx;
  line-height: 1.7;
}

.primary-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #ff7a45;
  color: #fff;
  font-size: 28rpx;
}
