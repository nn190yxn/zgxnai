<view class="page">
  <view class="summary-card" wx:if="{{!currentChild}}">
    <text class="summary-title">先补孩子档案，周总结会更准确</text>
    <text class="summary-copy">先建立孩子档案，再把成长记录和每周总结连起来。</text>
    <view class="primary-btn" bindtap="goToChildSetup">去完善档案</view>
  </view>

  <view class="summary-card" wx:elif="{{loading}}">
    <text class="summary-copy">正在整理本周成长总结...</text>
  </view>

  <view class="summary-card" wx:elif="{{!summary}}">
    <text class="summary-title">本周总结还没准备好</text>
    <text class="summary-copy">先去补几天成长记录，周总结会更贴近你家的真实状态。</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary}}">
    <text class="summary-title">{{summary.childName}} 的本周成长总结</text>
    <text class="summary-range">{{summary.weekStart}} - {{summary.weekEnd}}</text>
    <text class="summary-badge {{summary.premiumUnlocked ? 'summary-badge-active' : ''}}">{{summary.premiumUnlocked ? '会员完整版本' : '基础版本'}}</text>
    <text class="summary-copy">{{summary.overview}}</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary}}">
    <text class="section-title">记录概况</text>
    <text class="summary-copy">本周记录 {{summary.recordDays}} 天，完成今日计划 {{summary.completedPlanCount}} / {{summary.totalPlanCount}} 次。</text>
    <text class="summary-copy">能力训练完成 {{summary.completedTaskCount}} 次。</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary}}">
    <text class="section-title">本周亮点</text>
    <text class="summary-copy" wx:for="{{summary.highlights}}" wx:key="*this">{{item}}</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && summary.premiumUnlocked}}">
    <text class="section-title">重点观察</text>
    <text class="summary-copy" wx:for="{{summary.concerns}}" wx:key="*this">{{item}}</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && !summary.premiumUnlocked}}">
    <text class="section-title">重点观察</text>
    <text class="summary-copy" wx:for="{{summary.concerns}}" wx:key="*this">{{item}}</text>
    <text class="summary-copy">会员可继续查看更细的趋势解释、完整重点观察项和下周执行建议。</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary}}">
    <text class="section-title">下周重点</text>
    <text class="summary-copy" wx:for="{{summary.nextActions}}" wx:key="*this">{{item}}</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && summary.recommendedContent.length}}">
    <text class="section-title">继续看这些内容</text>
    <view class="content-card" wx:for="{{summary.recommendedContent}}" wx:key="title" data-target-path="{{item.targetPath}}" bindtap="onOpenContent">
      <text class="content-title">{{item.title}}</text>
      <text class="content-summary">{{item.summary}}</text>
    </view>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && !summary.premiumUnlocked}}">
    <text class="section-title">会员权益</text>
    <text class="summary-copy">{{summary.premiumTip}}</text>
    <view class="primary-btn" bindtap="goToMembership">去看会员权益</view>
  </view>
</view>
