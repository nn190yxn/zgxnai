<view class="page">
  <view class="summary-card" wx:if="{{!currentChild}}">
    <text class="summary-title">先完善孩子档案，再查看成长总结</text>
    <text class="summary-copy">先建立孩子档案，再把成长记录和每周成长总结连起来。</text>
    <view class="primary-btn" bindtap="goToChildSetup">去完善档案</view>
  </view>

  <view class="summary-card" wx:elif="{{loading}}">
    <text class="summary-copy">正在整理本周成长总结...</text>
  </view>

  <view class="summary-card" wx:elif="{{!summary}}">
    <text class="summary-title">本周成长总结还没生成</text>
    <text class="summary-copy">先补几天成长记录，再来看更贴合孩子状态的成长总结。</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary}}">
    <text class="summary-title">{{summary.childName}} 的本周成长总结</text>
    <text class="summary-range">{{summary.weekStart}} - {{summary.weekEnd}}</text>
    <view class="summary-badge-row">
      <text class="summary-badge {{summary.premiumUnlocked ? 'summary-badge-active' : ''}}">{{summary.premiumUnlocked ? '完整成长内容' : '基础成长内容'}}</text>
      <text class="summary-badge summary-badge-soft" wx:if="{{summary.ageGroup}}">{{summary.ageGroup}}</text>
      <text class="summary-badge summary-badge-soft" wx:if="{{summary.weakestDimensionLabel}}">重点关注 {{summary.weakestDimensionLabel}}</text>
    </view>
    <text class="summary-copy {{summary.overviewMood === 'begin' ? 'overview-begin' : summary.overviewMood === 'building' ? 'overview-building' : summary.overviewMood === 'steady' ? 'overview-steady' : ''}}">{{summary.overview}}</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary}}">
    <text class="section-title">记录概况</text>
    <text class="summary-copy">本周记录 {{summary.recordDays}} 天，完成今日计划 {{summary.completedPlanCount}} / {{summary.totalPlanCount}} 次。</text>
    <text class="summary-copy">能力训练完成 {{summary.completedTaskCount}} 次。</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && summary.dimensionScoreList.length}}">
    <text class="section-title">成长维度</text>
    <view class="dimension-item" wx:for="{{summary.dimensionScoreList}}" wx:key="key">
      <view class="dimension-row">
        <text class="dimension-label">{{item.label}}</text>
        <text class="dimension-score">{{item.scoreText}}</text>
      </view>
      <view class="dimension-track">
        <view class="dimension-fill" style="width: {{item.score}}%;"></view>
      </view>
    </view>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary}}">
    <text class="section-title">本周亮点</text>
    <text class="summary-copy" wx:for="{{summary.highlights}}" wx:key="*this">{{item}}</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && summary.trendItems.length}}">
    <text class="section-title">趋势变化</text>
    <view wx:for="{{summary.trendItems}}" wx:key="label" class="trend-row">
      <text class="trend-dir {{item.direction === 'up' ? 'trend-up' : item.direction === 'down' ? 'trend-down' : 'trend-stable'}}">{{item.direction === 'up' ? '↑' : item.direction === 'down' ? '↓' : '→'}}</text>
      <text class="summary-copy" style="flex:1">{{item.detail}}</text>
    </view>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && summary.premiumUnlocked}}">
    <text class="section-title">重点观察</text>
    <text class="summary-copy" wx:for="{{summary.concerns}}" wx:key="*this">{{item}}</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && !summary.premiumUnlocked}}">
    <text class="section-title">重点观察</text>
    <text class="summary-copy" wx:for="{{summary.concerns}}" wx:key="*this">{{item}}</text>
    <text class="summary-copy">继续查看后，可获得更细的趋势解释、完整重点观察项和下周陪伴建议。</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary}}">
    <text class="section-title">下周重点</text>
    <text class="summary-copy" wx:for="{{summary.nextActions}}" wx:key="*this">{{item}}</text>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && summary.recommendedContent.length}}">
    <text class="section-title">继续看这些内容</text>
    <view class="content-card" wx:for="{{summary.recommendedContent}}" wx:key="title" data-target-path="{{item.targetPath}}" bindtap="onOpenContent">
      <text class="content-title">{{item.title}}</text>
      <text class="content-summary">{{item.summary}}</text>
    </view>
  </view>

  <view class="summary-card" wx:if="{{currentChild && summary && !summary.premiumUnlocked}}">
    <text class="section-title">更多成长内容</text>
    <text class="summary-copy">{{summary.premiumTip}}</text>
    <view class="primary-btn" bindtap="goToMembership">查看宝贝成长服务</view>
  </view>
</view>
