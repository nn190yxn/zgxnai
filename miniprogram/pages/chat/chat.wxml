<!-- AI聊天页面 -->
<view class="page page-transition">
  <!-- 聊天区域 -->
  <scroll-view 
    class="chat-area {{voiceResultVisible && voiceResultText ? 'chat-area-with-voice-result' : ''}}" 
    scroll-y 
    enable-flex="true"
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
  >
    <view class="service-closed" wx:if="{{!featureFlags.aiChatEnabled}}">
      <text class="service-closed-title">小牛育儿AI问答</text>
      <text class="service-closed-desc">本页面提供儿童成长、营养食谱、亲子沟通、能力成长训练等育儿咨询服务。当前版本的在线AI生成服务正在合规配置中，审核人员可先查看下方正式运营内容与功能入口。</text>
      <view class="service-actions">
        <button class="service-action" size="mini" bindtap="goToAssessment">成长观察</button>
        <button class="service-action secondary" size="mini" bindtap="goToParenting">育儿知识</button>
      </view>
    </view>
    <view class="service-banner info">
      <text class="service-banner-title">AI生成内容提示</text>
      <text class="service-banner-desc">本页面涉及文本深度合成能力。开启AI问答后，回答内容由人工智能生成，仅供家庭教育参考，不能替代医生、心理咨询师或其他专业人员的判断。</text>
    </view>

    <view class="operation-section">
      <view class="operation-title">正式运营内容</view>
      <view class="operation-card" wx:for="{{operationItems}}" wx:key="title" bindtap="onOperationItemTap" data-type="{{item.type}}">
        <view class="operation-icon">{{item.icon}}</view>
        <view class="operation-body">
          <text class="operation-name">{{item.title}}</text>
          <text class="operation-desc">{{item.desc}}</text>
        </view>
        <text class="operation-arrow">→</text>
      </view>
    </view>

    <view class="sample-section">
      <view class="sample-title">AI问答示例</view>
      <view class="sample-question" wx:for="{{sampleQuestions}}" wx:key="*this" bindtap="useSampleQuestion" data-question="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>

    <!-- 欢迎消息 -->
    <view class="message bot" wx:if="{{featureFlags.aiChatEnabled && messages.length === 0}}">
      <view class="avatar avatar-image avatar-ai">AI</view>
      <view class="bubble">
        <text class="ai-label">AI生成</text>
        <text>您好！我是小牛育儿AI助理</text>
        <text class="mt20">我可以帮您解答：</text>
        <text>🧠 成长观察与训练问题</text>
        <text>🥗 儿童营养与饮食</text>
        <text>👨‍👩‍👧 育儿方法与技巧</text>
        <text>📚 能力成长与表达训练</text>
        <text class="mt20">请直接输入您的问题，我会尽力为您解答！</text>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{index}}">
      <view class="message {{item.role}} {{item.isError ? 'error' : ''}}">
        <view wx:if="{{item.role === 'user'}}" class="avatar">家</view>
        <view wx:else class="avatar avatar-image avatar-ai">AI</view>
        <view class="bubble">
          <text class="ai-label" wx:if="{{item.role !== 'user'}}">AI生成</text>
          <rich-text wx:if="{{item.markdownNodes && item.markdownNodes.length > 0}}" nodes="{{item.markdownNodes}}"></rich-text>
          <text wx:elif="{{!item.structured || !item.structured.available}}">{{item.content}}</text>
          <!-- 结构化渲染（新路径） -->
          <view wx:if="{{item.structured && item.structured.available && item.structured.tips && item.structured.tips.length > 0}}" class="structured-answer">
            <view class="judgment-text" wx:if="{{item.structured.judgment}}">{{item.structured.judgment}}</view>
            <tip-card
              wx:for="{{item.structured.tips}}"
              wx:key="id"
              type="{{item.type}}"
              title="{{item.title}}"
              text="{{item.text}}"
              rationale="{{item.rationale}}"
              sourceType="{{item.source_type}}"
              sourceId="{{item.source_id}}"
              sourceTitle="{{item.source_title}}"
            />
            <view class="followup-buttons" wx:if="{{item.structured.followups && item.structured.followups.length > 0}}">
              <button
                wx:for="{{item.structured.followups}}"
                wx:key="*this"
                class="followup-btn"
                data-question="{{item}}"
                bindtap="onFollowupTap"
              >{{item}}</button>
            </view>
          </view>
          <!-- 显示来源 -->
          <view wx:if="{{item.sources && item.sources.length > 0}}" class="sources">
            <text class="sources-label">📚 参考资料：</text>
            <text wx:for="{{item.sources}}" wx:for-item="source" wx:key="*this">{{source}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="message bot" wx:if="{{loading}}">
      <view class="avatar">🤖</view>
      <view class="bubble loading-bubble">
        <view class="typing">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-dock {{voiceResultVisible && voiceResultText ? 'bottom-dock-with-voice-result' : ''}}">
    <view class="ai-input-notice" wx:if="{{featureFlags.aiChatEnabled}}">AI生成内容仅供参考，请家长结合实际情况判断。</view>
    <view class="voice-hint" wx:if="{{featureFlags.aiChatEnabled && voiceHint}}">{{voiceHint}}</view>

    <!-- 语音识别结果卡片 -->
    <view class="voice-result-card" wx:if="{{voiceResultVisible && voiceResultText}}">
      <view class="voice-result-label">语音识别结果</view>
      <view class="voice-result-content">{{voiceResultText}}</view>
      <view class="voice-result-actions">
        <button class="voice-result-btn edit" bindtap="onEditVoiceResult">修改</button>
        <button class="voice-result-btn send" bindtap="onSendVoiceResult">发送</button>
      </view>
    </view>

    <!-- 输入区域 -->
    <view class="input-area">
      <button
        class="mode-toggle-btn"
        bindtap="toggleInputMode"
        disabled="{{!featureFlags.aiChatEnabled || loading}}"
      >
        {{inputMode === 'voice' ? '⌨' : '🎤'}}
      </button>
      <view class="input-wrapper">
        <textarea
          class="input"
          value="{{inputValue}}"
          bindinput="onInput"
          confirm-type="send"
          bindconfirm="sendMessage"
          adjust-position="{{true}}"
          hold-keyboard="{{false}}"
          disabled="{{!featureFlags.aiChatEnabled}}"
          placeholder="{{featureFlags.aiChatEnabled ? '输入您的问题...' : 'AI问答暂未开放'}}"
          auto-height
          maxlength="2000"
          show-confirm-bar="{{false}}"
          cursor-spacing="16"
        ></textarea>
      </view>
      <button class="send-btn" bindtap="sendMessage" disabled="{{!featureFlags.aiChatEnabled || !inputValue || loading}}">
        发送
      </button>
    </view>
    <view
      class="voice-action-bar {{inputMode === 'voice' ? '' : 'is-hidden'}}"
      bindtouchstart="onVoiceTouchStart"
      bindtouchend="onVoiceTouchEnd"
      bindtouchcancel="onVoiceTouchCancel"
    >
      <view class="hold-to-talk {{isRecording ? 'hold-to-talk-recording' : ''}} {{isRecognizing ? 'hold-to-talk-waiting' : ''}}">
        {{isRecording ? '松开发送' : (isRecognizing ? '识别中...' : '按住说话')}}
      </view>
    </view>
  </view>
</view>
