<!-- AI聊天页面 -->
<view class="page page-transition">
  <!-- 聊天区域 -->
  <scroll-view 
    class="chat-area {{voiceResultVisible && voiceResultText ? 'chat-area-with-voice-result' : ''}}" 
    scroll-y 
    enable-flex="true"
    style="padding-bottom:{{voiceResultVisible && voiceResultText ? '740rpx' : '420rpx'}}"
    scroll-into-view="{{scrollToView}}"
    scroll-top="{{scrollTop}}"
    scroll-with-animation
  >
    <view class="service-closed" wx:if="{{!featureFlags.aiChatEnabled}}">
      <text class="service-closed-title">小牛问答</text>
      <text class="service-closed-desc">小牛问答功能升级中。</text>
      <view class="service-actions">
        <button class="service-action" size="mini" bindtap="goToAssessment">成长观察</button>
        <button class="service-action secondary" size="mini" bindtap="goToParenting">育儿知识</button>
      </view>
    </view>
    <view class="service-banner info">
      <text class="service-banner-title">免责声明</text>
      <text class="service-banner-desc">小牛回答由 AI 生成，仅供家庭教育参考，不能替代医生、心理咨询师等专业判断。</text>
    </view>

    <!-- AI 介绍（未开始对话时展示） -->
    <view class="ai-intro" wx:if="{{featureFlags.aiChatEnabled && messages.length === 0}}" style="margin:24rpx 24rpx 32rpx;padding:28rpx 28rpx 32rpx;background:#FFFFFF;border:1rpx solid #E9D7CF;border-radius:24rpx;display:flex;gap:20rpx;box-sizing:border-box;">
      <view class="ai-intro-avatar" style="width:84rpx;height:84rpx;border-radius:42rpx;background:#FFF3ED;color:#FF6B35;font-size:28rpx;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;">AI</view>
      <view class="ai-intro-content" style="flex:1;min-width:0;padding-right:12rpx;box-sizing:border-box;overflow:hidden;">
        <text class="ai-intro-title" style="display:block;font-size:34rpx;font-weight:700;line-height:1.4;color:#1B2A1B;margin-bottom:12rpx;">小牛问答</text>
        <text class="ai-intro-desc" style="display:block;font-size:28rpx;line-height:1.8;color:#7A6660;padding-right:16rpx;box-sizing:border-box;word-break:break-word;">输入问题，小牛为您回答。</text>
        <view class="ai-intro-hint" style="display:flex;flex-wrap:wrap;gap:12rpx 12rpx;margin-top:20rpx;padding-right:12rpx;box-sizing:border-box;">
          <text class="ai-intro-hint-item" style="padding:10rpx 16rpx;border-radius:999rpx;background:#FFF3ED;color:#FF6B35;font-size:24rpx;line-height:1.4;">成长观察与训练问题</text>
          <text class="ai-intro-hint-item" style="padding:10rpx 16rpx;border-radius:999rpx;background:#FFF3ED;color:#FF6B35;font-size:24rpx;line-height:1.4;">儿童营养与饮食</text>
          <text class="ai-intro-hint-item" style="padding:10rpx 16rpx;border-radius:999rpx;background:#FFF3ED;color:#FF6B35;font-size:24rpx;line-height:1.4;">亲子沟通与育儿方法</text>
          <text class="ai-intro-hint-item" style="padding:10rpx 16rpx;border-radius:999rpx;background:#FFF3ED;color:#FF6B35;font-size:24rpx;line-height:1.4;">能力成长与表达训练</text>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{index}}">
      <view class="message {{item.role}} {{item.isError ? 'error' : ''}}">
        <view wx:if="{{item.role === 'user'}}" class="avatar">家</view>
        <view wx:else class="avatar avatar-image avatar-ai">AI</view>
        <view class="bubble">
          <text class="ai-label" wx:if="{{item.role !== 'user'}}">小牛回答</text>
          <rich-text wx:if="{{item.markdownNodes && item.markdownNodes.length > 0}}" nodes="{{item.markdownNodes}}"></rich-text>
          <text wx:elif="{{!item.structured || !item.structured.available}}">{{item.content}}</text>
          <!-- 结构化渲染（新路径） -->
          <view wx:if="{{item.structured && item.structured.available && item.structured.tips && item.structured.tips.length > 0}}" class="structured-answer">
            <view class="judgment-text" wx:if="{{item.structured.judgment}}">{{item.structured.judgment}}</view>
            <tip-card
              wx:for="{{item.structured.tips}}"
              wx:key="id"
              type="{{item.type}}"
              title="{{item.title}}"
              text="{{item.text}}"
              rationale="{{item.rationale}}"
              sourceType="{{item.source_type}}"
              sourceId="{{item.source_id}}"
              sourceTitle="{{item.source_title}}"
            />
            <view class="followup-buttons" wx:if="{{item.structured.followups && item.structured.followups.length > 0}}">
              <button
                wx:for="{{item.structured.followups}}"
                wx:key="*this"
                class="followup-btn"
                data-question="{{item}}"
                bindtap="onFollowupTap"
              >{{item}}</button>
            </view>
            <view class="followup-buttons" wx:elif="{{item.followUpQuestions && item.followUpQuestions.length > 0}}">
              <button
                wx:for="{{item.followUpQuestions}}"
                wx:key="*this"
                class="followup-btn"
                data-question="{{item}}"
                bindtap="onFollowupTap"
              >{{item}}</button>
            </view>
          </view>
          <!-- 显示来源 -->
          <view wx:if="{{item.sources && item.sources.length > 0}}" class="sources">
            <text class="sources-label">📚 参考资料：</text>
            <text wx:for="{{item.sources}}" wx:for-item="source" wx:key="*this">{{source}}</text>
          </view>
          <view wx:if="{{item.role !== 'user' && !item.isError}}" class="answer-next-actions">
            <text class="answer-next-title">接下来把建议用起来</text>
            <view class="answer-next-row">
              <button class="answer-next-btn primary" bindtap="askForTodaySteps">生成今晚三步</button>
              <button class="answer-next-btn" bindtap="goToGrowthRecord">记录孩子反应</button>
              <button class="answer-next-btn" bindtap="saveAiAnswerToGrowthRecord">保存到成长记录</button>
            </view>
            <view class="answer-next-row">
              <button class="answer-next-btn" bindtap="goToParentingSearch">找相关锦囊</button>
              <button class="answer-next-btn" bindtap="goToAssessment">做成长观察</button>
            </view>
            <view class="answer-next-row" wx:if="{{item.planAvailable}}">
              <button class="answer-next-btn primary" bindtap="generateSevenDayPlan">生成7天计划</button>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="message bot" wx:if="{{loading}}">
      <view class="avatar">🤖</view>
      <view class="bubble loading-bubble">
        <view class="typing">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
        <text class="loading-hint">小牛正在回答</text>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-dock {{voiceResultVisible && voiceResultText ? 'bottom-dock-with-voice-result' : ''}}">
    <view class="ai-input-notice" wx:if="{{featureFlags.aiChatEnabled}}">小牛回答仅供参考，请结合实际情况判断。</view>
    <view class="voice-hint" wx:if="{{featureFlags.aiChatEnabled && voiceHint}}">{{voiceHint}}</view>

    <!-- 语音识别结果卡片 -->
    <view class="voice-result-card" wx:if="{{voiceResultVisible && voiceResultText}}">
      <view class="voice-result-label">语音识别结果</view>
      <view class="voice-result-content">{{voiceResultText}}</view>
      <view class="voice-result-actions">
        <button class="voice-result-btn edit" bindtap="onEditVoiceResult">修改</button>
        <button class="voice-result-btn send" bindtap="onSendVoiceResult">发送</button>
      </view>
    </view>

    <!-- 输入区域 -->
    <view class="input-area" style="padding:24rpx 32rpx;background:#FFFFFF;border-top:1rpx solid #E9D7CF;display:flex;flex-direction:column;gap:16rpx;">
      <view class="voice-row" style="display:flex;">
        <view
          class="hold-to-talk {{isRecording ? 'hold-to-talk-recording' : ''}} {{isRecognizing ? 'hold-to-talk-waiting' : ''}}"
          bindtouchstart="onVoiceTouchStart"
          bindtouchend="onVoiceTouchEnd"
          bindtouchcancel="onVoiceTouchCancel"
          style="flex:1;height:96rpx;border-radius:20rpx;background:#F8FAFC;border:1rpx solid #CBD5E1;color:#334155;font-size:30rpx;font-weight:600;display:flex;align-items:center;justify-content:center;"
        >
          <text>{{isRecording ? '松开发送' : (isRecognizing ? '识别中...' : '按住说话，松开自动转文字')}}</text>
        </view>
      </view>
      <view class="text-row" style="display:flex;align-items:flex-end;gap:16rpx;">
        <view class="input-wrapper" style="flex:1;min-width:0;">
          <textarea
            class="input"
            value="{{inputValue}}"
            bindinput="onInput"
            confirm-type="send"
            bindconfirm="sendMessage"
            adjust-position="{{true}}"
            hold-keyboard="{{false}}"
            disabled="{{!featureFlags.aiChatEnabled}}"
            placeholder="{{featureFlags.aiChatEnabled ? '输入您的问题...' : 'AI问答暂未开放'}}"
            auto-height
            maxlength="2000"
            show-confirm-bar="{{false}}"
            cursor-spacing="16"
            style="width:100%;min-height:100rpx;max-height:240rpx;font-size:32rpx;line-height:1.5;padding:20rpx 32rpx;background:#F8FAFC;border-radius:20rpx;border:1rpx solid #CBD5E1;box-sizing:border-box;"
          />
        </view>
        <button class="send-btn" bindtap="sendMessage" disabled="{{!featureFlags.aiChatEnabled || !inputValue || loading}}" style="flex-shrink:0;width:160rpx;height:100rpx;line-height:100rpx;background:#FF6B35;color:#fff;border-radius:20rpx;font-size:32rpx;font-weight:600;border:none;padding:0;">发送</button>
      </view>
    </view>
  </view>
</view>
