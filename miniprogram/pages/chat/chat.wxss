/* AI聊天页面样式 */

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--bg);
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: 40rpx;
  padding-bottom: 420rpx;
  overflow-y: auto;
}

.chat-area-with-voice-result {
  padding-bottom: 740rpx;
}

.bottom-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #FFFFFF 14%, #FFFFFF 100%);
  z-index: 11;
}

.bottom-dock-with-voice-result {
  padding-top: 8rpx;
}

.service-banner {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FFF7ED;
  border: 1rpx solid #FDBA74;
}

.service-banner-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #9A3412;
  margin-bottom: 8rpx;
}

.service-banner-desc {
  display: block;
  font-size: 24rpx;
  color: #B45309;
  line-height: 1.6;
}

.service-banner.info {
  background: #F0F9FF;
  border-color: #BAE6FD;
}

.service-banner.info .service-banner-title {
  color: #075985;
}

.service-banner.info .service-banner-desc {
  color: #0C4A6E;
}

.service-closed {
  margin: 120rpx 16rpx 24rpx;
  padding: 44rpx 32rpx;
  border-radius: 8rpx;
  background: #fff;
  border: 1rpx solid var(--border);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
  text-align: center;
}

.service-closed-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
}

.service-closed-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

.service-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
  gap: 18rpx;
}

.service-action {
  min-width: 150rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 8rpx;
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  padding: 0 22rpx;
}

.service-action.secondary {
  background: #f1f5f9;
  color: var(--text);
}

/* AI 介绍 */
.ai-intro {
  margin: 60rpx 0 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.ai-intro-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFF7ED;
  border: 2rpx solid #FED7AA;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C2410C;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.ai-intro-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ai-intro-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.ai-intro-desc {
  font-size: 28rpx;
  color: var(--text-muted);
  line-height: 1.7;
}

.ai-intro-hint {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.ai-intro-hint-item {
  font-size: 24rpx;
  color: var(--primary);
  background: var(--primary-bg);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.ai-label {
  display: inline-block !important;
  width: fit-content;
  margin-bottom: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #FEF3C7;
  color: #92400E;
  font-size: 22rpx;
  font-weight: 600;
}

.avatar-image {
  background: #FFF7ED;
  border: 2rpx solid #FED7AA;
}

.avatar-ai {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C2410C;
  font-size: 24rpx;
  font-weight: 700;
}

.voice-result-card {
  left: 24rpx;
  right: 24rpx;
  margin: 0 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.08), 0 8rpx 32rpx rgba(0,0,0,0.06);
  padding: 24rpx;
}

.voice-result-label {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.voice-result-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  padding: 16rpx;
  background: var(--primary-bg);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  max-height: 240rpx;
  overflow-y: auto;
}

.voice-result-actions {
  display: flex;
  gap: 16rpx;
}

.voice-result-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  text-align: center;
}

.voice-result-btn.edit {
  background: #F1F5F9;
  color: var(--text);
  border: 1rpx solid var(--border);
}

.voice-result-btn.send {
  background: var(--primary);
  color: #FFFFFF;
}

.ai-input-notice {
  margin: 0 0 12rpx;
  padding: 12rpx 24rpx;
  background: #FFFBEB;
  border-top: 1rpx solid #FDE68A;
  color: #92400E;
  font-size: 22rpx;
  text-align: center;
}

/* 输入区域 */
.input-area {
  padding: 32rpx 40rpx;
  background: #FFFFFF;
  border-top: 1rpx solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.voice-row {
  display: flex;
}

.hold-to-talk {
  flex: 1;
  height: 96rpx;
  border-radius: 20rpx;
  background: #F8FAFC;
  border: 1rpx solid #CBD5E1;
  color: #334155;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hold-to-talk-recording {
  background: #FEE2E2;
  border-color: #F87171;
  color: #B91C1C;
}

.hold-to-talk-waiting {
  background: #EFF6FF;
  border-color: #93C5FD;
  color: #1D4ED8;
}

.text-row {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

.input-wrapper {
  flex: 1;
  min-width: 0;
}

.input {
  width: 100%;
  min-height: 100rpx;
  max-height: 240rpx;
  font-size: 32rpx;
  color: var(--text);
  line-height: 1.5;
  padding: 28rpx 40rpx;
  background: #F8FAFC;
  border-radius: 20rpx;
  border: 1rpx solid #CBD5E1;
  box-sizing: border-box;
}

.input[disabled] {
  background: #F1F5F9;
  color: var(--text-muted);
}

.send-btn {
  flex-shrink: 0;
  width: 160rpx;
  height: 100rpx;
  line-height: 100rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  text-align: center;
}

.send-btn[disabled] {
  background: var(--border);
  color: var(--text-muted);
}

.structured-answer {
  margin-top: 12rpx;
}

.judgment-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  padding-left: 18rpx;
  border-left: 4rpx solid var(--primary);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.followup-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.followup-btn {
  flex: 0 0 calc(50% - 8rpx);
  min-width: 0;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: var(--text);
  background: var(--primary-bg);
  border: none;
  border-radius: 8rpx;
  line-height: 1.4;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-height: 44rpx;
}
