/* AI聊天页面样式 */

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--bg);
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 420rpx;
  overflow-y: auto;
}

.chat-area-with-voice-result {
  padding-bottom: 740rpx;
}

.bottom-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #FFFFFF 14%, #FFFFFF 100%);
  z-index: 11;
}

.bottom-dock-with-voice-result {
  padding-top: 8rpx;
}

.service-banner {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FFF7ED;
  border: 1rpx solid #FDBA74;
}

.service-banner-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #9A3412;
  margin-bottom: 12rpx;
  line-height: 1.45;
}

.service-banner-desc {
  display: block;
  font-size: 24rpx;
  color: #B45309;
  line-height: 1.6;
}

.service-banner.info {
  background: #F0F9FF;
  border-color: #BAE6FD;
}

.service-banner.info .service-banner-title {
  color: #075985;
}

.service-banner.info .service-banner-desc {
  color: #0C4A6E;
}

.service-closed {
  margin: 120rpx 16rpx 24rpx;
  padding: 44rpx 32rpx;
  border-radius: 8rpx;
  background: #fff;
  border: 1rpx solid var(--border);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
  text-align: center;
}

.service-closed-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
}

.service-closed-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

.service-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
  gap: 18rpx;
}

.service-action {
  min-width: 150rpx;
  min-height: 64rpx;
  line-height: 1.45;
  border-radius: 8rpx;
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  padding: 14rpx 22rpx;
  text-align: center;
}

.service-action.secondary {
  background: #f1f5f9;
  color: var(--text);
}

/* AI 介绍 */
.ai-intro {
  margin: 24rpx 24rpx 32rpx;
  padding: 28rpx 28rpx 32rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #E9D7CF;
}

.ai-intro-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background: #FFF3ED;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FF6B35;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.ai-intro-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-right: 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.ai-intro-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1B2A1B;
  word-break: break-word;
}

.ai-intro-desc {
  display: block;
  font-size: 28rpx;
  color: #7A6660;
  line-height: 1.8;
  word-break: break-word;
}

.ai-intro-hint {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 12rpx;
  margin-top: 8rpx;
  box-sizing: border-box;
}

.ai-intro-hint-item {
  font-size: 24rpx;
  line-height: 1.45;
  color: #FF6B35;
  background: #FFF3ED;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  word-break: break-word;
}

.ai-label {
  display: inline-block !important;
  width: fit-content;
  margin-bottom: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #FEF3C7;
  color: #92400E;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 600;
}

.avatar-image {
  background: #FFF7ED;
  border: 2rpx solid #FED7AA;
}

.avatar-ai {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C2410C;
  font-size: 24rpx;
  font-weight: 700;
}

.voice-result-card {
  left: 24rpx;
  right: 24rpx;
  margin: 0 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.08), 0 8rpx 32rpx rgba(0,0,0,0.06);
  padding: 24rpx;
}

.voice-result-label {
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.voice-result-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  padding: 16rpx;
  background: var(--primary-bg);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  max-height: 240rpx;
  overflow-y: auto;
}

.voice-result-actions {
  display: flex;
  gap: 16rpx;
}

.voice-result-btn {
  flex: 1;
  min-height: 76rpx;
  line-height: 1.45;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 16rpx 18rpx;
  text-align: center;
}

.voice-result-btn.edit {
  background: #F1F5F9;
  color: var(--text);
  border: 1rpx solid var(--border);
}

.voice-result-btn.send {
  background: var(--primary);
  color: #FFFFFF;
}

.ai-input-notice {
  margin: 0 0 12rpx;
  padding: 12rpx 24rpx;
  background: #FFFBEB;
  border-top: 1rpx solid #FDE68A;
  color: #92400E;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.voice-hint {
  margin: 0 24rpx 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.82);
  color: #FFFFFF;
  font-size: 24rpx;
  line-height: 1.5;
}

/* 消息 */
.message {
  display: flex;
  margin-bottom: 36rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.message.bot .avatar {
  background: var(--primary-bg);
  margin-right: 20rpx;
}

.message.user .avatar {
  background: #E3F2FD;
  margin-left: 20rpx;
}

.bubble {
  max-width: 76%;
  padding: 26rpx 30rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.75;
  word-wrap: break-word;
}

.message.bot .bubble {
  background: var(--white);
  border: 1rpx solid var(--border);
  border-top-left-radius: 8rpx;
  color: var(--text);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.message.bot.error .bubble {
  background: #FFF7ED;
  border-color: #FDBA74;
  color: #9A3412;
}

.message.user .bubble {
  background: var(--primary);
  color: #fff;
  border-top-right-radius: 8rpx;
}

.bubble text,
.bubble rich-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
}

.mt20 {
  margin-top: 20rpx;
}

/* 来源标签 */
.sources {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.sources-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
  line-height: 1.45;
}

.sources text {
  font-size: 22rpx;
  color: var(--primary);
  display: inline;
  margin-right: 12rpx;
}

.answer-next-actions {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--border);
}

.answer-next-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 23rpx;
  color: #7A6660;
  font-weight: 700;
}

.answer-next-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.answer-next-btn {
  flex: 1 1 180rpx;
  min-width: 0;
  min-height: 68rpx;
  line-height: 1.45;
  padding: 0 10rpx;
  border-radius: 14rpx;
  background: #F8FAFC;
  color: #334155;
  border: 1rpx solid #CBD5E1;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  word-break: break-word;
}

.answer-next-btn::after {
  border: none;
}

.answer-next-btn.primary {
  background: #FF6B35;
  color: #FFFFFF;
  border-color: #FF6B35;
}

/* 加载动画 */
.loading-bubble {
  padding: 32rpx 48rpx;
}

.typing {
  display: flex;
  gap: 12rpx;
}

.loading-hint {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-light);
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
  30% { transform: translateY(-16rpx); opacity: 1; }
}

/* 输入区域 */
.input-area {
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.voice-row {
  display: flex;
}

.hold-to-talk {
  flex: 1;
  min-height: 96rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #F8FAFC;
  border: 1rpx solid #CBD5E1;
  color: #334155;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.hold-to-talk text {
  word-break: break-word;
}

.hold-to-talk-recording {
  background: #FEE2E2;
  border-color: #F87171;
  color: #B91C1C;
}

.hold-to-talk-waiting {
  background: #EFF6FF;
  border-color: #93C5FD;
  color: #1D4ED8;
}

.text-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.input-wrapper {
  flex: 1;
  min-width: 0;
}

.input {
  width: 100%;
  min-height: 100rpx;
  max-height: 240rpx;
  font-size: 32rpx;
  color: var(--text);
  line-height: 1.6;
  padding: 20rpx 32rpx;
  background: #F8FAFC;
  border-radius: 20rpx;
  border: 1rpx solid #CBD5E1;
  box-sizing: border-box;
}

.input[disabled] {
  background: #F1F5F9;
  color: var(--text-muted);
}

.send-btn {
  flex-shrink: 0;
  width: 160rpx;
  min-height: 100rpx;
  line-height: 1.45;
  background: var(--primary);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 24rpx 0;
  text-align: center;
}

.send-btn[disabled] {
  background: var(--border);
  color: var(--text-muted);
}

.structured-answer {
  margin-top: 12rpx;
}

.judgment-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  padding-left: 18rpx;
  border-left: 4rpx solid var(--primary);
  margin-bottom: 20rpx;
  line-height: 1.7;
}

.followup-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 14rpx;
}

.followup-btn {
  flex: 0 0 calc(50% - 8rpx);
  min-width: 0;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  color: var(--text);
  background: var(--primary-bg);
  border: none;
  border-radius: 8rpx;
  line-height: 1.5;
  text-align: center;
  min-height: 52rpx;
}
