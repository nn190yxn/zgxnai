<!-- 成长服务页面 - 审核期版本 -->
<view class="membership-page">
  <!-- 成长服务状态卡片 -->
  <view class="membership-card">
    <view class="membership-header">
      <text class="membership-title">宝贝成长服务</text>
    </view>
    <view class="membership-body">
      <view class="membership-info">
        <text class="membership-type">{{membershipInfo.is_active ? (membershipInfo.membership_type === 'trial' ? '成长服务试用中' : '成长服务已开通') : '当前为基础服务'}}</text>
        <text class="membership-days" wx:if="{{membershipInfo.days_left > 0}}">剩余 {{membershipInfo.days_left}} 天</text>
        <text class="membership-tip" wx:if="{{!membershipInfo.is_active}}">{{signupBenefitText}}</text>
      </view>
      <view class="membership-actions">
        <button class="btn-primary" bindtap="activateTrial" wx:if="{{!membershipInfo.is_trial_used && !membershipInfo.is_active}}">领取15天成长服务试用</button>
      </view>
    </view>
  </view>

  <view class="membership-card recall-card" wx:if="{{showExpiryRecall}}">
    <view class="membership-body">
      <view class="recall-badge {{expiryRecallLevel === 'urgent' ? 'recall-urgent' : 'recall-soon'}}">
        <text class="badge-text">{{expiryRecallLevel === 'urgent' ? '即将到期' : '快到期了'}}</text>
      </view>
      <text class="recall-title">{{expiryRecallLevel === 'urgent' ? '您的成长服务将在3天内到期' : '您的成长服务将在7天内到期'}}</text>
      <text class="recall-desc">{{expiryRecallLevel === 'urgent' ? '续费可继续享受1v1育儿陪伴、AI问答和每周成长总结。到期后基础功能不受影响，但专属内容将暂停。' : '提前续费可避免服务中断，连续记录不丢失，AI陪伴不暂停。'}}</text>
    </view>
  </view>

  <!-- 支付状态提示 -->
    <view class="audit-notice" wx:if="{{!showPayment}}">
      <view class="notice-icon">VIP</view>
      <text class="notice-title">成长服务购买能力配置中</text>
      <text class="notice-desc">{{paymentNotice}}</text>
      <text class="notice-desc">当前可先使用注册赠送、试用资格和邀请奖励</text>
  </view>

  <!-- 成长服务方案 -->
  <view class="plans-section" wx:if="{{showMembership}}">
    <view class="section-title">选择成长服务方案</view>
    <view class="plans-list">
      <view class="plan-item {{selectedPlan === item.code ? 'plan-selected' : ''}}" wx:for="{{plans}}" wx:key="code" data-code="{{item.code}}" bindtap="selectPlan">
        <view class="plan-header">
          <text class="plan-name">{{item.name}}</text>
          <text class="plan-duration">{{item.duration}}</text>
        </view>
        <view class="plan-price">
          <text class="price-current">¥{{item.price}}</text>
        </view>
        <view class="plan-desc">{{item.description}}</view>
      </view>
    </view>
    <view class="referral-info" wx:if="{{showPayment}}">
      <text class="referral-desc">{{paymentCapabilityHint}}</text>
    </view>
    <button wx:if="{{showPayment}}" class="btn-pay" loading="{{isPaying}}" disabled="{{isPaying}}" bindtap="paySelectedPlan">{{isPaying ? '开通处理中' : '使用官方虚拟支付开通'}}</button>
    <button wx:else class="btn-pay btn-pay-disabled" disabled="true">官方虚拟支付能力配置中</button>
  </view>

  <!-- 兑换码 -->
  <view class="promo-section" wx:if="{{promoEnabled}}">
    <view class="section-title">兑换码</view>
    <view class="referral-info">
      <text class="referral-desc">{{promoBenefitText}}</text>
    </view>
    <view class="promo-input">
        <input type="text" placeholder="输入成长服务兑换码" value="{{promoCode}}" bindinput="inputPromoCode" />
        <button class="btn-promo" bindtap="redeemPromoCode">兑换</button>
      </view>
  </view>

  <view class="plans-section">
    <view class="section-title">可查看的成长内容</view>
    <view class="benefit-list">
      <view class="benefit-item {{item.unlocked ? 'benefit-item-active' : ''}}" wx:for="{{displayFeatures}}" wx:key="key">
        <view class="benefit-head">
          <text class="benefit-title">{{item.title}}</text>
          <text class="benefit-status {{item.unlocked ? 'benefit-status-active' : ''}}">{{item.statusText}}</text>
        </view>
        <text class="benefit-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 裂变邀请 -->
  <view class="referral-section">
    <view class="section-title">邀请家人朋友</view>
    <view class="referral-info">
      <text class="referral-desc">邀请好友注册，双方各得7天成长服务，可与新用户注册礼包叠加</text>
    </view>
    <view class="referral-stats">
      <view class="stat-item">
        <text class="stat-value">{{referralStats.total_invites || 0}}</text>
        <text class="stat-label">已邀请</text>
      </view>
    </view>
    <button class="btn-share" open-type="share">发送邀请</button>
  </view>
</view>
