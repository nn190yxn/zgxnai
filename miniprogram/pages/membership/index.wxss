/* pages/membership/index.wxss */
.membership-page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.membership-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.membership-header {
  margin-bottom: 20rpx;
}

.membership-title {
  font-size: 36rpx;
  font-weight: bold;
}

.membership-status {
  margin-top: 10rpx;
}

.status-text {
  font-size: 28rpx;
  opacity: 0.9;
}

.membership-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.membership-info {
  flex: 1;
}

.membership-type {
  font-size: 32rpx;
  font-weight: bold;
}

.membership-days {
  font-size: 28rpx;
  margin-top: 10rpx;
  opacity: 0.9;
}

.membership-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.btn-primary {
  background: #fff;
  color: #667eea;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

.plans-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.plans-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-item {
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 30rpx;
  background: #fafafa;
}

.plan-selected {
  border-color: #667eea;
  background: #f0f4ff;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.plan-duration {
  font-size: 24rpx;
  color: #999;
}

.plan-price {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.price-original {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}

.plan-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.plan-auto-renew {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.renew-text {
  font-size: 24rpx;
  color: #666;
}

.btn-pay {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 30rpx;
}

.btn-pay-disabled {
  background: #c8c9cc;
  color: #fff;
}

.promo-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.promo-input {
  display: flex;
  gap: 20rpx;
}

.promo-input input {
  flex: 1;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.btn-promo {
  background: #667eea;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.benefit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.benefit-item {
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.benefit-item-active {
  background: #eef8ee;
}

.benefit-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.benefit-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.benefit-status {
  font-size: 22rpx;
  color: #d65a1f;
  background: #fff1ea;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.benefit-status-active {
  color: #2f8f46;
  background: #e7f6ea;
}

.benefit-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.referral-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.referral-info {
  margin-bottom: 20rpx;
}

.referral-desc {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.referral-limit {
  font-size: 24rpx;
  color: #999;
}

.referral-stats {
  display: flex;
  justify-content: space-around;
  margin: 30rpx 0;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.btn-share {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
}
