/* 知识点列表页面样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 骨架屏样式 */
.skeleton-container {
  padding: 24rpx 32rpx;
}

.skeleton-chapter {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.skeleton-point {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

/* 章节列表 */
.chapter-list {
  padding: 24rpx 32rpx;
}

/* 章节头部 */
.chapter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.chapter-info {
  flex: 1;
  min-width: 0;
}

.chapter-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.45;
}

.chapter-progress {
  display: flex;
  align-items: center;
}

.progress-bar-mini {
  flex: 1;
  max-width: 200rpx;
  height: 10rpx;
  background: #E8E8E8;
  border-radius: 5rpx;
  overflow: hidden;
  margin-right: 12rpx;
}

.progress-fill-mini {
  height: 100%;
  background: linear-gradient(90deg, #FF7E4B, #FF6B35);
  border-radius: 5rpx;
}

.progress-text-mini {
  font-size: 22rpx;
  color: #FF6B35;
  font-weight: 600;
  line-height: 1.45;
}

.chapter-arrow {
  font-size: 24rpx;
  color: #aaa;
  transition: transform 0.3s;
  margin-left: 16rpx;
}

.chapter-arrow.expanded {
  transform: rotate(180deg);
}

/* 知识点列表 */
.point-list {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.point-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.point-item:last-child {
  border-bottom: none;
}

.point-item:active {
  background: #FAFAFA;
}

/* 知识点状态 */
.point-status {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.point-status.mastered {
  background: #FFF3ED;
}

.point-status.learning {
  background: #FFF3E0;
}

.point-status.pending {
  background: #F5F5F5;
}

.status-icon {
  font-size: 24rpx;
}

.point-status.mastered .status-icon {
  color: #FF6B35;
}

.point-status.learning .status-icon {
  color: #E65100;
}

.point-status.pending .status-icon {
  color: #aaa;
}

/* 知识点内容 */
.point-content {
  flex: 1;
  min-width: 0;
}

.point-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.point-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx 12rpx;
}

.point-difficulty {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  line-height: 1.45;
}

.point-difficulty.difficulty-1 {
  background: #FFF3ED;
  color: #FF6B35;
}

.point-difficulty.difficulty-2 {
  background: #FFF3E0;
  color: #E65100;
}

.point-difficulty.difficulty-3 {
  background: #FFEBEE;
  color: #C62828;
}

.point-status-text {
  font-size: 22rpx;
  line-height: 1.45;
}

.point-status-text.status-mastered {
  color: #FF6B35;
}

.point-status-text.status-learning {
  color: #E65100;
}

.point-status-text.status-pending {
  color: #888;
}

/* 知识点操作 */
.point-actions {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 76rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  box-sizing: border-box;
}

.action-btn:active {
  background: #E8E8E8;
}

.action-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 20rpx;
  color: #666;
  line-height: 1.45;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #888;
  line-height: 1.6;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 测试弹窗 */
.test-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: relative;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.45;
}

.modal-close {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
  color: #aaa;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.test-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.test-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.test-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.45;
}

.test-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.test-tips {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: #888;
  line-height: 1.8;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #666;
  border-right: 1rpx solid #F0F0F0;
  line-height: 1.45;
}

.btn-confirm {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #FF6B35;
  font-weight: 600;
  line-height: 1.45;
}

.btn-confirm:active {
  background: #F5F5F5;
}
