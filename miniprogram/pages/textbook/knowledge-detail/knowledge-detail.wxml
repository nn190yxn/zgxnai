<!-- 知识点详情页面 -->
<view class="page page-transition">
  <!-- 骨架屏加载状态 -->
  <view class="skeleton-detail-container" wx:if="{{loading}}">
    <view style="padding: 32rpx;">
      <view class="skeleton skeleton-title" style="width: 60%; height: 48rpx; margin-bottom: 32rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 100%; height: 200rpx; margin-bottom: 32rpx; border-radius: 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 100%; margin-bottom: 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 90%; margin-bottom: 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 95%; margin-bottom: 16rpx;"></view>
    </view>
  </view>

  <block wx:if="{{!loading && knowledgeDetail}}">
    <!-- 知识点头部 -->
    <view class="point-header">
      <view class="point-title-wrap">
        <view class="point-tags">
          <text class="tag difficulty-{{knowledgeDetail.difficulty}}">{{knowledgeDetail.difficulty === 1 ? '简单' : knowledgeDetail.difficulty === 2 ? '中等' : '困难'}}</text>
          <text class="tag status-{{knowledgeDetail.status}}">{{knowledgeDetail.status === 'mastered' ? '会了' : knowledgeDetail.status === 'learning' ? '正在练' : '待练'}}</text>
        </view>
      </view>
      <view class="master-btn {{knowledgeDetail.status === 'mastered' ? 'mastered' : ''}}" bindtap="showMasterConfirm">
        <text class="master-icon">{{knowledgeDetail.status === 'mastered' ? '✓' : '○'}}</text>
        <text class="master-text">{{knowledgeDetail.status === 'mastered' ? '会了' : '标记会了'}}</text>
      </view>
    </view>

    <!-- 标签栏 -->
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 'explain' ? 'active' : ''}}" bindtap="switchTab" data-tab="explain">
        <text class="tab-text">怎么做</text>
      </view>
      <view class="tab-item {{currentTab === 'key' ? 'active' : ''}}" bindtap="switchTab" data-tab="key">
        <text class="tab-text">步骤</text>
      </view>
      <view class="tab-item {{currentTab === 'example' ? 'active' : ''}}" bindtap="switchTab" data-tab="example">
          <text class="tab-text">示范</text>
      </view>
      <view class="tab-item {{currentTab === 'practice' ? 'active' : ''}}" bindtap="switchTab" data-tab="practice">
        <text class="tab-text">练习</text>
      </view>
      <view class="tab-item {{currentTab === 'note' ? 'active' : ''}}" bindtap="switchTab" data-tab="note">
          <text class="tab-text">记录</text>
      </view>
    </view>

    <!-- 内容区域 -->
    <view class="content-area">
      <!-- 知识点讲解 -->
      <view class="tab-content" wx:if="{{currentTab === 'explain'}}">
        <view class="detail-visual-card" wx:if="{{knowledgeDetail.visual}}">
          <text class="detail-visual-icon">{{knowledgeDetail.visual.icon}}</text>
          <view class="detail-visual-text">
            <text class="detail-visual-title">{{knowledgeDetail.visual.title}}</text>
            <text class="detail-visual-desc">{{knowledgeDetail.visual.desc}}</text>
          </view>
        </view>
        <view class="coach-toolkit-card">
          <view class="coach-toolkit-head">
            <text class="coach-toolkit-title">今晚照着做</text>
            <text class="coach-toolkit-duration">约 {{knowledgeDetail.duration}} 分钟</text>
          </view>
          <view class="coach-toolkit-list">
            <view class="coach-toolkit-item">
                <text class="coach-toolkit-label">今天先练</text>
              <text class="coach-toolkit-value">{{knowledgeDetail.objective || '陪孩子完成一次小练习'}}</text>
            </view>
            <view class="coach-toolkit-item">
              <text class="coach-toolkit-label">{{knowledgeDetail.display_material_label}}</text>
              <text class="coach-toolkit-value">{{knowledgeDetail.display_material_value}}</text>
            </view>
            <view class="coach-toolkit-item">
                <text class="coach-toolkit-label">可以这样问</text>
              <text class="coach-toolkit-value">{{knowledgeDetail.parent_prompt || '围绕谁、做什么、为什么做追问'}}</text>
            </view>
          </view>
          <view class="coach-toolkit-actions">
            <view class="coach-toolkit-btn" bindtap="copyParentPrompt">
              <text>复制这句</text>
            </view>
            <view class="coach-toolkit-btn" bindtap="copySessionPlan">
              <text>复制今晚步骤</text>
            </view>
            <view class="coach-toolkit-btn primary" bindtap="goPracticeTab">
              <text>开始练习</text>
            </view>
          </view>
        </view>
        <view class="practice-material-card" wx:if="{{knowledgeDetail.has_reading_sections && knowledgeDetail.reading_sections.passage}}">
          <view class="section-head-row material-head-row">
            <text class="section-title">阅读正文</text>
            <text class="section-badge soft">先读这段</text>
          </view>
          <text class="practice-material-text" user-select="true">{{knowledgeDetail.reading_sections.passage}}</text>
        </view>
        <view class="reading-structure-card" wx:if="{{knowledgeDetail.has_reading_sections && knowledgeDetail.reading_sections.questions.length}}">
          <view class="section-head-row">
            <text class="section-title">先问这几句</text>
            <text class="section-badge">跟着提问</text>
          </view>
          <view class="reading-structure-list">
            <view class="reading-structure-item question" wx:for="{{knowledgeDetail.reading_sections.questions}}" wx:key="index">
              <text class="reading-structure-mark">问</text>
              <text class="reading-structure-text">{{item}}</text>
            </view>
          </view>
        </view>
        <view class="step-checklist-card" wx:if="{{stepChecklist.length > 0}}">
          <view class="step-checklist-head">
            <view class="step-checklist-heading">
              <text class="step-checklist-title">今天先做这几步</text>
              <text class="step-checklist-subtitle">按顺序完成，阅读节奏会更稳</text>
            </view>
            <text class="step-checklist-progress">{{stepChecklistDoneCount}} / {{stepChecklist.length}} 已完成</text>
          </view>
          <view class="step-checklist-list">
            <view class="step-checklist-item {{item.done ? 'done' : ''}}" wx:for="{{stepChecklist}}" wx:key="id" data-index="{{index}}" bindtap="toggleChecklistItem">
              <text class="step-checklist-mark">{{item.done ? '✓' : index + 1}}</text>
              <text class="step-checklist-text">{{item.content}}</text>
            </view>
          </view>
        </view>
        <view class="reading-structure-card" wx:if="{{knowledgeDetail.has_reading_sections && knowledgeDetail.reading_sections.analysis.length}}">
          <view class="section-head-row">
            <text class="section-title">怎么带着读</text>
            <text class="section-badge soft">边读边讲</text>
          </view>
          <view class="reading-structure-list">
            <view class="reading-structure-item" wx:for="{{knowledgeDetail.reading_sections.analysis}}" wx:key="index">
              <text class="reading-structure-mark">解</text>
              <text class="reading-structure-text">{{item}}</text>
            </view>
          </view>
        </view>
        <view class="reading-structure-card" wx:if="{{knowledgeDetail.has_reading_sections && knowledgeDetail.reading_sections.extension.length}}">
          <view class="section-head-row">
            <text class="section-title">读完再玩一下</text>
            <text class="section-badge warn">读完再做</text>
          </view>
          <view class="reading-structure-list">
            <view class="reading-structure-item extension" wx:for="{{knowledgeDetail.reading_sections.extension}}" wx:key="index">
              <text class="reading-structure-mark">练</text>
              <text class="reading-structure-text">{{item}}</text>
            </view>
          </view>
        </view>
        <view class="explain-section" wx:if="{{!knowledgeDetail.has_reading_sections}}">
          <view class="section-head-row">
            <text class="section-title">{{knowledgeDetail.explain.title}}</text>
            <text class="section-badge">分段讲解</text>
          </view>
          <view class="explain-content">
            <block wx:for="{{explainBlocks}}" wx:key="index">
              <view class="explain-block explain-block-{{item.type}}">
                <view class="explain-heading" wx:if="{{item.type === 'heading'}}">
                  <text class="explain-heading-tag">{{item.title}}</text>
                  <text class="explain-heading-text" wx:if="{{item.text}}">{{item.text}}</text>
                </view>
                <view class="explain-step" wx:if="{{item.type === 'step'}}">
                  <text class="explain-step-index">{{item.index}}</text>
                  <text class="explain-step-text">{{item.text}}</text>
                </view>
                <view class="explain-bullet" wx:if="{{item.type === 'bullet'}}">
                  <text class="explain-bullet-dot"></text>
                  <text class="explain-bullet-text">{{item.text}}</text>
                </view>
                <text class="explain-lead" user-select="true" wx:if="{{item.type === 'lead'}}">{{item.text}}</text>
                <text class="explain-text" user-select="true" wx:if="{{item.type === 'paragraph'}}">{{item.text}}</text>
              </view>
            </block>
          </view>
        </view>
      </view>

      <!-- 重点难点 -->
      <view class="tab-content" wx:if="{{currentTab === 'key'}}">
        <view class="key-section">
          <view class="section-head-row">
            <text class="section-title">照着做</text>
            <text class="section-badge soft">按顺序做</text>
          </view>
          <view class="key-list">
            <view class="key-item" wx:for="{{knowledgeDetail.keyPoints}}" wx:key="id">
              <view class="key-icon-wrap">
                <text class="key-icon">{{index + 1}}</text>
              </view>
              <view class="key-body">
                <text class="key-label">这一步</text>
                <text class="key-text">{{item.content}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="key-section">
          <view class="section-head-row">
            <text class="section-title">家长提醒</text>
            <text class="section-badge warn">避免踩坑</text>
          </view>
          <view class="key-list difficulty-list">
            <view class="key-item difficulty-item" wx:for="{{knowledgeDetail.difficulties}}" wx:key="id">
              <view class="key-icon-wrap warn">
                <text class="key-icon">!</text>
              </view>
              <view class="key-body">
                <text class="key-label warn">提醒</text>
                <text class="key-text">{{item.content}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 典型例题 -->
      <view class="tab-content" wx:if="{{currentTab === 'example'}}">
        <view class="example-list">
          <view class="example-item" wx:for="{{knowledgeDetail.examples}}" wx:key="id">
            <view class="example-header">
              <text class="example-title">{{item.title}}</text>
            </view>
            <view class="example-question">
              <text class="question-label">题目</text>
              <text class="question-text">{{item.question}}</text>
            </view>
            <view class="example-answer">
              <text class="answer-label">可以参考</text>
              <text class="answer-text">{{item.answer}}</text>
            </view>
            <view class="example-analysis">
              <text class="analysis-label">家长怎么看</text>
              <text class="analysis-text">{{item.analysis}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 练习题 -->
      <view class="tab-content" wx:if="{{currentTab === 'practice'}}">
        <view class="practice-area" wx:if="{{knowledgeDetail.practices.length > 0}}">
          <view class="practice-progress">
            <text class="progress-text">第 {{currentPracticeIndex + 1}} 题 / 共 {{knowledgeDetail.practices.length}} 题</text>
          </view>

          <view class="practice-question">
            <text class="question-text">{{knowledgeDetail.practices[currentPracticeIndex].question}}</text>
          </view>

          <!-- 选择题 -->
          <view class="practice-options" wx:if="{{knowledgeDetail.practices[currentPracticeIndex].type === 'choice'}}">
            <view class="option-item {{practiceAnswers[currentPracticeIndex] === index ? 'selected' : ''}}"
                  wx:for="{{knowledgeDetail.practices[currentPracticeIndex].options}}"
                  wx:key="index"
                  bindtap="selectAnswer"
                  data-index="{{index}}">
              <text class="option-letter">{{['A', 'B', 'C', 'D'][index]}}</text>
              <text class="option-text">{{item}}</text>
            </view>
          </view>

          <!-- 填空题 -->
          <view class="practice-fill" wx:if="{{knowledgeDetail.practices[currentPracticeIndex].type === 'fill'}}">
            <input class="fill-input"
                   placeholder="把孩子的答案写在这里"
                   value="{{practiceAnswers[currentPracticeIndex] || ''}}"
                   bindinput="onFillInput" />
          </view>

          <!-- 导航按钮 -->
          <view class="practice-nav">
            <view class="nav-btn prev-btn {{currentPracticeIndex === 0 ? 'disabled' : ''}}" bindtap="prevPractice">
              <text>上一题</text>
            </view>
            <view class="nav-btn next-btn {{currentPracticeIndex === knowledgeDetail.practices.length - 1 ? 'disabled' : ''}}" bindtap="nextPractice">
              <text>下一题</text>
            </view>
          </view>

          <!-- 提交按钮 -->
          <view class="submit-btn" bindtap="submitPractice">
            <text>看看答得怎么样</text>
          </view>
          <view class="practice-reset-btn" bindtap="resetPractice">
            <text>再练一遍</text>
          </view>
        </view>
      </view>

      <!-- 练习记录 -->
      <view class="tab-content" wx:if="{{currentTab === 'note'}}">
        <view class="note-section">
          <text class="section-title">这次练习记录</text>
          <textarea class="note-input"
                    placeholder="记下孩子哪里顺、哪里卡，下次更好接着练。"
                    value="{{noteContent}}"
                    bindinput="onNoteInput"
                    maxlength="1000">
          </textarea>
          <view class="note-footer">
            <text class="note-count">{{noteContent.length}}/1000</text>
            <view class="save-btn" bindtap="saveNote">
              <text>保存记录</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>

<!-- 练习结果弹窗 -->
<view class="modal-mask" wx:if="{{showPracticeResult}}" bindtap="closePracticeResult">
  <view class="result-modal" catchtap="preventBubble">
    <view class="modal-header">
      <text class="modal-title">这次练得怎么样</text>
      <view class="modal-close" bindtap="closePracticeResult">×</view>
    </view>
    <view class="modal-body">
      <view class="result-score">
        <text class="score-num">{{practiceResult.score}}</text>
        <text class="score-unit">分</text>
      </view>
      <view class="result-stats">
        <view class="stat-item">
          <text class="stat-value">{{practiceResult.total}}</text>
          <text class="stat-label">一共</text>
        </view>
        <view class="stat-item correct">
          <text class="stat-value">{{practiceResult.correct}}</text>
          <text class="stat-label">答对</text>
        </view>
        <view class="stat-item wrong">
          <text class="stat-value">{{practiceResult.total - practiceResult.correct}}</text>
          <text class="stat-label">再练</text>
        </view>
      </view>
      <view class="result-tips">
        <text wx:if="{{practiceResult.score >= 80}}">这次完成得很稳！</text>
        <text wx:elif="{{practiceResult.score >= 60}}">已经有进步，再练一轮会更顺。</text>
        <text wx:else>先别急，换个更短的步骤再试。</text>
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn-confirm" bindtap="closePracticeResult">知道了</view>
    </view>
  </view>
</view>

<!-- 会了确认弹窗 -->
<view class="modal-mask" wx:if="{{showMasterModal}}" bindtap="hideMasterModal">
  <view class="master-modal" catchtap="preventBubble">
    <view class="modal-header">
      <text class="modal-title">标记为会了</text>
      <view class="modal-close" bindtap="hideMasterModal">×</view>
    </view>
    <view class="modal-body">
      <view class="master-icon-wrap">
        <text class="master-icon-big">✓</text>
      </view>
      <text class="master-desc">这次孩子已经比较熟了吗？</text>
      <text class="master-tip">标记后，下次会少安排同类练习。</text>
    </view>
    <view class="modal-footer">
      <view class="btn-cancel" bindtap="hideMasterModal">再想想</view>
      <view class="btn-confirm" bindtap="confirmMaster">已经会了</view>
    </view>
  </view>
</view>
