/* 知识点详情页面样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #888;
}

/* 知识点头部 */
.point-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.point-title-wrap {
  flex: 1;
  min-width: 0;
}

.point-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.point-tags {
  display: flex;
  align-items: center;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.tag.difficulty-1 {
  background: #FFF3ED;
  color: #FF6B35;
}

.tag.difficulty-2 {
  background: #FFF3E0;
  color: #E65100;
}

.tag.difficulty-3 {
  background: #FFEBEE;
  color: #C62828;
}

.tag.status-mastered {
  background: #FFF3ED;
  color: #FF6B35;
}

.tag.status-learning {
  background: #FFF3E0;
  color: #E65100;
}

.tag.status-pending {
  background: #F5F5F5;
  color: #888;
}

.master-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFF3ED;
  border-radius: 16rpx;
  margin-left: 20rpx;
}

.master-btn.mastered {
  background: #FF6B35;
}

.master-icon {
  font-size: 32rpx;
  color: #FF6B35;
  margin-bottom: 4rpx;
}

.master-btn.mastered .master-icon {
  color: #fff;
}

.master-text {
  font-size: 22rpx;
  color: #FF6B35;
}

.master-btn.mastered .master-text {
  color: #fff;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #888;
}

.tab-item.active .tab-text {
  color: #FF6B35;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}

/* 内容区域 */
.content-area {
  padding: 24rpx 32rpx;
}

.tab-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.detail-visual-card {
  display: flex;
  align-items: center;
  padding: 22rpx;
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  background: linear-gradient(150deg, #FFF2EC, #FAF6F3);
  border: 1rpx solid rgba(255, 107, 53, 0.16);
}

.detail-visual-icon {
  width: 84rpx;
  height: 84rpx;
  margin-right: 18rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 42rpx;
  line-height: 84rpx;
}

.detail-visual-text {
  flex: 1;
  min-width: 0;
}

.detail-visual-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #4B3830;
  margin-bottom: 6rpx;
}

.detail-visual-desc {
  display: block;
  font-size: 23rpx;
  color: #7A6258;
  line-height: 1.5;
}

.coach-toolkit-card,
.step-checklist-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FFF9F5;
  border: 1rpx solid rgba(255, 107, 53, 0.14);
}

.coach-toolkit-head,
.step-checklist-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18rpx;
  gap: 16rpx;
}

.step-checklist-heading {
  flex: 1;
  min-width: 0;
}

.step-checklist-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9A786A;
}

.coach-toolkit-title,
.step-checklist-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #4B3830;
}

.coach-toolkit-duration,
.step-checklist-progress {
  font-size: 22rpx;
  color: #A06B54;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 107, 53, 0.10);
  white-space: nowrap;
}

.coach-toolkit-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.coach-toolkit-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
}

.coach-toolkit-label {
  display: block;
  font-size: 22rpx;
  color: #A06B54;
  margin-bottom: 8rpx;
}

.coach-toolkit-value {
  display: block;
  font-size: 27rpx;
  color: #333;
  line-height: 1.6;
}

.coach-toolkit-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.coach-toolkit-btn {
  min-width: 180rpx;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #A05A36;
  font-size: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 107, 53, 0.18);
}

.coach-toolkit-btn.primary {
  background: #FF6B35;
  color: #FFFFFF;
}

.step-checklist-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.step-checklist-item {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
}

.step-checklist-item.done {
  background: #FFF0E8;
}

.step-checklist-mark {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #FFE1D3;
  color: #FF6B35;
  text-align: center;
  line-height: 40rpx;
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.step-checklist-item.done .step-checklist-mark {
  background: #FF6B35;
  color: #FFFFFF;
}

.step-checklist-text {
  flex: 1;
  font-size: 27rpx;
  color: #333;
  line-height: 1.6;
}

/* 知识点讲解 */
.explain-section {
  padding: 8rpx 0;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.section-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-head-row .section-title {
  margin-bottom: 0;
}

.section-badge {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #FFF1E8;
  color: #C95B29;
  font-size: 22rpx;
  font-weight: 600;
}

.section-badge.soft {
  background: #EEF6FF;
  color: #2E6BCB;
}

.section-badge.warn {
  background: #FFF4E8;
  color: #C46A17;
}

.practice-material-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #F7FBFF 0%, #EEF6FF 100%);
  border: 1rpx solid rgba(46, 107, 203, 0.14);
}

.material-head-row {
  align-items: flex-start;
}

.practice-material-text {
  display: block;
  font-size: 28rpx;
  color: #2E3E56;
  line-height: 1.9;
  white-space: pre-wrap;
}

.reading-structure-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(255, 107, 53, 0.10);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.reading-structure-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reading-structure-item {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #FFF8F4;
}

.reading-structure-item.question {
  background: #FFF3ED;
}

.reading-structure-item.extension {
  background: #FFF7EE;
}

.reading-structure-mark {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
  border-radius: 14rpx;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.reading-structure-text {
  flex: 1;
  font-size: 27rpx;
  color: #4B3830;
  line-height: 1.75;
  white-space: pre-wrap;
}

.explain-content {
  background: linear-gradient(180deg, #FFFDFC 0%, #FFF8F4 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 107, 53, 0.10);
}

.explain-block {
  margin-bottom: 18rpx;
}

.explain-block:last-child {
  margin-bottom: 0;
}

.explain-heading-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #FFE9DD;
  color: #C25729;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.explain-heading-text {
  display: block;
  font-size: 27rpx;
  color: #5C453B;
  line-height: 1.7;
}

.explain-step,
.explain-bullet {
  display: flex;
  align-items: flex-start;
}

.explain-step-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: #FF6B35;
  color: #FFFFFF;
  text-align: center;
  line-height: 44rpx;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.explain-step-text,
.explain-bullet-text {
  flex: 1;
  font-size: 27rpx;
  color: #333;
  line-height: 1.7;
}

.explain-bullet-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FF8A5D;
  margin: 14rpx 16rpx 0 6rpx;
  flex-shrink: 0;
}

.explain-lead {
  display: block;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  color: #4B3830;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.7;
  box-shadow: inset 0 0 0 1rpx rgba(255, 107, 53, 0.10);
}

.explain-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 重点难点 */
.key-section {
  margin-bottom: 32rpx;
}

.key-section:last-child {
  margin-bottom: 0;
}

.key-list {
  padding: 8rpx 0;
}

.key-item {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 20rpx;
  border-bottom: none;
  border-radius: 18rpx;
  background: #FCFCFC;
  margin-bottom: 14rpx;
}

.key-item:last-child {
  margin-bottom: 0;
}

.key-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: #FFE6D8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.key-icon-wrap.warn {
  background: #FFF0DA;
}

.key-icon {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 700;
}

.difficulty-item .key-icon {
  color: #C97A12;
}

.key-body {
  flex: 1;
}

.key-label {
  display: inline-flex;
  margin-bottom: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #FFF1E8;
  color: #C25729;
  font-size: 21rpx;
  font-weight: 600;
}

.key-label.warn {
  background: #FFF3E0;
  color: #C46A17;
}

.key-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 典型例题 */
.example-list {
  padding: 8rpx 0;
}

.example-item {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF9F5 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 107, 53, 0.10);
}

.example-item:last-child {
  margin-bottom: 0;
}

.example-header {
  margin-bottom: 16rpx;
}

.example-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B35;
}

.example-question,
.example-answer,
.example-analysis {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
}

.example-analysis {
  margin-bottom: 0;
  background: #FFF8EF;
}

.example-question {
  background: #F7F8FA;
}

.example-answer {
  background: #FFF1E8;
}

.question-label,
.answer-label,
.analysis-label {
  display: inline-flex;
  margin-bottom: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.question-label {
  color: #5A6472;
  background: #EDEFF3;
}

.answer-label {
  color: #C25729;
  background: #FFDCCB;
}

.analysis-label {
  color: #B26A14;
  background: #FFECCB;
}

.question-text,
.answer-text,
.analysis-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.answer-text {
  color: #FF6B35;
  font-weight: 500;
}

/* 练习题 */
.practice-area {
  padding: 8rpx 0;
}

.practice-progress {
  text-align: center;
  margin-bottom: 24rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #888;
}

.practice-question {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.practice-question .question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 选择题选项 */
.practice-options {
  margin-bottom: 24rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: #FAFAFA;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.option-item:active {
  background: #F0F0F0;
}

.option-item.selected {
  background: #FFF3ED;
  border-color: #FF6B35;
}

.option-letter {
  width: 48rpx;
  height: 48rpx;
  background: #E8E8E8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.option-item.selected .option-letter {
  background: #FF6B35;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 填空题 */
.practice-fill {
  margin-bottom: 24rpx;
}

.fill-input {
  width: 100%;
  height: 88rpx;
  background: #FAFAFA;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.fill-input:focus {
  border-color: #FF6B35;
}

/* 导航按钮 */
.practice-nav {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-btn {
  padding: 16rpx 32rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.nav-btn:active {
  background: #E8E8E8;
}

.nav-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 提交按钮 */
.submit-btn {
  text-align: center;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #FF7E4B, #FF6B35);
  border-radius: 16rpx;
}

.practice-reset-btn {
  margin-top: 18rpx;
  text-align: center;
  font-size: 24rpx;
  color: #A06B54;
}

.submit-btn:active {
  opacity: 0.9;
}

.submit-btn text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

/* 学习笔记 */
.note-section {
  padding: 8rpx 0;
}

.note-input {
  width: 100%;
  height: 300rpx;
  background: #FAFAFA;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.note-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.note-count {
  font-size: 24rpx;
  color: #aaa;
}

.save-btn {
  padding: 16rpx 32rpx;
  background: #FF6B35;
  border-radius: 12rpx;
}

.save-btn:active {
  opacity: 0.9;
}

.save-btn text {
  font-size: 26rpx;
  color: #fff;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 结果弹窗 */
.result-modal,
.master-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: relative;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
  color: #aaa;
  line-height: 1;
}

.modal-body {
  padding: 40rpx 32rpx;
  text-align: center;
}

.result-score {
  margin-bottom: 32rpx;
}

.score-num {
  font-size: 80rpx;
  font-weight: 900;
  color: #FF6B35;
}

.score-unit {
  font-size: 32rpx;
  color: #FF6B35;
  margin-left: 8rpx;
}

.result-stats {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
  padding: 0 32rpx;
  border-right: 1rpx solid #E8E8E8;
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.stat-item.correct .stat-value {
  color: #FF6B35;
}

.stat-item.wrong .stat-value {
  color: #C62828;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

.result-tips {
  font-size: 28rpx;
  color: #666;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #666;
  border-right: 1rpx solid #F0F0F0;
}

.btn-confirm {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #FF6B35;
  font-weight: 600;
}

.btn-confirm:active {
  background: #F5F5F5;
}

/* 掌握确认弹窗 */
.master-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: #FFF3ED;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.master-icon-big {
  font-size: 60rpx;
  color: #FF6B35;
}

.master-desc {
  display: block;
  font-size: 32rpx;
  color: #333;
