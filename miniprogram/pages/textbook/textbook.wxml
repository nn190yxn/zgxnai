<!-- 能力成长 -->
<view class="page">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">能力成长</text>
    <text class="page-subtitle">每天10分钟任务，帮助孩子读得懂、坐得住、说得出</text>
  </view>

  <!-- 能力成长任务 -->
  <view class="reading-task-section" wx:if="{{readingTasks.length > 0}}">
    <view class="section-header">
      <text class="section-title">能力成长任务</text>
      <text class="task-count">{{readingTasks.length}}项</text>
    </view>
    <view class="reading-task-list">
      <view class="reading-task-card" wx:for="{{readingTasks}}" wx:key="id" bindtap="onReadingTaskTap" data-id="{{item.id}}" data-title="{{item.title}}">
        <!-- 任务封面图 -->
        <image class="reading-task-cover" wx:if="{{item.coverImage}}" src="{{item.coverImage}}" mode="aspectFill" />
        <view class="reading-task-visual">
          <text class="reading-task-visual-icon">{{item.visualIcon}}</text>
          <text class="reading-task-visual-label">{{item.visualLabel}}</text>
        </view>
        <view class="reading-task-main">
          <view class="reading-task-head">
            <text class="reading-task-level">{{item.level}}</text>
            <text class="reading-task-age">{{item.ageRange}}</text>
            <text class="reading-task-status {{item.status}}">{{item.status === 'completed' ? '已打卡' : '待完成'}}</text>
          </view>
          <text class="reading-task-title">{{item.title}}</text>
          <text class="reading-task-material">{{item.material}}</text>
          <text class="reading-task-objective">目标：{{item.objective}}</text>
          <!-- 步骤配图 -->
          <view class="reading-task-steps">
            <view class="reading-task-step-item" wx:for="{{item.steps}}" wx:for-item="step" wx:for-index="stepIndex" wx:key="*this">
              <text class="reading-task-step">{{stepIndex + 1}}. {{step}}</text>
            </view>
          </view>
          <!-- 家长提问 -->
          <text class="reading-task-prompt" wx:if="{{item.parentPrompt}}">家长提问：{{item.parentPrompt}}</text>
          <!-- 示例回答 -->
          <view class="reading-task-example" wx:if="{{item.exampleAnswer}}">
            <text class="example-title">参考回答</text>
            <view class="example-bubble">
              <text>{{item.exampleAnswer}}</text>
            </view>
          </view>
          <!-- 家长提示 -->
          <view class="reading-task-tips" wx:if="{{item.tips}}">
            <text class="tips-title">提示</text>
            <text class="tips-content">{{item.tips}}</text>
          </view>
          <text class="reading-task-duration">预计 {{item.duration}} 分钟</text>
        </view>
        <view class="reading-task-actions">
          <text class="task-action-btn" catchtap="markReadingTaskDone" data-id="{{item.id}}" data-title="{{item.title}}">打卡</text>
          <text class="task-voice-btn" wx:if="{{item.hasTts}}" catchtap="playTtsSample" data-url="{{item.ttsUrl}}">朗读</text>
          <text class="task-share-btn" catchtap="shareReadingTask" data-title="{{item.title}}">分享</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 复述录音（最小版） -->
  <view class="recording-section">
    <view class="section-header">
      <text class="section-title">口头复述录音</text>
      <text class="task-count">用于表达训练</text>
    </view>
    <view class="recording-card">
      <text class="recording-tip">读完后用一句话复述要点，可录音回放。</text>
      <view class="recording-actions">
        <text class="recording-btn" wx:if="{{!isRecording}}" bindtap="startRecording">开始录音</text>
        <text class="recording-btn recording-btn-stop" wx:if="{{isRecording}}" bindtap="stopRecording">停止录音</text>
        <text class="recording-btn" bindtap="playRecording">回放录音</text>
      </view>
      <text class="recording-path" wx:if="{{recordFilePath}}">已生成录音，可回放</text>
    </view>
  </view>

  <!-- 成长周报（最小版） -->
  <view class="reading-report-section">
    <view class="section-header">
      <text class="section-title">本周能力成长周报</text>
      <text class="section-more" bindtap="shareWeeklyReport">分享成果卡</text>
    </view>
    <view class="reading-report-card">
      <text class="reading-report-line">完成率：{{readingWeeklyReport.completionRate}}%</text>
      <text class="reading-report-line">已完成：{{readingWeeklyReport.completed}} / {{readingWeeklyReport.total}}</text>
      <text class="reading-report-line">连续打卡：{{readingWeeklyReport.streakDays}} 天</text>
      <text class="reading-report-line">复述录音：{{readingWeeklyReport.recordingCount}} 次</text>
      <text class="reading-report-tip">建议：{{readingWeeklyReport.suggestion}}</text>
    </view>
  </view>

  <!-- 家长三句话术 -->
  <view class="reading-script-section">
    <view class="section-header">
      <text class="section-title">家长三句话术</text>
    </view>
    <view class="reading-script-card">
      <text class="reading-script-item">1. 你觉得这段故事里最重要的一句话是什么？</text>
      <text class="reading-script-item">2. 主角为什么这么做？你从哪句话看出来的？</text>
      <text class="reading-script-item">3. 你能用一句话讲给我听吗？</text>
    </view>
  </view>

  <!-- 年级选择 -->
  <view class="grade-selector" bindtap="showGradePicker">
    <view class="grade-info">
      <text class="grade-label">当前年级</text>
      <text class="grade-value">{{gradeList[currentGrade - 1].name}}</text>
    </view>
    <text class="grade-arrow">▼</text>
  </view>

  <!-- 成长进度概览 -->
  <view class="progress-section">
    <view class="section-header">
      <text class="section-title">成长进度</text>
      <text class="section-more" bindtap="onViewAllProgress">查看全部</text>
    </view>
    <view class="progress-cards">
      <view class="progress-card mastered">
        <text class="progress-num">{{progressOverview.masteredPoints}}</text>
        <text class="progress-label">已掌握</text>
      </view>
      <view class="progress-card learning">
        <text class="progress-num">{{progressOverview.learningPoints}}</text>
        <text class="progress-label">进行中</text>
      </view>
      <view class="progress-card total">
        <text class="progress-num">{{progressOverview.totalPoints}}</text>
        <text class="progress-label">能力点总数</text>
      </view>
    </view>
    <view class="progress-bar-wrap">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressOverview.masteryRate}}%;"></view>
      </view>
      <text class="progress-rate">掌握率 {{progressOverview.masteryRate}}%</text>
    </view>
  </view>

  <!-- 今日成长任务 -->
  <view class="task-section" wx:if="{{todayTasks.length > 0}}">
    <view class="section-header">
      <text class="section-title">今日成长任务</text>
      <text class="task-count">{{todayTasks.length}}项待完成</text>
    </view>
    <view class="task-list">
      <view class="task-item {{item.status}}" wx:for="{{todayTasks}}" wx:key="id" bindtap="onTaskTap" data-task="{{item}}">
        <view class="task-icon-wrap">
          <text class="task-icon">{{item.icon}}</text>
        </view>
        <view class="task-content">
          <view class="task-header">
            <text class="task-subject">{{item.subjectName}}</text>
            <text class="task-status {{item.status}}">{{item.status === 'completed' ? '已完成' : item.status === 'in_progress' ? '进行中' : '待开启'}}</text>
          </view>
          <text class="task-title">{{item.title}}</text>
          <view class="task-progress" wx:if="{{item.status === 'in_progress' && item.progress}}">
            <view class="task-progress-bar">
              <view class="task-progress-fill" style="width: {{item.progress}}%;"></view>
            </view>
            <text class="task-progress-text">{{item.progress}}%</text>
          </view>
        </view>
        <text class="task-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 能力方向列表 -->
  <view class="subject-section">
    <view class="section-header">
      <text class="section-title">能力方向</text>
    </view>
    <view class="subject-list">
      <view class="subject-card" wx:for="{{subjectList}}" wx:key="id" bindtap="onSubjectTap" data-code="{{item.code}}">
        <view class="card-icon-wrap" style="background: {{item.color}}15;">
          <text class="card-icon">{{item.icon}}</text>
        </view>
        <view class="card-content">
          <text class="card-name">{{item.name}}</text>
          <text class="card-desc">{{item.desc}}</text>
        </view>
        <text class="card-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="footer-text">完成今日任务后可分享打卡文案到朋友圈，邀请家长一起坚持</text>
  </view>
</view>

<!-- 年级选择弹窗 -->
<view class="modal-mask" wx:if="{{showGradePicker}}" bindtap="hideGradePicker">
  <view class="grade-picker-modal" catchtap="preventBubble">
    <view class="modal-header">
      <text class="modal-title">选择年级</text>
      <view class="modal-close" bindtap="hideGradePicker">×</view>
    </view>
    <view class="grade-options">
      <view class="grade-option {{currentGrade === item.id ? 'active' : ''}}" wx:for="{{gradeList}}" wx:key="id" bindtap="onGradeSelect" data-grade="{{item.id}}">
        <text class="grade-option-text">{{item.name}}</text>
        <text class="grade-option-check" wx:if="{{currentGrade === item.id}}">✓</text>
      </view>
    </view>
  </view>
</view>
