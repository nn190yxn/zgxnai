<view class="page">
  <view wx:if="{{startupSafeMode}}" class="safe-mode">
    <text class="safe-title">小牛育儿AI助理</text>
    <text class="safe-desc">安全启动模式已开启</text>
    <text class="safe-note">如果这一页能显示，说明项目编译和首页渲染正常，剩余 timeout 来自某个后续原生能力或页面逻辑。</text>
  </view>

  <block wx:if="{{!startupSafeMode}}">
  <view class="hero">
    <view class="hero-content">
      <text class="hero-badge">小牛育儿AI助理</text>
      <text class="hero-title">{{bannerList[0].title}}</text>
      <text class="hero-desc">{{bannerList[0].desc}}</text>
      <view class="hero-actions">
        <view class="hero-btn hero-btn-primary" data-action="{{bannerList[0].action}}" bindtap="onTapBannerCta">{{bannerList[0].cta}}</view>
        <view wx:if="{{featureFlags.aiChatEnabled}}" class="hero-btn hero-btn-secondary" bindtap="goToChat">问问AI助理</view>
        <view wx:else class="hero-btn hero-btn-secondary">AI问答维护中</view>
      </view>
    </view>
    <view class="hero-image hero-image-placeholder">
      <text class="hero-emoji">🌱</text>
      <text class="hero-image-title">成长支持</text>
      <text class="hero-image-desc">观察、营养、阅读、沟通，围绕家庭场景提供帮助</text>
    </view>
  </view>

  <view class="section status-section">
    <view class="status-card">
      <view class="status-row">
        <text class="status-title">妈妈今日切入口</text>
        <text class="status-rate">3分钟</text>
      </view>
      <text class="status-item">当前重点：{{growthStatus.currentFocus}}</text>
      <text class="status-item">今日建议：{{growthStatus.todaySuggestion}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">遇到这些问题，直接点</text>
    </view>

    <view class="module-grid">
      <view wx:if="{{featureFlags.assessmentsEnabled}}" class="module-card" bindtap="goToAssessment">
        <text class="module-name">成长观察</text>
        <text class="module-desc">专注表达</text>
      </view>
      <view wx:else class="module-card module-card-disabled" bindtap="goToAssessment">
        <text class="module-name">成长观察</text>
        <text class="module-desc">暂未开放</text>
      </view>

      <view wx:if="{{featureFlags.educationEnabled}}" class="module-card" bindtap="goToTextbook">
        <text class="module-name">阅读力提升</text>
        <text class="module-desc">读懂说清</text>
      </view>
      <view wx:else class="module-card module-card-disabled" bindtap="goToTextbook">
        <text class="module-name">阅读力提升</text>
        <text class="module-desc">暂未开放</text>
      </view>

      <view class="module-card" bindtap="goToNutrition">
        <text class="module-name">营养食谱</text>
        <text class="module-desc">挑食长高</text>
      </view>

      <view wx:if="{{featureFlags.parentingEnabled}}" class="module-card" bindtap="goToParenting">
        <text class="module-name">育儿知识</text>
        <text class="module-desc">妈妈锦囊</text>
      </view>
      <view wx:else class="module-card module-card-disabled" bindtap="goToParenting">
        <text class="module-name">育儿知识</text>
        <text class="module-desc">暂未开放</text>
      </view>

      <view wx:if="{{featureFlags.aiChatEnabled}}" class="module-card" bindtap="goToChat">
        <text class="module-name">家长助手</text>
        <text class="module-desc">随时提问</text>
      </view>
      <view wx:else class="module-card module-card-disabled" bindtap="goToChat">
        <text class="module-name">家长助手</text>
        <text class="module-desc">暂未开放</text>
      </view>

      <view class="module-card" bindtap="goToWeeklyReport">
        <text class="module-name">成长记录</text>
        <text class="module-desc">持续追踪</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">今日建议</text>
    </view>

    <view class="quick-action" bindtap="goToTodayTask">
      <view class="quick-content">
        <text class="quick-title">{{todayTask.title}}</text>
        <text class="quick-desc">{{todayTask.duration}}</text>
      </view>
      <view class="quick-side">
        <text class="quick-arrow">开始观察</text>
        <text class="quick-share" catchtap="onShareTaskCard">生成介绍卡</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">本周成长</text>
    </view>

    <view class="progress-card" bindtap="goToWeeklyReport">
      <text class="progress-line">理解正确率 {{weeklyProgress.understandingFrom}}% → {{weeklyProgress.understandingTo}}%</text>
      <text class="progress-line">连续打卡 {{weeklyProgress.streakDays}} 天</text>
      <view class="progress-actions">
        <text class="progress-action">查看完整周报</text>
        <text class="progress-share" catchtap="onShareProgressCard">分享成果卡</text>
      </view>
    </view>
  </view>

  <view class="tips-card">
    <text class="tips-title">温馨提示</text>
    <text class="tips-content">本服务内容仅供家庭教育参考，不能替代专业评估或诊断。如对孩子发育有明显担忧，建议咨询医生或相关专业人员。</text>
  </view>
  </block>
</view>
