/* 首页样式 */

.page {
  min-height: 100vh;
  background: #FAF6F3;
  padding-bottom: 40rpx;
}

.safe-mode {
  min-height: 100vh;
  padding: 120rpx 48rpx;
  box-sizing: border-box;
  background: #FAF6F3;
}

.safe-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #1B2A1B;
  line-height: 1.3;
}

.safe-desc {
  display: block;
  margin-top: 28rpx;
  font-size: 30rpx;
  color: #FF6B35;
  font-weight: 700;
}

.safe-note {
  display: block;
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7A6660;
}

/* Hero区域 */
.hero {
  background: linear-gradient(145deg, #E85A29, #FF6B35 40%, #FF7E4B);
  padding: 24rpx 0 12rpx;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}

.hero-content {
  margin: 0 32rpx;
  min-height: 248rpx;
  padding: 36rpx 0;
  position: relative;
  z-index: 2;
}

.hero-image {
  display: block;
  width: calc(100% - 64rpx);
  height: 330rpx;
  margin: 8rpx 32rpx 24rpx;
  border-radius: 28rpx;
  background: #FFF7EA;
  box-shadow: 0 16rpx 36rpx rgba(120, 54, 18, 0.18);
  position: relative;
  z-index: 2;
}

.hero-image-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF7EA 0%, #FFE7D6 58%, #FFF1E6 100%);
}

.hero-emoji {
  font-size: 78rpx;
  margin-bottom: 16rpx;
}

.hero-image-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #8A3412;
}

.hero-image-desc {
  width: 78%;
  margin-top: 10rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.6;
  color: #9A5B3B;
}

.hero-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.5;
}

.hero-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.hero-btn {
  flex: 1;
  text-align: center;
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.hero-btn-primary {
  background: #fff;
  color: #FF6B35;
}

.hero-btn-secondary {
  background: rgba(255,255,255,0.22);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.4);
}

/* 区块 */
.section {
  padding: 32rpx;
}

.status-section {
  padding-top: 24rpx;
  padding-bottom: 0;
}

.status-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.status-title {
  font-size: 30rpx;
  color: #1B2A1B;
  font-weight: 600;
}

.status-rate {
  font-size: 34rpx;
  color: #FF6B35;
  font-weight: 700;
}

.status-item {
  display: block;
  font-size: 24rpx;
  color: #A08C86;
  line-height: 1.6;
}

.daily-action-section {
  padding-top: 24rpx;
  padding-bottom: 0;
}

.daily-action-card {
  padding: 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2F241F 0%, #5B3829 100%);
  box-shadow: 0 14rpx 34rpx rgba(91, 56, 41, 0.18);
}

.daily-action-eyebrow {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 236, 220, 0.78);
  font-weight: 700;
  margin-bottom: 12rpx;
}

.daily-action-title {
  display: block;
  font-size: 36rpx;
  line-height: 1.35;
  color: #FFFFFF;
  font-weight: 900;
}

.daily-action-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: rgba(255, 250, 244, 0.86);
}

.daily-action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.daily-action-primary,
.daily-action-secondary {
  flex: 1;
  padding: 18rpx 12rpx;
  border-radius: 18rpx;
  text-align: center;
  font-size: 25rpx;
  font-weight: 800;
}

.daily-action-primary {
  background: #FFFFFF;
  color: #D85C26;
}

.daily-action-secondary {
  background: rgba(255, 255, 255, 0.14);
  color: #FFFFFF;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1B2A1B;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9A6E61;
}

.plan-loading-card,
.plan-empty-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(138, 72, 32, 0.06);
}

.plan-loading-title,
.plan-empty-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.5;
  color: #2F241F;
  font-weight: 700;
}

.plan-loading-desc,
.plan-empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8F756C;
}

.plan-card {
  background: linear-gradient(180deg, #FFFDF9 0%, #FFF5EB 100%);
  border: 2rpx solid rgba(255, 126, 75, 0.14);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(138, 72, 32, 0.06);
}

.plan-card + .plan-card {
  margin-top: 18rpx;
}

.plan-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.plan-type {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 107, 53, 0.1);
  color: #D85C26;
  font-size: 22rpx;
  font-weight: 700;
}

.plan-status {
  font-size: 22rpx;
  color: #9A6E61;
}

.plan-status-done {
  color: #2E8B57;
  font-weight: 700;
}

.plan-title {
  display: block;
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.45;
  color: #2F241F;
  font-weight: 800;
}

.plan-reason {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #694E44;
}

.plan-summary {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #92766B;
}

.plan-actions {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.plan-link {
  flex: 1;
  font-size: 24rpx;
  color: #D85C26;
  font-weight: 700;
}

.plan-complete-btn {
  min-width: 176rpx;
  padding: 16rpx 22rpx;
  text-align: center;
  border-radius: 18rpx;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.plan-complete-btn-done {
  background: #E3F3E9;
  color: #2E8B57;
}

/* 模块网格 */
.module-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.module-card {
  width: calc((100% - 32rpx) / 3);
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 22rpx 14rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: all 0.3s;
}

.module-card-disabled {
  opacity: 0.45;
}

.module-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.module-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1B2A1B;
  display: block;
  margin-bottom: 4rpx;
}

.module-desc {
  font-size: 20rpx;
  color: #A08C86;
}

/* 快速入口 */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.quick-action {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.3s;
}

.quick-action:active {
  transform: scale(0.99);
}

.quick-content {
  flex: 1;
}

.quick-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1B2A1B;
  display: block;
  margin-bottom: 6rpx;
}

.quick-desc {
  font-size: 24rpx;
  color: #A08C86;
}

.quick-arrow {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 600;
}

.quick-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.quick-share {
  font-size: 22rpx;
  color: #2F80ED;
}

.progress-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.progress-line {
  display: block;
  font-size: 24rpx;
  color: #1B2A1B;
  line-height: 1.7;
}

.progress-action {
  display: inline-block;
  font-size: 24rpx;
  color: #FF6B35;
}

.progress-actions {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-share {
  font-size: 22rpx;
  color: #2F80ED;
}

/* 运营位卡片 */
.touchpoint-section {
  margin-bottom: 0;
}

.touchpoint-card {
  background: linear-gradient(135deg, #FFF7F0, #FFFCF8);
  border: 2rpx solid #FFE0C8;
  border-radius: 20rpx;
  padding: 24rpx;
}

.touchpoint-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.touchpoint-eyebrow {
  font-size: 22rpx;
  color: #FF6B35;
  background: #FFF0E5;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  display: inline-block;
}

.touchpoint-arrow {
  font-size: 28rpx;
  color: #CCB0A0;
}

.touchpoint-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1B2A1B;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.touchpoint-desc {
  display: block;
  font-size: 24rpx;
  color: #7A6660;
  line-height: 1.6;
}

.touchpoint-cta {
  margin-top: 16rpx;
}

.touchpoint-cta-text {
  display: inline-block;
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B35;
  padding: 8rpx 0;
}

/* 提示卡片 */
.tips-card {
  margin: 0 32rpx;
  background: #FFF8E1;
  border-radius: 20rpx;
  padding: 24rpx;
  border-left: 8rpx solid #FFC107;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #E65100;
  display: block;
  margin-bottom: 12rpx;
}

.tips-content {
  font-size: 24rpx;
  color: #795548;
  line-height: 1.6;
}
