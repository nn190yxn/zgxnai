/* 首页样式 */

.page {
  min-height: 100vh;
  background: #FAF6F3;
  padding-bottom: 40rpx;
}

.safe-mode {
  min-height: 100vh;
  padding: 120rpx 48rpx;
  box-sizing: border-box;
  background: #FAF6F3;
}

.safe-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #1B2A1B;
  line-height: 1.45;
}

.safe-desc {
  display: block;
  margin-top: 28rpx;
  font-size: 30rpx;
  color: #FF6B35;
  font-weight: 700;
}

.safe-note {
  display: block;
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7A6660;
}

/* 核心重构首屏 */
.core-hero {
  padding: 32rpx 32rpx 28rpx;
  background: #F7EFE8;
}

.core-hero-content {
  padding: 34rpx 30rpx 30rpx;
  border-radius: 28rpx;
  background: #2F241F;
  box-shadow: 0 16rpx 38rpx rgba(70, 42, 28, 0.16);
}

.core-brand {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 234, 0.14);
  color: #FFE7D2;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 700;
}

.core-title {
  display: block;
  margin-top: 22rpx;
  font-size: 46rpx;
  line-height: 1.28;
  font-weight: 900;
  color: #FFFFFF;
}

.core-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.65;
  color: rgba(255, 246, 238, 0.88);
}

.core-primary-action {
  margin-top: 30rpx;
  min-height: 92rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-primary-action-text {
  font-size: 29rpx;
  line-height: 1.45;
  font-weight: 900;
  color: #D85C26;
}

.core-scenes {
  margin-top: 26rpx;
}

.core-scenes-header {
  margin-bottom: 18rpx;
}

.core-scenes-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.45;
  color: #2F241F;
  font-weight: 850;
}

.core-scenes-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #8F756C;
}

.core-scene-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.core-scene-item {
  min-height: 168rpx;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 2rpx solid transparent;
  box-shadow: 0 8rpx 24rpx rgba(93, 62, 45, 0.07);
  box-sizing: border-box;
}

.core-scene-item-active {
  border-color: #D85C26;
  background: #FFF8F1;
}

.core-scene-name {
  display: block;
  font-size: 27rpx;
  line-height: 1.45;
  font-weight: 850;
  color: #2F241F;
}

.core-scene-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #7A6660;
}

.core-age-panel {
  margin-top: 20rpx;
  padding: 24rpx 22rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(93, 62, 45, 0.07);
}

.core-age-header {
  margin-bottom: 18rpx;
}

.core-age-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 850;
  color: #2F241F;
}

.core-age-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #8F756C;
}

.core-age-options {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.core-age-option {
  min-height: 76rpx;
  border-radius: 16rpx;
  background: #FFF8F1;
  border: 2rpx solid #F0DED2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.core-age-option-active {
  background: #2F241F;
  border-color: #2F241F;
}

.core-age-option-text {
  font-size: 26rpx;
  line-height: 1.45;
  color: #5F453B;
  font-weight: 800;
}

.core-age-option-active .core-age-option-text {
