}

.core-age-summary-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #6F5A52;
}

.core-focus-tags,
.core-ability-tags,
.core-pain-signs,
.core-result-observe-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.core-focus-tags,
.core-pain-signs,
.core-ability-tags {
