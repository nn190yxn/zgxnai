/* 搜索页面样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 32rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #666;
  margin-right: 12rpx;
  padding: 0 8rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 搜索建议区域 */
.search-suggest {
  padding: 24rpx 32rpx;
}

.suggest-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.clear-history {
  font-size: 26rpx;
  color: #999;
}

.hot-tag {
  font-size: 28rpx;
}

/* 关键词列表 */
.keyword-list {
  display: flex;
  flex-wrap: wrap;
}

.keyword-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.keyword-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.keyword-text {
  font-size: 26rpx;
  color: #666;
}

.hot-list .keyword-item {
  background: #FFF8E1;
}

.hot-list .keyword-text {
  color: #FF8F00;
}

/* 推荐搜索 */
.recommend-list {
  margin-top: 8rpx;
}

.recommend-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.recommend-item:last-child {
  border-bottom: none;
}

.recommend-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.recommend-text {
  font-size: 28rpx;
  color: #333;
}

/* 搜索结果 */
.search-results {
  padding: 24rpx 32rpx;
}

.scene-card,
.solution-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.scene-card-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.scene-category,
.solution-type {
  font-size: 22rpx;
  color: #FF6B35;
}

.scene-title,
.solution-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.scene-copy,
.solution-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

.scene-copy-action {
  margin-top: 12rpx;
  color: #333;
}

.solution-list {
  margin-bottom: 20rpx;
}

.result-count {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

/* 文章列表 */
.article-list {
  margin-top: 0;
}

.article-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  position: relative;
}

.article-main {
  display: flex;
  padding: 24rpx;
}

.article-cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.article-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-summary {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  margin-right: 12rpx;
  background: #FFF3ED;
  color: #FF6B35;
}

.tag.tag-age {
  background: #FFF8E1;
  color: #FF8F00;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
  margin-right: 16rpx;
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.favorite-btn.active {
  background: #FFEBEE;
}

.favorite-icon {
  font-size: 32rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
}
