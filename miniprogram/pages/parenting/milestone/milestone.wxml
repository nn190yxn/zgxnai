<view class="page-container">
  <view class="header">
    <text class="title">发展里程碑观察</text>
    <text class="subtitle">看看孩子这个阶段哪些已经会了</text>
    <view class="header-cover header-cover-placeholder">
      <text class="header-cover-emoji">📈</text>
      <text class="header-cover-title">分阶段观察</text>
      <text class="header-cover-desc">用几个简单问题看孩子当前状态</text>
    </view>
  </view>

  <!-- 年龄段选择 -->
  <view class="section" wx:if="{{step === 'age'}}">
    <text class="section-title">先选孩子现在的年龄段</text>
    <view class="age-grid">
      <view
        class="age-card {{selectedAge === item.id ? 'active' : ''}}"
        wx:for="{{ageRanges}}"
        wx:key="id"
        bindtap="selectAge"
        data-id="{{item.id}}"
      >
        <text class="age-name">{{item.name}}</text>
        <text class="age-months">{{item.months}}</text>
      </view>
    </view>
    <button class="btn-primary" bindtap="startAssessment" disabled="{{!selectedAge}}">开始观察</button>
  </view>

  <!-- 评估问题 -->
  <view class="section" wx:if="{{step === 'assess'}}">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
    <text class="progress-text">{{currentQuestionIndex + 1}} / {{currentIndicators.length}}</text>

    <view class="question-card" wx:if="{{currentIndicator}}">
      <view class="dimension-tag" style="background: {{currentDimension.color}}20; color: {{currentDimension.color}};">
        {{currentDimension.icon}} {{currentDimension.name}}
      </view>
      <text class="question-text">{{currentIndicator.text}}</text>
      <text class="question-hint">宝宝能做到这一点吗？</text>

      <view class="answer-options">
        <view class="answer-btn {{answers[currentIndicator.id] === true ? 'selected-yes' : ''}}" bindtap="answerYes">
          <text class="answer-icon">✅</text>
          <text class="answer-text">能做到</text>
        </view>
        <view class="answer-btn {{answers[currentIndicator.id] === false ? 'selected-no' : ''}}" bindtap="answerNo">
          <text class="answer-icon">❌</text>
          <text class="answer-text">还不能</text>
        </view>
      </view>
    </view>

    <view class="nav-buttons">
      <button class="btn-secondary" bindtap="prevQuestion" disabled="{{currentQuestionIndex === 0}}">上一题</button>
      <button class="btn-primary" bindtap="nextQuestion" wx:if="{{currentQuestionIndex < currentIndicators.length - 1}}">下一题</button>
      <button class="btn-primary" bindtap="submitAssessment" wx:if="{{currentQuestionIndex === currentIndicators.length - 1}}">看结果</button>
    </view>
  </view>

  <!-- 结果页面 -->
  <view class="section" wx:if="{{step === 'result'}}">
    <view class="result-header">
      <text class="result-title">观察结果</text>
      <view class="overall-score">
        <text class="score-number">{{overallPercentage}}</text>
        <text class="score-unit">%</text>
      </view>
      <text class="score-label">整体完成情况</text>
      <view class="level-badge {{resultLevel.tone}}" wx:if="{{resultLevel}}">{{resultLevel.name}}</view>
    </view>

    <view class="report-card" wx:if="{{resultLevel}}">
      <text class="report-title">结果怎么看</text>
      <text class="report-desc">{{resultLevel.description}}</text>
    </view>

    <view class="summary-grid">
      <view class="summary-card">
        <text class="summary-title">已经比较顺的地方</text>
        <view class="summary-item" wx:for="{{strengths}}" wx:key="id">
          <text class="summary-name" style="color: {{item.color}};">{{item.name}}</text>
          <text class="summary-score">{{item.percentage}}%</text>
        </view>
      </view>
      <view class="summary-card focus">
        <text class="summary-title">接下来先关注</text>
        <view class="summary-item" wx:for="{{focusAreas}}" wx:key="id">
          <text class="summary-name" style="color: {{item.color}};">{{item.name}}</text>
          <text class="summary-score">{{item.percentage}}%</text>
        </view>
      </view>
    </view>

    <view class="dimension-results">
      <view class="dimension-item" wx:for="{{dimensionResults}}" wx:key="id">
        <view class="dimension-info">
          <text class="dimension-icon">{{item.icon}}</text>
          <view class="dimension-text">
            <text class="dimension-name">{{item.name}}</text>
            <text class="dimension-desc">{{item.description}}</text>
          </view>
        </view>
        <view class="dimension-bar">
          <view class="dimension-fill" style="width: {{item.percentage}}%; background: {{item.color}};"></view>
        </view>
        <text class="dimension-percentage">{{item.percentage}}%</text>
      </view>
    </view>

    <view class="suggestion-section" wx:if="{{suggestions.length > 0}}">
      <text class="suggestion-title">接下来可以怎么陪</text>
      <view class="suggestion-list">
        <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="index">
          <text class="suggestion-icon">{{item.icon}}</text>
          <text class="suggestion-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <view class="practice-section" wx:if="{{practiceSuggestions.length > 0}}">
      <text class="suggestion-title">家里可以玩的小游戏</text>
      <view class="practice-card" wx:for="{{practiceSuggestions}}" wx:key="dimensionId">
        <text class="practice-dimension" style="color: {{item.color}};">{{item.name}}</text>
        <view class="practice-item" wx:for="{{item.items}}" wx:for-item="practice" wx:key="index">
          <text class="practice-dot" style="background: {{item.color}};"></text>
          <text class="practice-text">{{practice}}</text>
        </view>
      </view>
    </view>

    <view class="notice-section" wx:if="{{professionalNotes.length > 0}}">
      <text class="notice-title">需要留意的情况</text>
      <view class="notice-item" wx:for="{{professionalNotes}}" wx:key="index">
        <text class="notice-dot"></text>
        <text class="notice-text">{{item}}</text>
      </view>
    </view>

    <view class="result-actions">
      <button class="btn-primary" bindtap="restartAssessment">重新观察</button>
      <button class="btn-secondary" bindtap="goToHistory">查看历史</button>
    </view>
  </view>
</view>
