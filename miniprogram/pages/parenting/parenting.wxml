<!-- 育儿锦囊 -->
<view class="page">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">育儿锦囊</text>
    <text class="page-subtitle">专业育儿知识，陪伴孩子快乐成长</text>
  </view>

  <!-- 搜索入口 -->
  <view class="search-bar" bindtap="onSearchTap">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索育儿知识、文章...</text>
    </view>
  </view>

  <!-- 分类网格 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">知识分类</text>
    </view>
    <view class="category-grid">
      <view 
        class="category-card" 
        wx:for="{{categoryList}}" 
        wx:key="id" 
        bindtap="onCategoryTap" 
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        style="background: {{item.bgColor}}; border: 2rpx solid {{item.color}}20;"
      >
        <view class="card-icon-wrap" style="background: {{item.color}}15;">
          <text class="card-icon" style="color: {{item.color}};">{{item.emoji}}</text>
        </view>
        <text class="card-name" style="color: {{item.color}};">{{item.name}}</text>
        <text class="card-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 发展里程碑评估入口 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">成长评估</text>
    </view>
    <view class="milestone-entry" bindtap="goToMilestone">
      <view class="milestone-content">
        <text class="milestone-icon">🎯</text>
        <view class="milestone-text">
          <text class="milestone-title">发展里程碑评估</text>
          <text class="milestone-desc">了解孩子在各年龄段的发展情况</text>
        </view>
      </view>
      <text class="milestone-arrow">></text>
    </view>
  </view>

  <!-- 热门文章轮播 -->
  <view class="section" wx:if="{{hotArticles.length > 0}}">
    <view class="section-header">
      <text class="section-title">热门推荐</text>
      <text class="section-tag">精选</text>
    </view>
    <swiper 
      class="article-swiper" 
      indicator-dots="{{hotArticles.length > 1}}" 
      autoplay="{{true}}" 
      interval="5000" 
      duration="500"
      circular="{{true}}"
      bindchange="onSwiperChange"
    >
      <swiper-item wx:for="{{hotArticles}}" wx:key="id">
        <view class="swiper-card" bindtap="onSwiperTap" data-index="{{index}}">
          <view class="swiper-content">
            <text class="swiper-title">{{item.title}}</text>
            <view class="swiper-info">
              <text class="info-category">{{item.categoryName}}</text>
              <text class="info-views">👁️ {{item.viewCount || 0}}</text>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 最新文章列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最新文章</text>
      <view class="section-more" bindtap="onMoreArticlesTap">
        <text>更多</text>
        <text class="more-arrow">›</text>
      </view>
    </view>
    
    <!-- 加载中 -->
    <view class="loading-wrap" wx:if="{{loading && latestArticles.length === 0}}">
      <text class="loading-text">加载中...</text>
    </view>

    <view class="empty-wrap" wx:if="{{!loading && loadError}}">
      <text class="empty-icon">!</text>
      <text class="empty-text">加载失败</text>
      <text class="empty-desc">{{loadError}}</text>
      <button class="empty-action" size="mini" bindtap="retryLoadData">重试</button>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{!loading && !loadError && latestArticles.length === 0}}">
      <text class="empty-icon">📚</text>
      <text class="empty-text">暂无文章</text>
      <text class="empty-desc">敬请期待更多精彩内容</text>
    </view>
    
    <!-- 文章列表 -->
    <view class="article-list" wx:if="{{!loading && !loadError && latestArticles.length > 0}}">
      <view 
        class="article-card" 
        wx:for="{{latestArticles}}" 
        wx:key="id"
      >
        <view class="article-main" bindtap="onArticleTap" data-id="{{item.id}}">
          <view class="article-content no-image">
            <text class="article-title">{{item.title}}</text>
            <text class="article-summary">{{item.summary}}</text>
            <view class="article-tags">
              <text class="tag tag-primary" wx:if="{{item.categoryName}}">{{item.categoryName}}</text>
              <text class="tag tag-accent" wx:if="{{item.ageRange}}">{{item.ageRange}}</text>
            </view>
            <view class="article-meta">
              <text class="meta-item">{{item.author || '小牛育儿'}}</text>
              <text class="meta-item">{{item.publishTime}}</text>
              <text class="meta-item" wx:if="{{item.viewCount}}">👁️ {{item.viewCount}}</text>
            </view>
          </view>
        </view>
        <view 
          class="favorite-btn {{item.isFavorite ? 'active' : ''}}" 
          catchtap="onFavoriteTap" 
          data-id="{{item.id}}" 
          data-index="{{index}}"
        >
          <text class="favorite-icon">{{item.isFavorite ? '❤️' : '🤍'}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{latestArticles.length > 0}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:if="{{!loading && !hasMore}}">没有更多了</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="footer-text">更多育儿知识，持续更新中</text>
  </view>
</view>
