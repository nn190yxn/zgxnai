/* 育儿锦囊样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(145deg, #E85A29, #FF6B35 40%, #FF7E4B);
  padding: 48rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  position: relative;
  z-index: 1;
}

.recommendation-pill {
  display: inline-flex;
  margin-top: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 23rpx;
  position: relative;
  z-index: 1;
}

/* 搜索栏 */
.search-bar {
  padding: 24rpx 32rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

/* 模块 */
.section {
  padding: 24rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.section-tag {
  font-size: 22rpx;
  color: #FF8F00;
  background: #FFF8E1;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.more-arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
  color: #999;
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.category-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.category-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.card-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #FFF3ED;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.card-icon {
  font-size: 48rpx;
}

.card-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.45;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
}

/* 里程碑评估入口 */
.milestone-cover {
  display: block;
  width: 100%;
  height: 300rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.16);
}

.milestone-cover-placeholder {
  background: linear-gradient(135deg, #FFF0E8 0%, #FFE7D6 52%, #FFF8F2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.milestone-cover-emoji {
  font-size: 72rpx;
  margin-bottom: 14rpx;
}

.milestone-cover-title {
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #9A3412;
}

.milestone-cover-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #9A5B3B;
}

.milestone-entry {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
  transition: all 0.3s;
}

.milestone-entry:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.2);
}

.milestone-content {
  display: flex;
  align-items: center;
}

.milestone-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.milestone-text {
  flex: 1;
}

.milestone-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  line-height: 1.45;
}

.milestone-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.milestone-arrow {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

/* 热门文章轮播 */
.article-swiper {
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.swiper-card {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.swiper-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 80rpx 24rpx 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
}

.swiper-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.swiper-info {
  display: flex;
  align-items: center;
}

.info-category {
  font-size: 22rpx;
  color: #fff;
  background: rgba(46, 125, 50, 0.9);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  line-height: 1.45;
}

.info-views {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.45;
}

/* 文章列表 */
.article-list {
  margin-top: 0;
}

.article-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  position: relative;
}

.article-main {
  display: flex;
  padding: 24rpx;
}

.article-cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.article-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-content.no-image {
  margin-left: 0;
}

.article-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-summary {
  font-size: 24rpx;
  color: #999;
  line-height: 1.7;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  line-height: 1.45;
  margin-right: 12rpx;
}

.tag-primary {
  background: #FFF3ED;
  color: #FF6B35;
}

.tag-accent {
  background: #FFF8E1;
  color: #FF8F00;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
  margin-right: 16rpx;
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.favorite-btn.active {
  background: #FFEBEE;
}

.favorite-icon {
  font-size: 32rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  max-width: 560rpx;
  line-height: 1.7;
}

.empty-action {
  margin-top: 22rpx;
  min-width: 144rpx;
  min-height: 60rpx;
  line-height: 1.45;
  border-radius: 8rpx;
  background: #2f7cf6;
  color: #fff;
  font-size: 24rpx;
  padding: 13rpx 20rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

/* 底部提示 */
.footer-tip {
  padding: 40rpx 32rpx 20rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #aaa;
}
