/* 文章列表页面样式 */

.page {
  min-height: 100vh;
  background: #F6F7F4;
}

/* 搜索栏 */
.search-bar {
  padding: 24rpx 32rpx;
  background: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 筛选区域 */
.filter-section {
  background: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.filter-section.age-filter {
  border-bottom: none;
  padding-bottom: 20rpx;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  padding: 0 32rpx;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F5F5;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.filter-item.active {
  background: #FF6B35;
  color: #fff;
}

.filter-item.age-item {
  background: #FFF8E1;
  color: #FF8F00;
}

.filter-item.age-item.active {
  background: #FF8F00;
  color: #fff;
}

/* 文章列表区域 */
.article-section {
  padding: 24rpx 32rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

/* 文章列表 */
.article-list {
  margin-top: 0;
}

.article-card {
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 45, 37, 0.06);
  overflow: hidden;
  position: relative;
}

.article-main {
  display: flex;
  padding: 24rpx;
}

.article-cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  position: relative;
  overflow: hidden;
}

/* 占位符样式 */
.article-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f8ef 0%, #e8f0e0 100%);
  font-size: 60rpx;
}

.article-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #24312A;
  line-height: 1.36;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-summary {
  font-size: 25rpx;
  color: #667168;
  line-height: 1.58;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-right: 12rpx;
  background: #F5F8EF;
  color: #55753E;
}

.tag.tag-age {
  background: #FFF8E7;
  color: #9A6B19;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #8A948C;
  margin-right: 16rpx;
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.favorite-btn.active {
  background: #FFEBEE;
}

.favorite-icon {
  font-size: 32rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #eee;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* 骨架屏样式 */
.skeleton-container {
  padding: 0;
}

.skeleton-article {
  display: flex;
  padding: 24rpx;
}

.skeleton-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
