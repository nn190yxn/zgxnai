<view class="page-container">
  <view class="header">
    <text class="title">观察历史</text>
    <text class="subtitle">看看孩子每次有哪些变化</text>
  </view>

  <view class="history-list" wx:if="{{history.length > 0}}">
    <view class="history-item" wx:for="{{history}}" wx:key="id" bindtap="viewDetail" data-id="{{item.id}}">
      <view class="history-header">
        <text class="history-age">{{item.ageLabel}}</text>
        <text class="history-date">{{item.createdAtText}}</text>
      </view>
      <view class="history-score">
        <text class="score-value">{{item.overallPercentage}}%</text>
        <view class="score-bar">
          <view class="score-fill" style="width: {{item.overallPercentage}}%"></view>
        </view>
      </view>
      <view class="history-detail">
        <text class="detail-text">{{item.totalScore}}/{{item.totalItems}} 项达标</text>
        <text class="trend-text {{item.trendClass}}">{{item.trendText}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{history.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">还没有观察记录</text>
    <text class="empty-hint">做完一次里程碑观察，这里会留好记录</text>
  </view>

  <view class="action-bar">
    <button class="btn-primary" bindtap="startNewAssessment">再观察一次</button>
  </view>
</view>
