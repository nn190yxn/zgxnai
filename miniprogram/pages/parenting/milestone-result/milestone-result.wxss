.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  color: #fff;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.history-list {
  padding: 30rpx;
}

.history-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-age {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.history-date {
  font-size: 24rpx;
  color: #999;
}

.history-score {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B35;
  margin-right: 20rpx;
}

.score-bar {
  flex: 1;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35, #FF8C5A);
  border-radius: 8rpx;
}

.history-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-text {
  font-size: 24rpx;
  color: #999;
}

.trend-text {
  font-size: 24rpx;
  font-weight: 600;
}

.trend-text.up {
  color: #4CAF50;
}

.trend-text.down {
  color: #E8737A;
}

.trend-text.neutral {
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}
