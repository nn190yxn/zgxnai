<!-- 文章详情页面 -->
<view class="page page-transition">
  <!-- 骨架屏加载状态 -->
  <view class="skeleton-detail-container" wx:if="{{loading}}">
    <view class="skeleton skeleton-image" style="width: 100%; height: 400rpx; margin-bottom: 24rpx;"></view>
    <view class="skeleton-content" style="padding: 0 32rpx;">
      <view class="skeleton skeleton-title" style="width: 70%; margin-bottom: 24rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 40%; margin-bottom: 32rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 100%; margin-bottom: 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 100%; margin-bottom: 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 90%; margin-bottom: 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 100%; margin-bottom: 16rpx;"></view>
    </view>
  </view>

  <block wx:elif="{{article}}">
    <view class="offline-tip" wx:if="{{offlineFallback}}">当前为离线示例内容，可能与真实数据不一致</view>
    <!-- 文章头部 -->
    <view class="article-header">
      
      <!-- 标题 -->
      <view class="article-title-wrap">
        <text class="article-title">{{article.title}}</text>
        <view class="article-tags">
          <text class="tag tag-primary" wx:if="{{article.categoryName}}">{{article.categoryName}}</text>
          <text class="tag tag-accent" wx:if="{{article.ageRange}}">{{article.ageRange}}</text>
        </view>
      </view>
      
      <!-- 作者信息 -->
      <view class="article-meta">
        <view class="author-info">
          <image class="author-avatar" src="{{article.authorAvatar || '/images/tab-profile.png'}}" mode="aspectFill" />
          <text class="author-name">{{article.author || '小牛育儿'}}</text>
        </view>
        <view class="publish-info">
          <text class="publish-time">{{article.publishTime}}</text>
          <text class="view-count" wx:if="{{article.viewCount}}">👁️ {{article.viewCount}}人阅读</text>
        </view>
      </view>
    </view>

    <!-- 文章内容 -->
    <view class="article-content">
      <view class="content-section" wx:if="{{contentBlocks.length > 0}}">
        <block wx:for="{{contentBlocks}}" wx:key="index">
          <view class="content-block heading-block" wx:if="{{item.type === 'heading'}}">
            <text class="heading-mark"></text>
            <text class="content-heading">{{item.text}}</text>
          </view>

          <view class="content-block subheading-block" wx:elif="{{item.type === 'subheading'}}">
            <text class="content-subheading">{{item.text}}</text>
          </view>

          <view class="content-block lead-block" wx:elif="{{item.type === 'lead'}}">
            <text class="content-lead">{{item.text}}</text>
          </view>

          <view class="content-block list-block {{item.type}}" wx:elif="{{item.type === 'bullet' || item.type === 'ordered'}}">
            <text class="list-marker">{{item.type === 'ordered' ? item.indexText : '•'}}</text>
            <text class="list-text">{{item.text}}</text>
          </view>

          <view class="content-block tip-block" wx:elif="{{item.type === 'tip'}}">
            <text class="tip-title">{{item.title}}</text>
            <text class="tip-body">{{item.body}}</text>
          </view>

          <view class="content-block quote-block" wx:elif="{{item.type === 'quote'}}">
            <text class="quote-text">{{item.text}}</text>
          </view>

          <view class="content-block paragraph-block" wx:else>
            <text class="content-paragraph">{{item.text}}</text>
          </view>
        </block>
      </view>
      <view class="content-section rich-content-section" wx:else>
        <rich-text nodes="{{article.content}}" />
      </view>
    </view>

    <!-- 关键要点 -->
    <view class="key-points-section" wx:if="{{article.keyPoints && article.keyPoints.length > 0}}">
      <view class="section-header">
        <text class="section-title">💡 关键要点</text>
        <text class="copy-btn" bindtap="copyKeyPoints">复制</text>
      </view>
      <view class="key-points-list">
        <view class="key-point-item" wx:for="{{article.keyPoints}}" wx:key="index">
          <text class="point-index">{{index + 1}}</text>
          <text class="point-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 相关文章推荐 -->
    <view class="related-section" wx:if="{{relatedArticles.length > 0}}">
      <view class="section-header">
        <text class="section-title">📖 相关推荐</text>
      </view>
      <view class="related-list">
        <view 
          class="related-item" 
          wx:for="{{relatedArticles}}" 
          wx:key="id"
          bindtap="onRelatedArticleTap"
          data-id="{{item.id}}"
        >
          <image 
            class="related-cover" 
            src="{{item.cover || '/images/default-article.png'}}" 
            mode="aspectFill"
          />
          <view class="related-content">
            <text class="related-title">{{item.title}}</text>
            <text class="related-summary">{{item.summary}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <view class="action-btn {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">
        <text class="action-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
        <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <button class="action-btn share-btn" open-type="share">
        <text class="action-icon">📤</text>
        <text class="action-text">分享</text>
      </button>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-wrap" wx:else>
    <text class="empty-icon">📄</text>
    <text class="empty-text">文章不存在</text>
  </view>
</view>
