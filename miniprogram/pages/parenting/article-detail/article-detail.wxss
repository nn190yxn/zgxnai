/* 文章详情页面样式 */

.page {
  min-height: 100vh;
  background: #F6F7F4;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 文章头部 */
.article-header {
  background: #fff;
  margin-bottom: 20rpx;
}

.article-cover {
  width: 100%;
  height: 400rpx;
  display: block;
}

.article-title-wrap {
  padding: 24rpx 32rpx 16rpx;
}

.article-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #24312A;
  line-height: 1.36;
  margin-bottom: 16rpx;
  letter-spacing: 0;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.tag-primary {
  background: #FFF3ED;
  color: #FF6B35;
}

.tag-accent {
  background: #FFF8E1;
  color: #FF8F00;
}

.article-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.author-info {
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.author-name {
  font-size: 26rpx;
  color: #344338;
}

.publish-info {
  display: flex;
  align-items: center;
}

.publish-time {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.view-count {
  font-size: 24rpx;
  color: #999;
}

/* 文章内容 */
.article-content {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 36rpx 34rpx 42rpx;
}

.content-section {
  color: #26342B;
}

.content-block {
  margin-bottom: 24rpx;
}

.content-block:last-child {
  margin-bottom: 0;
}

.lead-block {
  padding: 24rpx 28rpx;
  background: #F5F8EF;
  border-left: 8rpx solid #7FA35D;
  border-radius: 8rpx;
}

.content-lead {
  display: block;
  font-size: 31rpx;
  line-height: 1.76;
  color: #304535;
  font-weight: 500;
}

.paragraph-block {
  padding: 2rpx 0;
}

.content-paragraph {
  display: block;
  font-size: 30rpx;
  line-height: 1.9;
  color: #344139;
  text-align: justify;
}

.heading-block {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 40rpx;
  margin-bottom: 22rpx;
}

.heading-block:first-child {
  margin-top: 0;
}

.heading-mark {
  width: 10rpx;
  height: 34rpx;
  border-radius: 6rpx;
  background: #E86B3D;
  flex-shrink: 0;
}

.content-heading {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1F2D25;
}

.subheading-block {
  margin-top: 30rpx;
  margin-bottom: 16rpx;
}

.content-subheading {
  display: block;
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #31523A;
}

.list-block {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 20rpx;
  background: #FAFBF7;
  border-radius: 8rpx;
  margin-bottom: 14rpx;
}

.list-block.ordered {
  background: #F4F8FB;
}

.list-marker {
  min-width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #E86B3D;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.list-block.bullet .list-marker {
  background: #7FA35D;
}

.list-text {
  flex: 1;
  font-size: 29rpx;
  line-height: 1.7;
  color: #334038;
}

.tip-block {
  padding: 24rpx 26rpx;
  background: #FFF8E7;
  border: 1rpx solid #F1D9A7;
  border-radius: 8rpx;
}

.tip-title {
  display: block;
  font-size: 29rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #9A6B19;
  margin-bottom: 10rpx;
}

.tip-body {
  display: block;
  font-size: 29rpx;
  line-height: 1.78;
  color: #4A3B23;
}

.quote-block {
  padding: 22rpx 26rpx;
  background: #F4F6F7;
  border-left: 8rpx solid #78909C;
  border-radius: 8rpx;
}

.quote-text {
  display: block;
  font-size: 29rpx;
  line-height: 1.78;
  color: #3B4A50;
}

.rich-content-section {
  font-size: 30rpx;
  line-height: 1.86;
}

.rich-content-section image {
  max-width: 100%;
  display: block;
  margin: 20rpx 0;
  border-radius: 12rpx;
}

.rich-content-section p {
  margin-bottom: 20rpx;
}

.rich-content-section h1,
.rich-content-section h2,
.rich-content-section h3 {
  font-weight: 700;
  margin: 30rpx 0 16rpx;
}

.rich-content-section h1 {
  font-size: 36rpx;
}

.rich-content-section h2 {
  font-size: 34rpx;
}

.rich-content-section h3 {
  font-size: 32rpx;
}

/* 关键要点 */
.key-points-section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 24rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.copy-btn {
  font-size: 26rpx;
  color: #FF6B35;
  padding: 8rpx 20rpx;
  border: 1rpx solid #FF6B35;
  border-radius: 24rpx;
}

.key-points-list {
  background: #F9FBE7;
  border-radius: 16rpx;
  padding: 20rpx;
}

.key-point-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #FFF3ED;
}

.key-point-item:last-child {
  border-bottom: none;
}

.point-index {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #FF6B35;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.point-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 相关文章 */
.related-section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 24rpx 32rpx;
}

.related-list {
  margin-top: 16rpx;
}

.related-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.related-item:last-child {
  border-bottom: none;
}

.related-cover {
  width: 160rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.related-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.related-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.related-summary {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 0 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.action-btn.active .action-text {
  color: #E53935;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}

.share-btn {
  background: transparent;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 互动区域 */
.interaction-section {
  background: #fff;
  margin: 20rpx 0;
  padding: 32rpx;
}

/* 点赞和收藏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 40rpx;
}

.action-item .action-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.action-item .action-count {
  font-size: 24rpx;
  color: #666;
}

.action-item .action-text {
  font-size: 24rpx;
  color: #666;
}

.action-item.active .action-text,
.action-item.active .action-count {
  color: #E53935;
}

/* 评论输入 */
.comment-input-section {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.comment-submit {
  margin-left: 20rpx;
  padding: 16rpx 32rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

/* 评论列表 */
.comments-section {
  margin-top: 32rpx;
}

.comments-section .section-header {
  margin-bottom: 24rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.comment-author {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}
