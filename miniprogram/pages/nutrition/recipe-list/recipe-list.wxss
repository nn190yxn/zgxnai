/* 食谱列表页面样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 32rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-input::placeholder {
  color: #999;
}

.clear-btn {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 筛选区域 */
.filter-section {
  background: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
  padding: 0 32rpx;
}

.filter-item {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #666;
  background: #F5F5F5;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.filter-item.active {
  color: #fff;
  background: #FF6B35;
}

.filter-item.age-item {
  font-size: 24rpx;
}

.age-filter {
  border-bottom: none;
}

/* 食谱区域 */
.recipe-section {
  padding: 24rpx 32rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.6;
}

.empty-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: #999;
}

/* 食谱列表 */
.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recipe-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.recipe-main {
  display: flex;
  padding: 20rpx;
}

.recipe-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.recipe-visual {
  background: linear-gradient(135deg, #FFF3ED 0%, #FFF8E1 56%, #E8F5E9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.recipe-visual::before {
  content: '';
  position: absolute;
  right: -28rpx;
  top: -28rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 107, 53, 0.12);
}

.recipe-visual::after {
  content: '';
  position: absolute;
  left: -28rpx;
  bottom: -28rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(67, 160, 71, 0.1);
}

.recipe-visual-thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.recipe-visual-icon {
  font-size: 70rpx;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.recipe-visual-title {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #7A4B2E;
  position: relative;
  z-index: 1;
}

.recipe-content {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.65;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  line-height: 1.45;
  background: #FFF3ED;
  color: #FF6B35;
}

.recipe-meta {
  display: flex;
  gap: 16rpx;
  margin-top: auto;
}

.meta-item {
  font-size: 22rpx;
  line-height: 1.45;
  color: #999;
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.favorite-btn.active {
  background: #FFEBEE;
}

.favorite-icon {
  font-size: 32rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #eee;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* 骨架屏样式 */
.skeleton-container {
  padding: 0;
}

.skeleton-recipe {
  display: flex;
  padding: 20rpx;
}

.skeleton-content {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
