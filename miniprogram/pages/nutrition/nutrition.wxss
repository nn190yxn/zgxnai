/* 营养中心样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(145deg, #E85A29, #FF6B35 40%, #FF7E4B);
  padding: 48rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
  line-height: 1.45;
  position: relative;
  z-index: 1;
  word-break: break-word;
}

.page-subtitle {
  font-size: 26rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.85);
  position: relative;
  z-index: 1;
  word-break: break-word;
}

/* 搜索栏 */
.search-bar {
  padding: 24rpx 32rpx;
  background: #fff;
  margin-top: -20rpx;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
  z-index: 2;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-input::placeholder {
  color: #999;
}

.nutrition-cover-wrap {
  padding: 0 32rpx 8rpx;
  background: #fff;
}

.nutrition-cover {
  display: block;
  width: 100%;
  height: 300rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.14);
}

.nutrition-cover-placeholder {
  background: linear-gradient(135deg, #FFF3ED 0%, #FFF8E1 54%, #E8F5E9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.nutrition-cover-emoji {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.nutrition-cover-title {
  font-size: 36rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #6B3417;
}

.nutrition-cover-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8A5A44;
}

.age-switch-section {
  padding: 16rpx 32rpx 8rpx;
  background: #fff;
}

.compact-header {
  margin-bottom: 16rpx;
}

.section-subtext {
  font-size: 22rpx;
  line-height: 1.55;
  color: #999;
}

.age-switch-scroll {
  white-space: nowrap;
}

.age-switch-list {
  display: flex;
  padding-bottom: 4rpx;
}

.age-switch-item {
  flex-shrink: 0;
  margin-right: 16rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #FFF3ED;
  color: #A04B20;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 600;
}

.age-switch-item.active {
  background: linear-gradient(135deg, #FF6B35, #FF8A55);
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(255, 107, 53, 0.22);
}

/* 区块 */
.section {
  padding: 24rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #333;
  min-width: 0;
  word-break: break-word;
}

.section-tag {
  font-size: 22rpx;
  color: #FF8F00;
  background: #FFF8E1;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  line-height: 1.45;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.more-arrow {
  margin-left: 4rpx;
  font-size: 32rpx;
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advice-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.05);
}

.advice-badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #FFF3ED;
  color: #D65A28;
  font-size: 20rpx;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.advice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.45;
}

.advice-content {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
}

/* 分类滚动 */
.category-scroll {
  overflow-x: auto;
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.category-list {
  display: flex;
  padding-right: 32rpx;
}

.category-item {
  flex-shrink: 0;
  width: 160rpx;
  text-align: center;
  margin-right: 24rpx;
  padding: 24rpx 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.category-item:active {
  transform: scale(0.95);
}

.category-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #FFF3ED;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
}

.category-icon {
  font-size: 40rpx;
}

.category-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.category-desc {
  display: block;
  font-size: 20rpx;
  line-height: 1.45;
  color: #999;
}

/* 今日推荐卡片 */
.recommend-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.recommend-image {
  width: 100%;
  height: 320rpx;
}

.recipe-visual {
  background: linear-gradient(135deg, #FFF3ED 0%, #FFF8E1 56%, #E8F5E9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.recipe-visual::before {
  content: '';
  position: absolute;
  right: -42rpx;
  top: -42rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: rgba(255, 107, 53, 0.12);
}

.recipe-visual::after {
  content: '';
  position: absolute;
  left: -36rpx;
  bottom: -36rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(67, 160, 71, 0.1);
}

.recipe-visual-large {
  width: 100%;
  height: 320rpx;
}

.recipe-visual-thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.recipe-visual-icon {
  font-size: 70rpx;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.recipe-visual-large .recipe-visual-icon {
  font-size: 96rpx;
}

.recipe-visual-title {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #7A4B2E;
  position: relative;
  z-index: 1;
}

.recipe-visual-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #A06A3A;
  position: relative;
  z-index: 1;
}

.recommend-content {
  padding: 24rpx;
}

.recommend-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.45;
}

.recommend-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.65;
  margin-bottom: 16rpx;
}

.recommend-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.recommend-info {
  display: flex;
  gap: 24rpx;
}

.info-item {
  font-size: 24rpx;
  line-height: 1.45;
  color: #666;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  line-height: 1.45;
}

.tag-primary {
  background: #FFF3ED;
  color: #FF6B35;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #999;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  max-width: 560rpx;
  line-height: 1.7;
}

.empty-action {
  margin-top: 22rpx;
  min-width: 144rpx;
  min-height: 60rpx;
  line-height: 1.45;
  border-radius: 8rpx;
  background: #2f7cf6;
  color: #fff;
  font-size: 24rpx;
  padding: 13rpx 20rpx;
}

/* 食谱列表 */
.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recipe-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.recipe-main {
  display: flex;
  padding: 20rpx;
}

.recipe-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.recipe-content {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.65;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.recipe-meta {
  display: flex;
  gap: 20rpx;
  margin-top: auto;
}

.meta-item {
  font-size: 22rpx;
  line-height: 1.45;
  color: #999;
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.favorite-btn.active {
  background: #FFEBEE;
}

.favorite-icon {
  font-size: 32rpx;
}

/* 底部提示 */
.footer-tip {
  padding: 40rpx 32rpx 20rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #aaa;
}
