<!-- 营养中心 -->
<view class="page">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">营养中心</text>
    <text class="page-subtitle">科学饮食，助力孩子健康成长</text>
  </view>

  <!-- 搜索入口 -->
  <view class="search-bar" bindtap="onSearchTap">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索食谱、食材..." 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
    </view>
  </view>

  <view class="nutrition-cover-wrap">
    <image class="nutrition-cover" src="/images/nutrition-cover.png" mode="aspectFill" />
  </view>

  <!-- 分类入口 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">食谱分类</text>
    </view>
    <view class="category-scroll">
      <view class="category-list">
        <view 
          class="category-item" 
          wx:for="{{categoryList}}" 
          wx:key="id" 
          bindtap="onCategoryTap" 
          data-id="{{item.id}}"
          data-name="{{item.name}}"
        >
          <view class="category-icon-wrap">
            <text class="category-icon">{{item.icon}}</text>
          </view>
          <text class="category-name">{{item.name}}</text>
          <text class="category-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 今日推荐 -->
  <view class="section" wx:if="{{todayRecommend}}">
    <view class="section-header">
      <text class="section-title">今日推荐</text>
      <text class="section-tag">精选</text>
    </view>
    <view class="recommend-card" bindtap="onTodayRecommendTap">
      <image 
        wx:if="{{todayRecommend.hasImage}}"
        class="recommend-image" 
        src="{{todayRecommend.image}}" 
        mode="aspectFill"
      />
      <view wx:if="{{!todayRecommend.hasImage}}" class="recipe-visual recipe-visual-large">
        <text class="recipe-visual-icon">{{todayRecommend.visualIcon}}</text>
        <text class="recipe-visual-title">{{todayRecommend.category || '儿童营养'}}</text>
        <text class="recipe-visual-subtitle">{{todayRecommend.nutrition.highlight || '家常搭配'}}</text>
      </view>
      <view class="recommend-content">
        <text class="recommend-name">{{todayRecommend.name}}</text>
        <text class="recommend-desc">{{todayRecommend.description}}</text>
        <view class="recommend-tags">
          <text class="tag tag-primary" wx:for="{{todayRecommend.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
        <view class="recommend-info">
          <text class="info-item">⏱️ {{todayRecommend.cookTime || '30分钟'}}</text>
          <text class="info-item">🔥 {{todayRecommend.calories || '200卡'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 热门食谱 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门食谱</text>
      <view class="section-more" bindtap="onMoreHotTap">
        <text>更多</text>
        <text class="more-arrow">›</text>
      </view>
    </view>
    
    <!-- 加载中 -->
    <view class="loading-wrap" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <view class="empty-wrap" wx:if="{{!loading && loadError}}">
      <text class="empty-icon">!</text>
      <text class="empty-text">加载失败</text>
      <text class="empty-desc">{{loadError}}</text>
      <button class="empty-action" size="mini" bindtap="retryLoadData">重试</button>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{!loading && !loadError && hotRecipes.length === 0}}">
      <text class="empty-icon">🍽️</text>
      <text class="empty-text">暂无热门食谱</text>
    </view>
    
    <!-- 食谱列表 -->
    <view class="recipe-list" wx:if="{{!loading && !loadError && hotRecipes.length > 0}}">
      <view 
        class="recipe-card" 
        wx:for="{{hotRecipes}}" 
        wx:key="id"
      >
        <view class="recipe-main" bindtap="onRecipeTap" data-id="{{item.id}}">
          <image 
            wx:if="{{item.hasImage}}"
            class="recipe-image" 
            src="{{item.image}}" 
            mode="aspectFill"
          />
          <view wx:if="{{!item.hasImage}}" class="recipe-visual recipe-visual-thumb">
            <text class="recipe-visual-icon">{{item.visualIcon}}</text>
            <text class="recipe-visual-title">{{item.category || '食谱'}}</text>
          </view>
          <view class="recipe-content">
            <text class="recipe-name">{{item.name}}</text>
            <text class="recipe-desc">{{item.description}}</text>
            <view class="recipe-tags">
              <text class="tag tag-primary" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
            </view>
            <view class="recipe-meta">
              <text class="meta-item">⏱️ {{item.cookTime}}</text>
              <text class="meta-item">👁️ {{item.viewCount}}</text>
            </view>
          </view>
        </view>
        <view 
          class="favorite-btn {{item.isFavorite ? 'active' : ''}}" 
          catchtap="onFavoriteTap" 
          data-id="{{item.id}}" 
          data-index="{{index}}"
        >
          <text class="favorite-icon">{{item.isFavorite ? '❤️' : '🤍'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="footer-text">更多美味食谱，持续更新中</text>
  </view>
</view>
