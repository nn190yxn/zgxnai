<!-- 食谱详情页面 -->
<view class="page page-transition">
  <!-- 骨架屏加载状态 -->
  <view class="skeleton-detail-container" wx:if="{{loading}}">
    <view class="skeleton skeleton-image" style="width: 100%; height: 400rpx; margin-bottom: 24rpx;"></view>
    <view class="skeleton-content" style="padding: 0 32rpx;">
      <view class="skeleton skeleton-title" style="width: 60%; margin-bottom: 24rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 100%; margin-bottom: 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 80%; margin-bottom: 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width: 90%; margin-bottom: 32rpx;"></view>
      <view class="skeleton-section">
        <view class="skeleton skeleton-title" style="width: 30%; margin-bottom: 20rpx;"></view>
        <view class="skeleton skeleton-text" style="width: 100%; margin-bottom: 16rpx;"></view>
        <view class="skeleton skeleton-text" style="width: 100%; margin-bottom: 16rpx;"></view>
      </view>
    </view>
  </view>

  <block wx:elif="{{recipe}}">
    <view class="offline-tip" wx:if="{{offlineFallback}}">当前为离线示例内容，可能与真实数据不一致</view>
    <!-- 食谱图片 -->
    <view class="recipe-header">
      <image
        wx:if="{{recipe.hasImage}}"
        class="recipe-image image-fade-in {{imageLoaded ? 'loaded' : ''}}"
        src="{{recipe.image}}"
        mode="aspectFill"
        lazy-load="{{true}}"
        bindload="onImageLoad"
        bindtap="previewImage"
        data-url="{{recipe.image}}"
      />
      <view wx:if="{{!recipe.hasImage}}" class="recipe-visual recipe-visual-hero">
        <text class="recipe-visual-icon">{{recipe.visualIcon}}</text>
        <text class="recipe-visual-title">{{recipe.category || '儿童营养食谱'}}</text>
        <text class="recipe-visual-subtitle">{{recipe.nutrition.highlight || '家常营养搭配'}}</text>
      </view>
      <view class="header-actions">
        <view class="action-btn {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">
          <text class="action-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
          <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
        </view>
        <button class="action-btn share-btn" open-type="share">
          <text class="action-icon">📤</text>
          <text class="action-text">分享</text>
        </button>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="info-section">
      <text class="recipe-name">{{recipe.name}}</text>
      <text class="recipe-desc">{{recipe.description}}</text>
      <view class="offline-tip" wx:if="{{recipe.contentNotice}}">{{recipe.contentNotice}}</view>
      <view class="summary-pills">
        <text class="summary-pill">{{recipe.category || '营养食谱'}}</text>
        <text class="summary-pill">{{recipe.ageRange || '儿童适用'}}</text>
        <text class="summary-pill">{{recipe.calories || '200卡'}}</text>
      </view>
      
      <!-- 营养标签 -->
      <view class="nutrition-tags" wx:if="{{recipe.tags && recipe.tags.length > 0}}">
        <text class="tag" wx:for="{{recipe.tags}}" wx:key="*this">{{item}}</text>
      </view>

      <!-- 基本信息 -->
      <view class="basic-info">
        <view class="info-item">
          <text class="info-icon">⏱️</text>
          <text class="info-label">烹饪时间</text>
          <text class="info-value">{{recipe.cookTime || '30分钟'}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">🔥</text>
          <text class="info-label">热量</text>
          <text class="info-value">{{recipe.calories || '200卡'}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">📊</text>
          <text class="info-label">难度</text>
          <text class="info-value">{{recipe.difficulty || '简单'}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">👶</text>
          <text class="info-label">适合年龄</text>
          <text class="info-value">{{recipe.ageRange || '1-3岁'}}</text>
        </view>
      </view>
    </view>

    <!-- 营养建议 -->
    <view class="section" wx:if="{{recipe.nutrition}}">
      <view class="section-header">
        <text class="section-title">营养建议</text>
      </view>
      
      <!-- 营养亮点 -->
      <view class="nutrition-highlight" wx:if="{{recipe.nutrition.highlight}}">
        <text class="highlight-icon">💡</text>
        <text class="highlight-text">{{recipe.nutrition.highlight}}</text>
      </view>
      
      <!-- 主要营养成分 -->
      <view class="nutrition-card">
        <view class="nutrition-item" wx:if="{{recipe.nutrition.protein}}">
          <text class="nutrition-name">蛋白质</text>
          <view class="nutrition-bar-wrap">
            <view class="nutrition-bar" style="width: {{recipe.nutrition.proteinPercent || 50}}%;"></view>
          </view>
          <text class="nutrition-value">{{recipe.nutrition.protein}}</text>
        </view>
        <view class="nutrition-item" wx:if="{{recipe.nutrition.carbs}}">
          <text class="nutrition-name">碳水化合物</text>
          <view class="nutrition-bar-wrap">
            <view class="nutrition-bar carbs" style="width: {{recipe.nutrition.carbsPercent || 50}}%;"></view>
          </view>
          <text class="nutrition-value">{{recipe.nutrition.carbs}}</text>
        </view>
        <view class="nutrition-item" wx:if="{{recipe.nutrition.fat}}">
          <text class="nutrition-name">脂肪</text>
          <view class="nutrition-bar-wrap">
            <view class="nutrition-bar fat" style="width: {{recipe.nutrition.fatPercent || 50}}%;"></view>
          </view>
          <text class="nutrition-value">{{recipe.nutrition.fat}}</text>
        </view>
        <view class="nutrition-item" wx:if="{{recipe.nutrition.fiber}}">
          <text class="nutrition-name">膳食纤维</text>
          <view class="nutrition-bar-wrap">
            <view class="nutrition-bar fiber" style="width: {{recipe.nutrition.fiberPercent || 50}}%;"></view>
          </view>
          <text class="nutrition-value">{{recipe.nutrition.fiber}}</text>
        </view>
      </view>
      
      <!-- 维生素和矿物质 -->
      <view class="nutrition-micronutrients" wx:if="{{recipe.nutrition.calcium || recipe.nutrition.iron || recipe.nutrition.zinc || recipe.nutrition.vitaminC || recipe.nutrition.vitaminA}}">
        <view class="micronutrient-title">维生素与矿物质</view>
        <view class="micronutrient-grid">
          <view class="micronutrient-item" wx:if="{{recipe.nutrition.calcium}}">
            <text class="micronutrient-name">钙</text>
            <text class="micronutrient-value">{{recipe.nutrition.calcium}}</text>
          </view>
          <view class="micronutrient-item" wx:if="{{recipe.nutrition.iron}}">
            <text class="micronutrient-name">铁</text>
            <text class="micronutrient-value">{{recipe.nutrition.iron}}</text>
          </view>
          <view class="micronutrient-item" wx:if="{{recipe.nutrition.zinc}}">
            <text class="micronutrient-name">锌</text>
            <text class="micronutrient-value">{{recipe.nutrition.zinc}}</text>
          </view>
          <view class="micronutrient-item" wx:if="{{recipe.nutrition.vitaminC}}">
            <text class="micronutrient-name">维生素C</text>
            <text class="micronutrient-value">{{recipe.nutrition.vitaminC}}</text>
          </view>
          <view class="micronutrient-item" wx:if="{{recipe.nutrition.vitaminA}}">
            <text class="micronutrient-name">维生素A</text>
            <text class="micronutrient-value">{{recipe.nutrition.vitaminA}}</text>
          </view>
        </view>
      </view>
      
      <!-- 营养搭配建议 -->
      <view class="nutrition-combination" wx:if="{{recipe.nutrientCombination}}">
        <view class="combination-title">营养搭配建议</view>
        <text class="combination-text">{{recipe.nutrientCombination}}</text>
      </view>

      <view class="nutrition-combination" wx:if="{{recipe.depthSummary}}">
        <view class="combination-title">这道为什么适合当前年龄</view>
        <text class="combination-text">{{recipe.depthSummary}}</text>
      </view>

      <view class="nutrition-combination" wx:if="{{recipe.suitableScene}}">
        <view class="combination-title">更适合怎么安排</view>
        <text class="combination-text">{{recipe.suitableScene}}</text>
      </view>

      <view class="nutrition-combination" wx:if="{{recipe.ageFocus}}">
        <view class="combination-title">当前阶段重点</view>
        <text class="combination-text">{{recipe.ageFocus}}</text>
      </view>

      <!-- 每日营养占比 -->
      <view class="daily-nutrition" wx:if="{{recipe.dailyNutritionPercent}}">
        <view class="daily-title">每日营养占比</view>
        <text class="daily-text">{{recipe.dailyNutritionPercent}}</text>
      </view>

      <view class="nutrition-tips" wx:if="{{recipe.tips}}">
        <view class="combination-title">喂养建议</view>
        <text class="combination-text">{{recipe.tips}}</text>
      </view>

      <view class="nutrition-combination" wx:if="{{recipe.feedingAdvice && recipe.feedingAdvice.length > 0}}">
        <view class="combination-title">家长怎么执行更稳</view>
        <view class="advice-points">
          <view class="advice-point" wx:for="{{recipe.feedingAdvice}}" wx:key="*this">
            <text class="advice-point-index">{{index + 1}}</text>
            <text class="advice-point-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="nutrition-combination" wx:if="{{recipe.pairingAdvice && recipe.pairingAdvice.length > 0}}">
        <view class="combination-title">同餐搭配建议</view>
        <view class="advice-points">
          <view class="advice-point" wx:for="{{recipe.pairingAdvice}}" wx:key="*this">
            <text class="advice-point-index">搭</text>
            <text class="advice-point-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="nutrition-combination warning-block" wx:if="{{recipe.safetyWarnings && recipe.safetyWarnings.length > 0}}">
        <view class="combination-title">需要特别注意</view>
        <view class="advice-points">
          <view class="advice-point" wx:for="{{recipe.safetyWarnings}}" wx:key="*this">
            <text class="advice-point-index">!</text>
            <text class="advice-point-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="nutrition-combination" wx:if="{{recipe.substitutionAdvice}}">
        <view class="combination-title">孩子暂时不接受时</view>
        <text class="combination-text">{{recipe.substitutionAdvice}}</text>
      </view>
    </view>

    <!-- 食材清单 -->
    <view class="section" wx:if="{{recipe.ingredients && recipe.ingredients.length > 0}}">
      <view class="section-header">
        <text class="section-title">食材清单</text>
        <text class="section-action" bindtap="copyIngredients">复制</text>
      </view>
      <view class="ingredient-list">
        <view class="ingredient-item" wx:for="{{recipe.ingredients}}" wx:key="name">
          <text class="ingredient-name">{{item.name}}</text>
          <text class="ingredient-amount">{{item.amount}}</text>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <view class="bar-btn {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">
        <text class="bar-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
        <text class="bar-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <button class="bar-btn share-btn" open-type="share">
        <text class="bar-icon">📤</text>
        <text class="bar-text">分享</text>
      </button>
    </view>

    <!-- 占位 -->
    <view class="bottom-placeholder"></view>
  </block>

  <!-- 空状态 -->
  <view class="empty-wrap" wx:else>
    <text class="empty-icon">🍽️</text>
    <text class="empty-text">食谱不存在</text>
  </view>
</view>
