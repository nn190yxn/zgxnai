/* 食谱详情页面样式 */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
}

/* 食谱头部 */
.recipe-header {
  position: relative;
}

.recipe-image {
  width: 100%;
  height: 500rpx;
}

.recipe-visual {
  background: linear-gradient(135deg, #FFF3ED 0%, #FFF8E1 56%, #E8F5E9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.recipe-visual::before {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -70rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 107, 53, 0.12);
}

.recipe-visual::after {
  content: '';
  position: absolute;
  left: -56rpx;
  bottom: -56rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(67, 160, 71, 0.1);
}

.recipe-visual-hero {
  width: 100%;
  height: 500rpx;
}

.recipe-visual-icon {
  font-size: 126rpx;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.recipe-visual-title {
  margin-top: 22rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #7A4B2E;
  position: relative;
  z-index: 1;
}

.recipe-visual-subtitle {
  max-width: 560rpx;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #A06A3A;
  text-align: center;
  line-height: 1.45;
  position: relative;
  z-index: 1;
}

.header-actions {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.action-btn.active {
  background: #FFEBEE;
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 20rpx;
  color: #333;
}

.share-btn {
  padding: 0;
  margin: 0;
  line-height: normal;
  background: rgba(255, 255, 255, 0.95);
}

.share-btn::after {
  border: none;
}

/* 基本信息区域 */
.info-section {
  background: #fff;
  padding: 32rpx;
  margin-top: -40rpx;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
}

.recipe-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.recipe-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.summary-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.summary-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #FFF1EA;
  color: #C85C23;
  font-size: 24rpx;
  font-weight: 600;
}

/* 营养标签 */
.nutrition-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #FFF3ED;
  color: #FF6B35;
}

/* 基本信息 */
.basic-info {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, #FFF9F5 0%, #FFFFFF 100%);
  border: 1rpx solid #F9E3D6;
  border-radius: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 108rpx;
}

.info-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

/* 区块 */
.section {
  background: #fff;
  margin: 20rpx 32rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.section-action {
  font-size: 26rpx;
  color: #FF6B35;
}

/* 营养分析卡片 */
.nutrition-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.nutrition-highlight {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #FFF6E8 0%, #FFFDF7 100%);
  border-radius: 20rpx;
}

.highlight-icon {
  font-size: 34rpx;
  line-height: 1;
}

.highlight-text {
  flex: 1;
  font-size: 28rpx;
  color: #7A4B2E;
  line-height: 1.7;
  font-weight: 500;
}

.nutrition-item {
  display: flex;
  align-items: center;
}

.nutrition-name {
  width: 160rpx;
  font-size: 26rpx;
  color: #666;
}

.nutrition-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.nutrition-bar {
  height: 100%;
  background: linear-gradient(90deg, #FF8F5A, #FF7E4B);
  border-radius: 8rpx;
}

.nutrition-bar.carbs {
  background: linear-gradient(90deg, #FFB74D, #FF9800);
}

.nutrition-bar.fat {
  background: linear-gradient(90deg, #EF5350, #E53935);
}

.nutrition-bar.fiber {
  background: linear-gradient(90deg, #42A5F5, #1E88E5);
}

.nutrition-value {
  width: 100rpx;
  text-align: right;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.nutrition-micronutrients,
.nutrition-combination,
.daily-nutrition,
.nutrition-tips {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FAFBFC;
}

.micronutrient-title,
.combination-title,
.daily-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 18rpx;
}

.micronutrient-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.micronutrient-item {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #EEF1F4;
}

.micronutrient-name {
  display: block;
  font-size: 24rpx;
  color: #8A8F98;
  margin-bottom: 6rpx;
}

.micronutrient-value {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.combination-text,
.daily-text {
  display: block;
  font-size: 28rpx;
  color: #5C6470;
  line-height: 1.8;
}

.advice-points {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advice-point {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #EEF1F4;
}

.advice-point-index {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #D65A28;
  background: #FFF3ED;
  flex-shrink: 0;
}

.advice-point-text {
  flex: 1;
  font-size: 26rpx;
  color: #5C6470;
  line-height: 1.7;
}

.warning-block {
  background: #FFF8F4;
}

/* 食材清单 */
.ingredient-list {
  display: flex;
  flex-direction: column;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 28rpx;
  color: #333;
}

.ingredient-amount {
  font-size: 28rpx;
  color: #666;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-btn.active .bar-icon {
  color: #E53935;
}

.bar-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.bar-text {
  font-size: 22rpx;
  color: #666;
}

.share-btn {
  padding: 0;
  margin: 0;
  line-height: normal;
  background: transparent;
}

.share-btn::after {
  border: none;
}

/* 底部占位 */
.bottom-placeholder {
  height: 140rpx;
}
